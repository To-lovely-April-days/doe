<Window x:Class="MaxChemical.Modules.DOE.Views.DOEDesignWizardView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:converters="clr-namespace:MaxChemical.Modules.DOE.Converters"
        xmlns:vm="clr-namespace:MaxChemical.Modules.DOE.ViewModels"
        xmlns:models="clr-namespace:MaxChemical.Modules.DOE.Models"
        mc:Ignorable="d"
        Title="DOE 实验设计向导" 
        Width="960" Height="700"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <converters:EnumBoolConverter x:Key="EnumBoolConverter"/>
        <converters:NullToVisibilityConverter x:Key="NullToVis"/>
        <converters:BoolToBackgroundConverter x:Key="BoolToBackground"/>
        <converters:StepBrushConverter x:Key="StepBrush"/>

        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#1B4F72"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
        <Style x:Key="CardPanel" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══ 步骤指示器 ═══ -->
        <Border Grid.Row="0" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="20,16">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
                    <Border Width="32" Height="32" CornerRadius="16" 
                            Background="{Binding CurrentStep, Converter={StaticResource StepBrush}, ConverterParameter=1}">
                        <TextBlock Text="1" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                    </Border>
                    <TextBlock Text="因子定义" VerticalAlignment="Center" Margin="6,0,0,0"/>
                </StackPanel>
                <TextBlock Text="→" VerticalAlignment="Center" Foreground="#CCC" Margin="0,0,16,0"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
                    <Border Width="32" Height="32" CornerRadius="16"
                            Background="{Binding CurrentStep, Converter={StaticResource StepBrush}, ConverterParameter=2}">
                        <TextBlock Text="2" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                    </Border>
                    <TextBlock Text="设计方法" VerticalAlignment="Center" Margin="6,0,0,0"/>
                </StackPanel>
                <TextBlock Text="→" VerticalAlignment="Center" Foreground="#CCC" Margin="0,0,16,0"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
                    <Border Width="32" Height="32" CornerRadius="16"
                            Background="{Binding CurrentStep, Converter={StaticResource StepBrush}, ConverterParameter=3}">
                        <TextBlock Text="3" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                    </Border>
                    <TextBlock Text="矩阵预览" VerticalAlignment="Center" Margin="6,0,0,0"/>
                </StackPanel>
                <TextBlock Text="→" VerticalAlignment="Center" Foreground="#CCC" Margin="0,0,16,0"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
                    <Border Width="32" Height="32" CornerRadius="16"
                            Background="{Binding CurrentStep, Converter={StaticResource StepBrush}, ConverterParameter=4}">
                        <TextBlock Text="4" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                    </Border>
                    <TextBlock Text="响应与条件" VerticalAlignment="Center" Margin="6,0,0,0"/>
                </StackPanel>
                <TextBlock Text="→" VerticalAlignment="Center" Foreground="#CCC" Margin="0,0,16,0"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
                    <Border Width="32" Height="32" CornerRadius="16"
                            Background="{Binding CurrentStep, Converter={StaticResource StepBrush}, ConverterParameter=5}">
                        <TextBlock Text="5" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                    </Border>
                    <TextBlock Text="导入数据" VerticalAlignment="Center" Margin="6,0,0,0"/>
                </StackPanel>
                <TextBlock Text="→" VerticalAlignment="Center" Foreground="#CCC" Margin="0,0,16,0"/>
                <StackPanel Orientation="Horizontal">
                    <Border Width="32" Height="32" CornerRadius="16"
                            Background="{Binding CurrentStep, Converter={StaticResource StepBrush}, ConverterParameter=6}">
                        <TextBlock Text="6" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                    </Border>
                    <TextBlock Text="确认保存" VerticalAlignment="Center" Margin="6,0,0,0"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ═══ 内容区域 ═══ -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24,16">
            <Grid>
                <!-- Step 1: 因子定义 -->
                <StackPanel Visibility="{Binding IsStep1Visible, Converter={StaticResource BoolToVis}}">
                    <TextBlock Style="{StaticResource SectionHeader}" Text="Step 1: 定义 DOE 因子"/>
                    <Border Style="{StaticResource CardPanel}">
                        <StackPanel>
                            <TextBlock Text="添加因子并选择对应的流程参数" Foreground="#666" Margin="0,0,0,12"/>

                            <!-- 因子表格 -->
                            <DataGrid ItemsSource="{Binding Factors}" AutoGenerateColumns="False"
                                      CanUserAddRows="False" CanUserDeleteRows="False"
                                      GridLinesVisibility="Horizontal" AlternatingRowBackground="#FAFAFA"
                                      Margin="0,0,0,12" MaxHeight="320" MinHeight="100">
                                <DataGrid.Columns>
                                    <!-- 因子名称（可编辑） -->
                                    <DataGridTextColumn Header="因子名称" Binding="{Binding FactorName, UpdateSourceTrigger=PropertyChanged}" Width="120"/>

                                    <!-- ★ 新增: 因子类型选择 -->
                                    <DataGridTemplateColumn Header="因子类型" Width="90">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <ComboBox SelectedItem="{Binding FactorType, UpdateSourceTrigger=PropertyChanged}"
                                                          Margin="2" Padding="4,2" BorderThickness="1">
                                                    <ComboBox.Items>
                                                        <models:DOEFactorType>Continuous</models:DOEFactorType>
                                                        <models:DOEFactorType>Categorical</models:DOEFactorType>
                                                    </ComboBox.Items>
                                                    <ComboBox.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock>
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Text" Value="连续"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding}" Value="{x:Static models:DOEFactorType.Categorical}">
                                                                                <Setter Property="Text" Value="类别"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                        </DataTemplate>
                                                    </ComboBox.ItemTemplate>
                                                </ComboBox>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <!-- 绑定流程参数（下拉选择，类别因子显示"手动操作"提示） -->
                                    <DataGridTemplateColumn Header="绑定流程参数" Width="220">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Grid>
                                                    <!-- 连续因子: 正常的参数下拉 -->
                                                    <ComboBox ItemsSource="{Binding AvailableCandidates}"
                                                              SelectedItem="{Binding SelectedCandidate, UpdateSourceTrigger=PropertyChanged}"
                                                              DisplayMemberPath="DisplayName"
                                                              IsEditable="False"
                                                              Visibility="{Binding IsContinuous, Converter={StaticResource BoolToVis}}"
                                                              Margin="2" Padding="4,2"
                                                              BorderThickness="1">
                                                        <ComboBox.Style>
                                                            <Style TargetType="ComboBox">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsBound}" Value="False">
                                                                        <Setter Property="BorderBrush" Value="#F39C12"/>
                                                                        <Setter Property="Background" Value="#FFF8E1"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding IsBound}" Value="True">
                                                                        <Setter Property="BorderBrush" Value="#27AE60"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </ComboBox.Style>
                                                    </ComboBox>
                                                    <!-- 类别因子: 显示"手动操作"提示 -->
                                                    <TextBlock Text="手动操作（无需绑定参数）" 
                                                               Foreground="#999" FontStyle="Italic" FontSize="11"
                                                               VerticalAlignment="Center" Margin="6,0"
                                                               Visibility="{Binding IsCategorical, Converter={StaticResource BoolToVis}}"/>
                                                </Grid>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <!-- 下界（仅连续因子显示） -->
                                    <DataGridTemplateColumn Header="下界" Width="80">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBox Text="{Binding LowerBound, StringFormat={}{0:F2}, UpdateSourceTrigger=PropertyChanged}"
                                                         Visibility="{Binding IsContinuous, Converter={StaticResource BoolToVis}}"
                                                         BorderThickness="0" Padding="4,2"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <!-- 上界（仅连续因子显示） -->
                                    <DataGridTemplateColumn Header="上界" Width="80">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBox Text="{Binding UpperBound, StringFormat={}{0:F2}, UpdateSourceTrigger=PropertyChanged}"
                                                         Visibility="{Binding IsContinuous, Converter={StaticResource BoolToVis}}"
                                                         BorderThickness="0" Padding="4,2"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <!-- 水平数（连续因子显示数字，类别因子自动计算） -->
                                    <DataGridTemplateColumn Header="水平数" Width="60">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBox Text="{Binding LevelCount, UpdateSourceTrigger=PropertyChanged}"
                                                         Visibility="{Binding IsContinuous, Converter={StaticResource BoolToVis}}"
                                                         BorderThickness="0" Padding="4,2"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <!-- ★ 新增: 类别水平标签（仅类别因子显示） -->
                                    <DataGridTemplateColumn Header="类别水平" Width="160">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBox Text="{Binding CategoryLevels, UpdateSourceTrigger=PropertyChanged}"
                                                         Visibility="{Binding IsCategorical, Converter={StaticResource BoolToVis}}"
                                                         BorderThickness="0" Padding="4,2"
                                                         ToolTip="逗号分隔，如: 催化剂A,催化剂B,催化剂C"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <!-- 步长（只读，仅连续因子） -->
                                    <DataGridTemplateColumn Header="步长" Width="80">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding StepSize, StringFormat={}{0:F4}}"
                                                           Visibility="{Binding IsContinuous, Converter={StaticResource BoolToVis}}"
                                                           Padding="4,2"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <!-- 操作 -->
                                    <DataGridTemplateColumn Header="操作" Width="50">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Content="删除"
                                                        Command="{Binding DataContext.RemoveFactorCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                        CommandParameter="{Binding}" Padding="4,2" FontSize="11"
                                                        Foreground="#E74C3C" Background="Transparent" BorderThickness="0" Cursor="Hand"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>

                            <!-- 添加按钮 -->
                            <Button Content="+ 添加因子" Command="{Binding AddFactorCommand}" Padding="12,6"
                                    HorizontalAlignment="Left" Background="#F0F0F0" BorderBrush="#CCC" BorderThickness="1" Cursor="Hand"/>

                            <!-- 提示 -->
                            <TextBlock Text="提示：每个因子必须绑定一个流程参数，未绑定的因子（黄色边框）无法进入下一步" 
                                       Foreground="#999" FontSize="11" Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Step 2: 设计方法 -->
                <StackPanel Visibility="{Binding IsStep2Visible, Converter={StaticResource BoolToVis}}">
                    <TextBlock Style="{StaticResource SectionHeader}" Text="Step 2: 选择设计方法"/>
                    <Border Style="{StaticResource CardPanel}">
                        <StackPanel>
                            <!-- ── 筛选类设计 ── -->
                            <TextBlock Text="筛选类设计" FontSize="12" FontWeight="SemiBold" Foreground="#7F8C8D" Margin="0,0,0,8"/>

                            <RadioButton Content="全因子设计（Full Factorial）— 所有因子所有水平的完全组合"
                         IsChecked="{Binding SelectedMethod, Converter={StaticResource EnumBoolConverter}, ConverterParameter=FullFactorial}"
                         Margin="0,0,0,12" FontSize="14"/>

                            <RadioButton Content="部分因子设计（Fractional Factorial）— 适合因子较多的筛选实验"
                         IsChecked="{Binding SelectedMethod, Converter={StaticResource EnumBoolConverter}, ConverterParameter=FractionalFactorial}"
                         Margin="0,0,0,8" FontSize="14"/>
                            <StackPanel Orientation="Horizontal" Margin="24,0,0,12">
                                <TextBlock Text="分辨度:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <ComboBox Width="60" SelectedValue="{Binding FractionalResolution}" SelectedValuePath="Content">
                                    <ComboBoxItem Content="3"/>
                                    <ComboBoxItem Content="4"/>
                                    <ComboBoxItem Content="5"/>
                                </ComboBox>
                            </StackPanel>

                            <RadioButton Content="正交设计（Taguchi）— 标准正交表"
                         IsChecked="{Binding SelectedMethod, Converter={StaticResource EnumBoolConverter}, ConverterParameter=Taguchi}"
                         Margin="0,0,0,8" FontSize="14"/>
                            <StackPanel Orientation="Horizontal" Margin="24,0,0,16">
                                <TextBlock Text="正交表:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <ComboBox Width="80" SelectedValue="{Binding TaguchiTableType}" SelectedValuePath="Content">
                                    <ComboBoxItem Content="auto"/>
                                    <ComboBoxItem Content="L4"/>
                                    <ComboBoxItem Content="L8"/>
                                    <ComboBoxItem Content="L9"/>
                                    <ComboBoxItem Content="L16"/>
                                    <ComboBoxItem Content="L18"/>
                                    <ComboBoxItem Content="L27"/>
                                </ComboBox>
                            </StackPanel>

                            <!-- ──  新增: RSM 优化类设计 ── -->
                            <Border BorderBrush="#E0E0E0" BorderThickness="0,1,0,0" Padding="0,12,0,0" Margin="0,4,0,0">
                                <StackPanel>
                                    <TextBlock Text="RSM 响应面优化设计" FontSize="12" FontWeight="SemiBold" Foreground="#2E86C1" Margin="0,0,0,8"/>
                                    <TextBlock Text="用于拟合二阶多项式模型，找到最优工艺参数（至少 2 个因子）" 
                               FontSize="11" Foreground="#999" Margin="0,0,0,12"/>

                                    <!--  CCD -->
                                    <RadioButton Content="CCD 中心复合设计 — RSM 最常用方法，含角点+轴点+中心点"
                                 IsChecked="{Binding SelectedMethod, Converter={StaticResource EnumBoolConverter}, ConverterParameter=CCD}"
                                 Margin="0,0,0,8" FontSize="14"/>
                                    <StackPanel Orientation="Horizontal" Margin="24,0,0,12">
                                        <TextBlock Text="Alpha 类型:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <ComboBox Width="110" SelectedValue="{Binding CcdAlphaType}" SelectedValuePath="Tag">
                                            <ComboBoxItem Content="可旋转（推荐）" Tag="rotatable"/>
                                            <ComboBoxItem Content="面心" Tag="face"/>
                                            <ComboBoxItem Content="正交" Tag="orthogonal"/>
                                        </ComboBox>
                                        <TextBlock Text="中心点:" VerticalAlignment="Center" Margin="16,0,8,0"/>
                                        <TextBox Width="50" Text="{Binding CcdCenterCount, UpdateSourceTrigger=PropertyChanged}" 
                                 VerticalContentAlignment="Center"/>
                                        <TextBlock Text="(-1 = 自动)" VerticalAlignment="Center" Margin="4,0,0,0" Foreground="#999" FontSize="11"/>
                                    </StackPanel>

                                    <!--  BBD -->
                                    <RadioButton Content="Box-Behnken 设计 — 无极端角点，化工安全性更好（≥3 因子）"
                                 IsChecked="{Binding SelectedMethod, Converter={StaticResource EnumBoolConverter}, ConverterParameter=BoxBehnken}"
                                 Margin="0,0,0,8" FontSize="14"/>
                                    <StackPanel Orientation="Horizontal" Margin="24,0,0,12">
                                        <TextBlock Text="中心点:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBox Width="50" Text="{Binding BbdCenterCount, UpdateSourceTrigger=PropertyChanged}" 
                                 VerticalContentAlignment="Center"/>
                                        <TextBlock Text="(-1 = 自动)" VerticalAlignment="Center" Margin="4,0,0,0" Foreground="#999" FontSize="11"/>
                                    </StackPanel>

                                    <!--  D-Optimal -->
                                    <RadioButton Content="D-Optimal 设计 — 不规则因子空间或需要定制实验次数"
                                 IsChecked="{Binding SelectedMethod, Converter={StaticResource EnumBoolConverter}, ConverterParameter=DOptimal}"
                                 Margin="0,0,0,8" FontSize="14"/>
                                    <StackPanel Orientation="Horizontal" Margin="24,0,0,12">
                                        <TextBlock Text="实验次数:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBox Width="50" Text="{Binding DOptimalRunCount, UpdateSourceTrigger=PropertyChanged}" 
                                 VerticalContentAlignment="Center"/>
                                        <TextBlock Text="(-1 = 自动)" VerticalAlignment="Center" Margin="4,0,0,0" Foreground="#999" FontSize="11"/>
                                        <TextBlock Text="模型:" VerticalAlignment="Center" Margin="16,0,8,0"/>
                                        <ComboBox Width="100" SelectedValue="{Binding DOptimalModelType}" SelectedValuePath="Tag">
                                            <ComboBoxItem Content="线性" Tag="linear"/>
                                            <ComboBoxItem Content="交互" Tag="interaction"/>
                                            <ComboBoxItem Content="二阶（推荐）" Tag="quadratic"/>
                                        </ComboBox>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- ── 自定义 ── -->
                            <Border BorderBrush="#E0E0E0" BorderThickness="0,1,0,0" Padding="0,12,0,0" Margin="0,4,0,0">
                                <RadioButton Content="自定义（从 Excel 导入参数矩阵）"
                             IsChecked="{Binding SelectedMethod, Converter={StaticResource EnumBoolConverter}, ConverterParameter=Custom}"
                             Margin="0,0,0,8" FontSize="14"/>
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Step 3: 矩阵预览 -->
                <StackPanel Visibility="{Binding IsStep3Visible, Converter={StaticResource BoolToVis}}">
                    <TextBlock Style="{StaticResource SectionHeader}" Text="Step 3: 参数矩阵预览"/>
                    <Border Style="{StaticResource CardPanel}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <TextBlock Text="{Binding MatrixRunCount, StringFormat=共 {0} 组实验}" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                <Button Content="随机化排列" Command="{Binding RandomizeMatrixCommand}" Padding="8,4" Margin="20,0,0,0"/>
                                <TextBlock Text="中心点数:" VerticalAlignment="Center" Margin="20,0,8,0"/>
                                <TextBox Text="{Binding CenterPointCount}" Width="40" VerticalAlignment="Center"/>
                                <Button Content="添加中心点" Command="{Binding AddCenterPointsCommand}" Padding="8,4" Margin="8,0,0,0"/>
                            </StackPanel>

                            <DataGrid ItemsSource="{Binding MatrixTable}" AutoGenerateColumns="True"
              IsReadOnly="True" MaxHeight="400"
              GridLinesVisibility="All" AlternatingRowBackground="#FAFAFA"
              CanUserSortColumns="True"/>
                            <!--  新增: 设计质量评估面板（插入到 Step3 的 DataGrid 下方） -->
                            <Border Background="#F8FBFF" CornerRadius="8" BorderBrush="#D6E8FC" BorderThickness="1" 
        Padding="16,12" Margin="0,12,0,0"
        Visibility="{Binding HasDesignQuality, Converter={StaticResource BoolToVis}}">
                                <StackPanel>
                                    <TextBlock Text="设计质量评估" FontSize="13" FontWeight="SemiBold" Foreground="#1B4F72" Margin="0,0,0,8"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- D-效率 -->
                                        <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                            <TextBlock Text="D-效率" FontSize="11" Foreground="#7F8C8D"/>
                                            <TextBlock Text="{Binding QualityDEffText}" FontSize="18" FontWeight="SemiBold" Foreground="#2E86C1"/>
                                            <TextBlock Text="系数估计精度" FontSize="10" Foreground="#BDC3C7"/>
                                        </StackPanel>

                                        <!-- A-效率 -->
                                        <StackPanel Grid.Column="1" Margin="0,0,12,0">
                                            <TextBlock Text="A-效率" FontSize="11" Foreground="#7F8C8D"/>
                                            <TextBlock Text="{Binding QualityAEffText}" FontSize="18" FontWeight="SemiBold" Foreground="#27AE60"/>
                                            <TextBlock Text="方差之和" FontSize="10" Foreground="#BDC3C7"/>
                                        </StackPanel>

                                        <!-- G-效率 -->
                                        <StackPanel Grid.Column="2" Margin="0,0,12,0">
                                            <TextBlock Text="G-效率" FontSize="11" Foreground="#7F8C8D"/>
                                            <TextBlock Text="{Binding QualityGEffText}" FontSize="18" FontWeight="SemiBold" Foreground="#8E44AD"/>
                                            <TextBlock Text="预测方差均匀性" FontSize="10" Foreground="#BDC3C7"/>
                                        </StackPanel>

                                        <!-- 自由度 -->
                                        <StackPanel Grid.Column="3">
                                            <TextBlock Text="自由度" FontSize="11" Foreground="#7F8C8D"/>
                                            <TextBlock Text="{Binding QualityDofText}" FontSize="18" FontWeight="SemiBold" Foreground="#E67E22"/>
                                            <TextBlock Text="误差估计能力" FontSize="10" Foreground="#BDC3C7"/>
                                        </StackPanel>
                                    </Grid>

                                    <!-- VIF 警告 -->
                                    <TextBlock Text="提示：D-效率 > 0.7 为良好，VIF &lt; 5 无多重共线性" 
                   FontSize="10" Foreground="#95A5A6" Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Step 4: 响应变量 + 停止条件 -->
                <StackPanel Visibility="{Binding IsStep4Visible, Converter={StaticResource BoolToVis}}">
                    <TextBlock Style="{StaticResource SectionHeader}" Text="Step 4: 定义响应变量和停止条件"/>
                    <Border Style="{StaticResource CardPanel}">
                        <StackPanel>
                            <TextBlock Text="响应变量（实验结果指标）" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <DataGrid ItemsSource="{Binding Responses}" AutoGenerateColumns="False"
                                      CanUserAddRows="False" MaxHeight="150"
                                      GridLinesVisibility="Horizontal" AlternatingRowBackground="#FAFAFA" Margin="0,0,0,8">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="响应名称" Binding="{Binding ResponseName}" Width="200"/>
                                    <DataGridTextColumn Header="单位" Binding="{Binding Unit}" Width="80"/>
                                    <DataGridTemplateColumn Header="优化目标" Width="90">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <ComboBox ItemsSource="{Binding GoalOptions}" 
                      SelectedItem="{Binding Goal, UpdateSourceTrigger=PropertyChanged}"
                      Margin="2" Padding="4,2"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <DataGridTextColumn Header="下界" Binding="{Binding DesirabilityLower, StringFormat={}{0:F2}}" Width="70"/>
                                    <DataGridTextColumn Header="上界" Binding="{Binding DesirabilityUpper, StringFormat={}{0:F2}}" Width="70"/>
                                    <DataGridTextColumn Header="目标值" Binding="{Binding DesirabilityTarget, StringFormat={}{0:F2}}" Width="70"/>
                                    <DataGridTextColumn Header="权重" Binding="{Binding DesirabilityWeight, StringFormat={}{0:F1}}" Width="50"/>
                                    <DataGridTemplateColumn Header="操作" Width="60">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Content="删除" 
                                                        Command="{Binding DataContext.RemoveResponseCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                        CommandParameter="{Binding}" Padding="4,2" FontSize="11"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                            <Button Content="添加响应变量" Command="{Binding AddResponseCommand}" Padding="8,4" HorizontalAlignment="Left"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardPanel}">
                        <StackPanel>
                            <TextBlock Text="停止条件（满足时自动终止实验批次）" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <ItemsControl ItemsSource="{Binding StopConditions}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:StopConditionViewModel}">
                                        <StackPanel Orientation="Horizontal" Margin="0,4">
                                            <TextBox Text="{Binding ResponseName}" Width="120" Margin="0,0,8,0"/>
                                            <ComboBox ItemsSource="{x:Static vm:StopConditionViewModel.OperatorOptions}" 
                                                      SelectedItem="{Binding Operator}" Width="160" Margin="0,0,8,0"/>
                                            <TextBox Text="{Binding TargetValue}" Width="80" Margin="0,0,8,0"/>
                                            <Button Content="删除" 
                                                    Command="{Binding DataContext.RemoveStopConditionCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}" Padding="4,2"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <Button Content="添加停止条件" Command="{Binding AddStopConditionCommand}" Padding="8,4" HorizontalAlignment="Left" Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Step 5: 历史数据导入 -->
                <StackPanel Visibility="{Binding IsStep5Visible, Converter={StaticResource BoolToVis}}">
                    <TextBlock Style="{StaticResource SectionHeader}" Text="Step 5: 导入历史实验数据（可选）"/>
                    <Border Style="{StaticResource CardPanel}">
                        <StackPanel>
                            <TextBlock Text="导入以前的实验数据可预热 GPR 模型，加速冷启动" Foreground="#666" Margin="0,0,0,12"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <TextBox Text="{Binding ImportFilePath}" Width="500" IsReadOnly="True" Margin="0,0,8,0"/>
                                <Button Content="浏览..." Command="{Binding BrowseImportFileCommand}" Padding="12,4"/>
                                <Button Content="校验" Command="{Binding ValidateImportCommand}" Padding="12,4" Margin="8,0,0,0"/>
                            </StackPanel>
                            <TextBlock Text="要求：Excel 列名必须与上面定义的因子名称和响应名称完全匹配" Foreground="#888" FontSize="12"/>
                            <Border Margin="0,12,0,0" Padding="12" CornerRadius="4"
                                    Visibility="{Binding ValidationResult, Converter={StaticResource NullToVis}}"
                                    Background="{Binding ValidationResult.IsValid, Converter={StaticResource BoolToBackground}}">
                                <TextBlock Text="{Binding StatusMessage}" FontWeight="SemiBold"/>
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Step 6: 确认保存 -->
                <StackPanel Visibility="{Binding IsStep6Visible, Converter={StaticResource BoolToVis}}">
                    <TextBlock Style="{StaticResource SectionHeader}" Text="Step 6: 确认并保存"/>
                    <Border Style="{StaticResource CardPanel}">
                        <StackPanel>
                            <TextBlock Text="批次名称" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding BatchName}" Width="400" HorizontalAlignment="Left" Margin="0,0,0,16"/>
                            <TextBlock Text="方案摘要" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <TextBlock Text="{Binding Factors.Count, StringFormat=因子数量: {0}}" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding SelectedMethod, StringFormat=设计方法: {0}}" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding MatrixRunCount, StringFormat=实验组数: {0}}" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding Responses.Count, StringFormat=响应变量: {0}}" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding StopConditions.Count, StringFormat=停止条件: {0}}" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding ImportedDataCount, StringFormat=导入历史数据: {0} 条}" Margin="0,0,0,16"/>
                            <Button Content="保存 DOE 方案" Command="{Binding SaveBatchCommand}" 
                                    Padding="20,8" FontSize="14" FontWeight="SemiBold"
                                    Background="#2E75B6" Foreground="White" HorizontalAlignment="Left"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </ScrollViewer>

        <!-- ═══ 底部导航栏 ═══ -->
        <Border Grid.Row="2" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0" Padding="20,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <ProgressBar Width="20" Height="20" IsIndeterminate="{Binding IsLoading}"
                                 Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}" Margin="0,0,8,0"/>
                    <TextBlock Text="{Binding StatusMessage}" Foreground="#666"/>
                </StackPanel>
                <Button Grid.Column="1" Content="上一步" Command="{Binding PreviousStepCommand}" Padding="16,8" Margin="0,0,8,0"/>
                <Button Grid.Column="2" Content="下一步" Command="{Binding NextStepCommand}" Padding="16,8"
                        Background="#2E75B6" Foreground="White"/>
            </Grid>
        </Border>
    </Grid>
</Window>
