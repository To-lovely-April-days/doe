<Window x:Class="MaxChemical.Modules.DOE.Views.DOEDesignWizardView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:MaxChemical.Modules.DOE.Converters"
        xmlns:models="clr-namespace:MaxChemical.Modules.DOE.Models"
        Title="DOE 实验设计向导"
        Width="960" Height="640"
        WindowStartupLocation="CenterScreen"
        Background="#F4F7F9" WindowStyle="None" AllowsTransparency="True"
        ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="DOEWizardStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
            <converters:EnumBoolConverter x:Key="EnumBoolConverter"/>
            <converters:NullToVisibilityConverter x:Key="NullToVis"/>
            <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis"/>
            <converters:StepBrushConverter x:Key="StepBrush"/>
        </ResourceDictionary>
    </Window.Resources>

    <Border CornerRadius="14" Background="White" BorderBrush="#D8E2E8" BorderThickness="0.5"
            ClipToBounds="True">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="210"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ═══ 左侧导航栏 ═══ -->
            <Border Grid.Column="0" Background="{StaticResource WzSurface}" BorderBrush="{StaticResource WzDivider}"
                    BorderThickness="0,0,0.5,0">
                <DockPanel>
                    <!-- 品牌 -->
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="22,22,22,16">
                        <Border Width="28" Height="28" CornerRadius="8" Background="{StaticResource WzPrimary}">
                            <TextBlock Text="D" FontSize="14" FontWeight="SemiBold" Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="DOE 向导" FontSize="14" FontWeight="Medium" Foreground="{StaticResource WzText}"
                                   VerticalAlignment="Center" Margin="10,0,0,0"/>
                    </StackPanel>

                    <!-- 底部帮助 -->
                    <Border DockPanel.Dock="Bottom" Padding="22,14,22,18" BorderBrush="{StaticResource WzDivider}" BorderThickness="0,0.5,0,0">
                        <TextBlock FontSize="11" Foreground="{StaticResource WzTextHint}" TextWrapping="Wrap" LineHeight="17">
                            <Run Text="按 Esc 取消"/><LineBreak/><Run Text="进度自动保存"/>
                        </TextBlock>
                    </Border>

                    <!-- 导航步骤 -->
                    <StackPanel Margin="0,4,0,0">
                        <!-- Step 1 -->
                        <Border Style="{StaticResource WzNavItem}" MouseLeftButtonDown="NavStep_Click" Tag="1">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="22" Height="22" CornerRadius="7"
                                        Background="{Binding CurrentStep, Converter={StaticResource StepBrush}, ConverterParameter=1}">
                                    <TextBlock Text="1" FontSize="10" FontWeight="SemiBold" Foreground="White"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="因子定义" FontSize="13" VerticalAlignment="Center" Margin="11,0,0,0"
                                           Foreground="{StaticResource WzTextMuted}"/>
                            </StackPanel>
                        </Border>
                        <!-- Step 2 -->
                        <Border Style="{StaticResource WzNavItem}" MouseLeftButtonDown="NavStep_Click" Tag="2">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="22" Height="22" CornerRadius="7"
                                        Background="{Binding CurrentStep, Converter={StaticResource StepBrush}, ConverterParameter=2}">
                                    <TextBlock Text="2" FontSize="10" FontWeight="SemiBold" Foreground="White"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="设计方法" FontSize="13" VerticalAlignment="Center" Margin="11,0,0,0"
                                           Foreground="{StaticResource WzTextMuted}"/>
                            </StackPanel>
                        </Border>
                        <!-- Step 3 -->
                        <Border Style="{StaticResource WzNavItem}" MouseLeftButtonDown="NavStep_Click" Tag="3">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="22" Height="22" CornerRadius="7"
                                        Background="{Binding CurrentStep, Converter={StaticResource StepBrush}, ConverterParameter=3}">
                                    <TextBlock Text="3" FontSize="10" FontWeight="SemiBold" Foreground="White"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="矩阵预览" FontSize="13" VerticalAlignment="Center" Margin="11,0,0,0"
                                           Foreground="{StaticResource WzTextMuted}"/>
                            </StackPanel>
                        </Border>
                        <!-- Step 4 -->
                        <Border Style="{StaticResource WzNavItem}" MouseLeftButtonDown="NavStep_Click" Tag="4">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="22" Height="22" CornerRadius="7"
                                        Background="{Binding CurrentStep, Converter={StaticResource StepBrush}, ConverterParameter=4}">
                                    <TextBlock Text="4" FontSize="10" FontWeight="SemiBold" Foreground="White"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="响应与条件" FontSize="13" VerticalAlignment="Center" Margin="11,0,0,0"
                                           Foreground="{StaticResource WzTextMuted}"/>
                            </StackPanel>
                        </Border>
                        <!-- Step 5 -->
                        <Border Style="{StaticResource WzNavItem}" MouseLeftButtonDown="NavStep_Click" Tag="5">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="22" Height="22" CornerRadius="7"
                                        Background="{Binding CurrentStep, Converter={StaticResource StepBrush}, ConverterParameter=5}">
                                    <TextBlock Text="5" FontSize="10" FontWeight="SemiBold" Foreground="White"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="数据导入" FontSize="13" VerticalAlignment="Center" Margin="11,0,0,0"
                                           Foreground="{StaticResource WzTextMuted}"/>
                            </StackPanel>
                        </Border>
                        <!-- Step 6 -->
                        <Border Style="{StaticResource WzNavItem}" MouseLeftButtonDown="NavStep_Click" Tag="6">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="22" Height="22" CornerRadius="7"
                                        Background="{Binding CurrentStep, Converter={StaticResource StepBrush}, ConverterParameter=6}">
                                    <TextBlock Text="6" FontSize="10" FontWeight="SemiBold" Foreground="White"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="确认保存" FontSize="13" VerticalAlignment="Center" Margin="11,0,0,0"
                                           Foreground="{StaticResource WzTextMuted}"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- ═══ 右侧主内容 ═══ -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 顶部栏：项目信息 + 关闭按钮（可拖拽） -->
                <Border Grid.Row="0" Background="Transparent" MouseLeftButtonDown="TitleBar_MouseDown"
                        Padding="30,10,10,10" BorderBrush="{StaticResource WzDivider}" BorderThickness="0,0,0,0.5">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- 项目信息（有项目时显示） -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center"
                                    Visibility="{Binding IsProjectMode, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="{Binding ProjectName}" FontSize="12.5" FontWeight="Medium"
                                       Foreground="{StaticResource WzText}" VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis" MaxWidth="280"/>
                            <Border Background="{StaticResource WzPrimary}" CornerRadius="4"
                                    Padding="8,3" Margin="10,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding StatusMessage}" FontSize="10" FontWeight="Medium"
                                           Foreground="White"/>
                            </Border>
                        </StackPanel>

                        <!-- 关闭按钮 -->
                        <Button Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center"
                                Click="CloseBtn_Click" Width="30" Height="30" Cursor="Hand" ToolTip="关闭 (Esc)">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd" Background="Transparent" CornerRadius="8"
                                            Width="30" Height="30">
                                        <Path Data="M8,8 L18,18 M18,8 L8,18" Stroke="{StaticResource WzTextHint}"
                                              StrokeThickness="1.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Width="26" Height="26"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#FCEBEB"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </Border>

                <!-- ═══ 内容区域 ═══ -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0">
                    <Grid Margin="30,18,30,18">

                        <!-- Step 1: 因子定义 -->
                        <StackPanel Visibility="{Binding IsStep1Visible, Converter={StaticResource BoolToVis}}">
                            <Border Background="{StaticResource WzPrimaryLight}" CornerRadius="6" Padding="10,3" HorizontalAlignment="Left" Margin="0,0,0,10">
                                <TextBlock Text="STEP 1" Style="{StaticResource WzStepBadge}"/>
                            </Border>
                            <TextBlock Text="定义实验因子" FontSize="18" FontWeight="Medium" Foreground="{StaticResource WzText}" Margin="0,0,0,3"/>
                            <TextBlock Text="添加因子，设置类型和水平范围" FontSize="13" Foreground="{StaticResource WzTextSec}" Margin="0,0,0,22"/>

                            <DataGrid ItemsSource="{Binding Factors}" AutoGenerateColumns="False"
                                      CanUserAddRows="False" CanUserDeleteRows="False"
                                      GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="{StaticResource WzDivider}"
                                      Background="Transparent" BorderThickness="0" RowStyle="{StaticResource WzGridRow}"
                                      HeadersVisibility="Column" FontSize="12.5" RowHeight="42" ColumnHeaderHeight="32"
                                      Margin="0,0,0,8" MaxHeight="320" MinHeight="80">
                                <DataGrid.ColumnHeaderStyle>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Foreground" Value="{StaticResource WzTextHint}"/>
                                        <Setter Property="FontSize" Value="11"/>
                                        <Setter Property="FontWeight" Value="Medium"/>
                                        <Setter Property="Padding" Value="4,0"/>
                                        <Setter Property="BorderBrush" Value="{StaticResource WzDivider}"/>
                                        <Setter Property="BorderThickness" Value="0,0,0,0.5"/>
                                    </Style>
                                </DataGrid.ColumnHeaderStyle>
                                <DataGrid.Columns>
                                    <!-- 因子名称 -->
                                    <DataGridTemplateColumn Header="因子名称" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBox Text="{Binding FactorName, UpdateSourceTrigger=PropertyChanged}"
                                                         Style="{StaticResource WzCellInput}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <!-- 因子类型 -->
                                    <DataGridTemplateColumn Header="类型" Width="90">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <ComboBox SelectedItem="{Binding FactorType, UpdateSourceTrigger=PropertyChanged}"
                                                          Style="{StaticResource WzComboCompact}">
                                                    <ComboBox.Items>
                                                        <models:DOEFactorType>Continuous</models:DOEFactorType>
                                                        <models:DOEFactorType>Categorical</models:DOEFactorType>
                                                    </ComboBox.Items>
                                                    <ComboBox.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock>
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Text" Value="连续"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding}" Value="{x:Static models:DOEFactorType.Categorical}">
                                                                                <Setter Property="Text" Value="类别"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                        </DataTemplate>
                                                    </ComboBox.ItemTemplate>
                                                </ComboBox>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <!-- 低水平（仅连续因子） -->
                                    <DataGridTemplateColumn Header="低水平" Width="75">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBox Text="{Binding LowerBound, StringFormat={}{0:F2}, UpdateSourceTrigger=PropertyChanged}"
                                                         Style="{StaticResource WzCellNum}"
                                                         Visibility="{Binding IsContinuous, Converter={StaticResource BoolToVis}}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <!-- 高水平（仅连续因子） -->
                                    <DataGridTemplateColumn Header="高水平" Width="75">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBox Text="{Binding UpperBound, StringFormat={}{0:F2}, UpdateSourceTrigger=PropertyChanged}"
                                                         Style="{StaticResource WzCellNum}"
                                                         Visibility="{Binding IsContinuous, Converter={StaticResource BoolToVis}}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <!-- 类别水平（仅类别因子） -->
                                    <DataGridTemplateColumn Header="类别水平" Width="140">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBox Text="{Binding CategoryLevels, UpdateSourceTrigger=PropertyChanged}"
                                                         Style="{StaticResource WzCellInput}" Tag="如: A,B,C"
                                                         ToolTip="逗号分隔，如: 催化剂A,催化剂B,催化剂C"
                                                         Visibility="{Binding IsCategorical, Converter={StaticResource BoolToVis}}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <!-- 绑定参数（连续因子下拉 / 类别因子显示提示） -->
                                    <DataGridTemplateColumn Header="绑定参数" Width="140">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Grid>
                                                    <ComboBox ItemsSource="{Binding AvailableCandidates}"
                                                              SelectedItem="{Binding SelectedCandidate, UpdateSourceTrigger=PropertyChanged}"
                                                              Style="{StaticResource WzComboCompact}"
                                                              Visibility="{Binding IsContinuous, Converter={StaticResource BoolToVis}}">
                                                        <ComboBox.ItemTemplate>
                                                            <DataTemplate>
                                                                <TextBlock Text="{Binding DisplayName}"/>
                                                            </DataTemplate>
                                                        </ComboBox.ItemTemplate>
                                                    </ComboBox>
                                                    <TextBlock Text="手动操作" FontSize="11" FontStyle="Italic"
                                                               Foreground="{StaticResource WzTextHint}"
                                                               VerticalAlignment="Center" Margin="8,0"
                                                               Visibility="{Binding IsCategorical, Converter={StaticResource BoolToVis}}"/>
                                                </Grid>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <!-- 删除 -->
                                    <DataGridTemplateColumn Header="" Width="36">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Style="{StaticResource WzBtnDel}"
                                                        Command="{Binding DataContext.RemoveFactorCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                        CommandParameter="{Binding}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>

                            <Button Content="+ 添加因子" Command="{Binding AddFactorCommand}" Style="{StaticResource WzBtnAdd}"/>
                            <TextBlock Text="每个因子需绑定流程参数。类别因子在水平栏填写逗号分隔的水平值。" Style="{StaticResource WzHint}" Margin="0,12,0,0"/>
                        </StackPanel>

                        <!-- Step 2: 设计方法 -->
                        <StackPanel Visibility="{Binding IsStep2Visible, Converter={StaticResource BoolToVis}}">
                            <Border Background="{StaticResource WzPrimaryLight}" CornerRadius="6" Padding="10,3" HorizontalAlignment="Left" Margin="0,0,0,10">
                                <TextBlock Text="STEP 2" Style="{StaticResource WzStepBadge}"/>
                            </Border>
                            <TextBlock Text="选择设计方法" FontSize="18" FontWeight="Medium" Foreground="{StaticResource WzText}" Margin="0,0,0,3"/>
                            <TextBlock Text="系统根据因子数量和阶段自动推荐" FontSize="13" Foreground="{StaticResource WzTextSec}" Margin="0,0,0,20"/>

                            <!-- ══ 筛选 (Screening) ══ -->
                            <TextBlock Text="筛选 (S)" FontSize="12" FontWeight="Medium" Foreground="{StaticResource WzTextMuted}" Margin="0,0,0,8"/>
                            <TextBlock Text="从多个因子中快速识别关键影响因子" FontSize="11" Foreground="{StaticResource WzTextHint}" Margin="0,0,0,10"/>

                            <RadioButton GroupName="Method" Style="{StaticResource WzRadio}" Margin="0,0,0,4"
                                         IsChecked="{Binding SelectedMethod, Converter={StaticResource EnumBoolConverter}, ConverterParameter=PlackettBurman}">
                                <StackPanel>
                                    <TextBlock Text="Plackett-Burman 设计" FontSize="13" FontWeight="Medium"/>
                                    <TextBlock Text="经济筛选 · 实验次数为 4 的倍数 · 最多 N-1 个因子" FontSize="11" Foreground="{StaticResource WzTextHint}" Margin="0,2,0,0"/>
                                </StackPanel>
                            </RadioButton>

                            <RadioButton GroupName="Method" Style="{StaticResource WzRadio}" Margin="0,0,0,4"
                                         IsChecked="{Binding SelectedMethod, Converter={StaticResource EnumBoolConverter}, ConverterParameter=FractionalFactorial}">
                                <StackPanel>
                                    <TextBlock Text="部分因子设计（Fractional Factorial）" FontSize="13" FontWeight="Medium"/>
                                    <TextBlock Text="2^(k-p) 设计 · 分辨度可控" FontSize="11" Foreground="{StaticResource WzTextHint}" Margin="0,2,0,0"/>
                                </StackPanel>
                            </RadioButton>
                            <StackPanel Orientation="Horizontal" Margin="28,0,0,12">
                                <TextBlock Text="分辨度:" FontSize="12" Foreground="{StaticResource WzTextSec}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <ComboBox Width="60" Style="{StaticResource WzComboCompact}"
                                          SelectedValue="{Binding FractionalResolution}" SelectedValuePath="Content">
                                    <ComboBoxItem Content="3"/>
                                    <ComboBoxItem Content="4"/>
                                    <ComboBoxItem Content="5"/>
                                </ComboBox>
                            </StackPanel>

                            <!-- ══ 因子 (Factorial) ══ -->
                            <Border BorderBrush="{StaticResource WzDivider}" BorderThickness="0,0.5,0,0" Padding="0,14,0,0" Margin="0,6,0,0">
                                <StackPanel>
                                    <TextBlock Text="因子 (F)" FontSize="12" FontWeight="Medium" Foreground="{StaticResource WzTextMuted}" Margin="0,0,0,8"/>
                                    <TextBlock Text="分析主效应和交互效应" FontSize="11" Foreground="{StaticResource WzTextHint}" Margin="0,0,0,10"/>

                                    <RadioButton GroupName="Method" Style="{StaticResource WzRadio}" Margin="0,0,0,4"
                                                 IsChecked="{Binding SelectedMethod, Converter={StaticResource EnumBoolConverter}, ConverterParameter=FullFactorial}">
                                        <StackPanel>
                                            <TextBlock Text="全因子设计（Full Factorial）" FontSize="13" FontWeight="Medium"/>
                                            <TextBlock Text="所有因子所有水平的完全组合 · 无混杂" FontSize="11" Foreground="{StaticResource WzTextHint}" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </RadioButton>
                                    <StackPanel Orientation="Horizontal" Margin="28,0,0,12">
                                        <TextBlock Text="水平数:" FontSize="12" Foreground="{StaticResource WzTextSec}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <ComboBox Width="60" Style="{StaticResource WzComboCompact}"
                                                  SelectedValue="{Binding FullFactorialLevels}" SelectedValuePath="Tag">
                                            <ComboBoxItem Content="2" Tag="2"/>
                                            <ComboBoxItem Content="3" Tag="3"/>
                                        </ComboBox>
                                        <TextBlock Text="中心点:" FontSize="12" Foreground="{StaticResource WzTextSec}" VerticalAlignment="Center" Margin="16,0,8,0"/>
                                        <TextBox Width="50" Text="{Binding FullFactorialCenterCount, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource WzCellNum}"/>
                                        <TextBlock Text="(0 = 不加)" FontSize="11" Foreground="{StaticResource WzTextHint}" VerticalAlignment="Center" Margin="6,0,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- ══ 响应曲面 (Response Surface) ══ -->
                            <Border BorderBrush="{StaticResource WzDivider}" BorderThickness="0,0.5,0,0" Padding="0,14,0,0" Margin="0,6,0,0">
                                <StackPanel>
                                    <TextBlock Text="响应曲面 (R)" FontSize="12" FontWeight="Medium" Foreground="{StaticResource WzPrimary}" Margin="0,0,0,8"/>
                                    <TextBlock Text="拟合二阶多项式模型，找到最优工艺参数（至少 2 个连续因子）" FontSize="11" Foreground="{StaticResource WzTextHint}" Margin="0,0,0,10"/>

                                    <!-- CCD -->
                                    <RadioButton GroupName="Method" Style="{StaticResource WzRadio}" Margin="0,0,0,4"
                                                 IsChecked="{Binding SelectedMethod, Converter={StaticResource EnumBoolConverter}, ConverterParameter=CCD}">
                                        <StackPanel>
                                            <TextBlock Text="CCD 中心复合设计" FontSize="13" FontWeight="Medium"/>
                                            <TextBlock Text="RSM 最常用 · 含角点+轴点+中心点" FontSize="11" Foreground="{StaticResource WzTextHint}" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </RadioButton>
                                    <StackPanel Orientation="Horizontal" Margin="28,0,0,10">
                                        <TextBlock Text="Alpha 类型:" FontSize="12" Foreground="{StaticResource WzTextSec}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <ComboBox Width="120" Style="{StaticResource WzComboCompact}"
                                                  SelectedValue="{Binding CcdAlphaType}" SelectedValuePath="Tag">
                                            <ComboBoxItem Content="可旋转（推荐）" Tag="rotatable"/>
                                            <ComboBoxItem Content="面心" Tag="face"/>
                                            <ComboBoxItem Content="正交" Tag="orthogonal"/>
                                        </ComboBox>
                                        <TextBlock Text="中心点:" FontSize="12" Foreground="{StaticResource WzTextSec}" VerticalAlignment="Center" Margin="16,0,8,0"/>
                                        <TextBox Width="50" Text="{Binding CcdCenterCount, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource WzCellNum}"/>
                                        <TextBlock Text="(-1 = 自动)" FontSize="11" Foreground="{StaticResource WzTextHint}" VerticalAlignment="Center" Margin="6,0,0,0"/>
                                    </StackPanel>

                                    <!-- BBD -->
                                    <RadioButton GroupName="Method" Style="{StaticResource WzRadio}" Margin="0,0,0,4"
                                                 IsChecked="{Binding SelectedMethod, Converter={StaticResource EnumBoolConverter}, ConverterParameter=BoxBehnken}">
                                        <StackPanel>
                                            <TextBlock Text="Box-Behnken 设计" FontSize="13" FontWeight="Medium"/>
                                            <TextBlock Text="无极端角点 · 化工安全性更好（≥3 因子）" FontSize="11" Foreground="{StaticResource WzTextHint}" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </RadioButton>
                                    <StackPanel Orientation="Horizontal" Margin="28,0,0,10">
                                        <TextBlock Text="中心点:" FontSize="12" Foreground="{StaticResource WzTextSec}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBox Width="50" Text="{Binding BbdCenterCount, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource WzCellNum}"/>
                                        <TextBlock Text="(-1 = 自动)" FontSize="11" Foreground="{StaticResource WzTextHint}" VerticalAlignment="Center" Margin="6,0,0,0"/>
                                    </StackPanel>

                                    <!-- D-Optimal -->
                                    <RadioButton GroupName="Method" Style="{StaticResource WzRadio}" Margin="0,0,0,4"
                                                 IsChecked="{Binding SelectedMethod, Converter={StaticResource EnumBoolConverter}, ConverterParameter=DOptimal}">
                                        <StackPanel>
                                            <TextBlock Text="D-Optimal 设计" FontSize="13" FontWeight="Medium"/>
                                            <TextBlock Text="不规则因子空间 · 定制实验次数" FontSize="11" Foreground="{StaticResource WzTextHint}" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </RadioButton>
                                    <StackPanel Orientation="Horizontal" Margin="28,0,0,10">
                                        <TextBlock Text="实验次数:" FontSize="12" Foreground="{StaticResource WzTextSec}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBox Width="50" Text="{Binding DOptimalRunCount, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource WzCellNum}"/>
                                        <TextBlock Text="(-1 = 自动)" FontSize="11" Foreground="{StaticResource WzTextHint}" VerticalAlignment="Center" Margin="6,0,0,0"/>
                                        <TextBlock Text="模型:" FontSize="12" Foreground="{StaticResource WzTextSec}" VerticalAlignment="Center" Margin="16,0,8,0"/>
                                        <ComboBox Width="110" Style="{StaticResource WzComboCompact}"
                                                  SelectedValue="{Binding DOptimalModelType}" SelectedValuePath="Tag">
                                            <ComboBoxItem Content="线性" Tag="linear"/>
                                            <ComboBoxItem Content="交互" Tag="interaction"/>
                                            <ComboBoxItem Content="二阶（推荐）" Tag="quadratic"/>
                                        </ComboBox>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- ══ 自定义 (Custom) ══ -->
                            <Border BorderBrush="{StaticResource WzDivider}" BorderThickness="0,0.5,0,0" Padding="0,14,0,0" Margin="0,6,0,0">
                                <StackPanel>
                                    <TextBlock Text="自定义" FontSize="12" FontWeight="Medium" Foreground="{StaticResource WzTextMuted}" Margin="0,0,0,8"/>
                                    <TextBlock Text="导入已有实验方案，选择对应的分析类型" FontSize="11" Foreground="{StaticResource WzTextHint}" Margin="0,0,0,10"/>

                                    <RadioButton GroupName="Method" Style="{StaticResource WzRadio}" Margin="0,0,0,4"
                                                 IsChecked="{Binding SelectedMethod, Converter={StaticResource EnumBoolConverter}, ConverterParameter=Custom}">
                                        <StackPanel>
                                            <TextBlock Text="从 Excel 导入参数矩阵" FontSize="13" FontWeight="Medium"/>
                                            <TextBlock Text="列名需匹配因子名称" FontSize="11" Foreground="{StaticResource WzTextHint}" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </RadioButton>
                                    <StackPanel Orientation="Horizontal" Margin="28,4,0,6">
                                        <TextBlock Text="分析类型:" FontSize="12" Foreground="{StaticResource WzTextSec}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <ComboBox Width="160" Style="{StaticResource WzComboCompact}"
                                                  SelectedValue="{Binding CustomAnalysisType}" SelectedValuePath="Tag">
                                            <ComboBoxItem Content="筛选（主效应）" Tag="linear"/>
                                            <ComboBoxItem Content="因子（主效应+交互）" Tag="interaction"/>
                                            <ComboBoxItem Content="响应曲面（二阶）" Tag="quadratic"/>
                                        </ComboBox>
                                        <TextBlock Text="决定 OLS 回归的模型阶次" FontSize="11" Foreground="{StaticResource WzTextHint}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- Step 3: 矩阵预览 -->
                        <StackPanel Visibility="{Binding IsStep3Visible, Converter={StaticResource BoolToVis}}">
                            <Border Background="{StaticResource WzPrimaryLight}" CornerRadius="6" Padding="10,3" HorizontalAlignment="Left" Margin="0,0,0,10">
                                <TextBlock Text="STEP 3" Style="{StaticResource WzStepBadge}"/>
                            </Border>
                            <TextBlock Text="实验矩阵预览" FontSize="18" FontWeight="Medium" Foreground="{StaticResource WzText}" Margin="0,0,0,3"/>
                            <TextBlock Text="检查生成的实验方案，调整随机化和中心点" FontSize="13" Foreground="{StaticResource WzTextSec}" Margin="0,0,0,18"/>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                <CheckBox Content="随机化实验顺序" IsChecked="{Binding IsRandomized}" Style="{StaticResource WzCheckBox}" Margin="0,0,20,0"/>
                                <TextBlock Text="中心点:" FontSize="12" Foreground="{StaticResource WzTextSec}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBox Text="{Binding CenterPointCount}" Style="{StaticResource WzCellNum}" Width="52"/>
                                <TextBlock FontSize="12" Foreground="{StaticResource WzTextHint}" VerticalAlignment="Center" Margin="16,0,0,0">
                                    <Run Text="共 "/><Run Text="{Binding MatrixRunCount, Mode=OneWay}"/><Run Text=" 组"/>
                                </TextBlock>
                            </StackPanel>

                            <DataGrid ItemsSource="{Binding MatrixTable}" AutoGenerateColumns="True"
                                      IsReadOnly="True" CanUserAddRows="False"
                                      GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="{StaticResource WzDivider}"
                                      Background="White" BorderBrush="{StaticResource WzDivider}" BorderThickness="0.5"
                                      RowStyle="{StaticResource WzGridRow}" FontFamily="Consolas" FontSize="12"
                                      RowHeight="30" ColumnHeaderHeight="30" MaxHeight="360">
                                <DataGrid.ColumnHeaderStyle>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="Background" Value="{StaticResource WzSurface}"/>
                                        <Setter Property="Foreground" Value="{StaticResource WzTextMuted}"/>
                                        <Setter Property="FontSize" Value="11"/>
                                        <Setter Property="FontFamily" Value="Segoe UI"/>
                                        <Setter Property="FontWeight" Value="Medium"/>
                                        <Setter Property="Padding" Value="10,0"/>
                                        <Setter Property="BorderBrush" Value="{StaticResource WzDivider}"/>
                                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                    </Style>
                                </DataGrid.ColumnHeaderStyle>
                            </DataGrid>
                        </StackPanel>

                        <!-- Step 4: 响应与条件 -->
                        <StackPanel Visibility="{Binding IsStep4Visible, Converter={StaticResource BoolToVis}}">
                            <Border Background="{StaticResource WzPrimaryLight}" CornerRadius="6" Padding="10,3" HorizontalAlignment="Left" Margin="0,0,0,10">
                                <TextBlock Text="STEP 4" Style="{StaticResource WzStepBadge}"/>
                            </Border>
                            <TextBlock Text="响应变量与停止条件" FontSize="18" FontWeight="Medium" Foreground="{StaticResource WzText}" Margin="0,0,0,3"/>
                            <TextBlock Text="定义测量指标和自动终止规则" FontSize="13" Foreground="{StaticResource WzTextSec}" Margin="0,0,0,18"/>

                            <TextBlock Text="响应变量" Style="{StaticResource WzLabel}"/>
                            <DataGrid ItemsSource="{Binding Responses}" AutoGenerateColumns="False"
                                      CanUserAddRows="False" GridLinesVisibility="Horizontal"
                                      HorizontalGridLinesBrush="{StaticResource WzDivider}"
                                      Background="Transparent" BorderThickness="0" RowStyle="{StaticResource WzGridRow}"
                                      FontSize="12.5" RowHeight="40" ColumnHeaderHeight="30" MaxHeight="200">
                                <DataGrid.ColumnHeaderStyle>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Foreground" Value="{StaticResource WzTextHint}"/>
                                        <Setter Property="FontSize" Value="11"/>
                                        <Setter Property="FontWeight" Value="Medium"/>
                                        <Setter Property="Padding" Value="4,0"/>
                                        <Setter Property="BorderBrush" Value="{StaticResource WzDivider}"/>
                                        <Setter Property="BorderThickness" Value="0,0,0,0.5"/>
                                    </Style>
                                </DataGrid.ColumnHeaderStyle>
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn Header="名称" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBox Text="{Binding ResponseName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource WzCellInput}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="目标" Width="100">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <ComboBox ItemsSource="{Binding GoalOptions}" 
                                                          SelectedItem="{Binding Goal, UpdateSourceTrigger=PropertyChanged}" 
                                                          Style="{StaticResource WzComboCompact}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="权重" Width="60">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBox Text="{Binding Importance, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource WzCellNum}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="" Width="36">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Style="{StaticResource WzBtnDel}" Command="{Binding DataContext.RemoveResponseCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                            <Button Content="+ 添加响应" Command="{Binding AddResponseCommand}" Style="{StaticResource WzBtnAdd}" Margin="0,6,0,20"/>

                            <TextBlock Text="停止条件（可选）" Style="{StaticResource WzLabel}"/>
                            <DataGrid ItemsSource="{Binding StopConditions}" AutoGenerateColumns="False"
                                      CanUserAddRows="False" GridLinesVisibility="Horizontal"
                                      HorizontalGridLinesBrush="{StaticResource WzDivider}"
                                      Background="Transparent" BorderThickness="0" RowStyle="{StaticResource WzGridRow}"
                                      FontSize="12.5" RowHeight="40" ColumnHeaderHeight="30" MaxHeight="160">
                                <DataGrid.ColumnHeaderStyle>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Foreground" Value="{StaticResource WzTextHint}"/>
                                        <Setter Property="FontSize" Value="11"/>
                                        <Setter Property="FontWeight" Value="Medium"/>
                                        <Setter Property="Padding" Value="4,0"/>
                                        <Setter Property="BorderBrush" Value="{StaticResource WzDivider}"/>
                                        <Setter Property="BorderThickness" Value="0,0,0,0.5"/>
                                    </Style>
                                </DataGrid.ColumnHeaderStyle>
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn Header="响应" Width="120">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBox Text="{Binding ResponseName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource WzCellInput}" Width="110"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="条件" Width="70">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <ComboBox SelectedItem="{Binding Operator, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource WzComboCompact}">
                                                    <ComboBox.Items>
                                                        <sys:String xmlns:sys="clr-namespace:System;assembly=mscorlib">≥</sys:String>
                                                        <sys:String xmlns:sys="clr-namespace:System;assembly=mscorlib">≤</sys:String>
                                                        <sys:String xmlns:sys="clr-namespace:System;assembly=mscorlib">=</sys:String>
                                                    </ComboBox.Items>
                                                </ComboBox>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="目标值" Width="90">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBox Text="{Binding TargetValue, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource WzCellNum}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="" Width="36">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Style="{StaticResource WzBtnDel}" Command="{Binding DataContext.RemoveStopConditionCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                            <Button Content="+ 添加条件" Command="{Binding AddStopConditionCommand}" Style="{StaticResource WzBtnAdd}"/>
                        </StackPanel>

                        <!-- Step 5: 数据导入 -->
                        <StackPanel Visibility="{Binding IsStep5Visible, Converter={StaticResource BoolToVis}}">
                            <Border Background="{StaticResource WzPrimaryLight}" CornerRadius="6" Padding="10,3" HorizontalAlignment="Left" Margin="0,0,0,10">
                                <TextBlock Text="STEP 5" Style="{StaticResource WzStepBadge}"/>
                            </Border>
                            <TextBlock Text="历史数据导入" FontSize="18" FontWeight="Medium" Foreground="{StaticResource WzText}" Margin="0,0,0,3"/>
                            <TextBlock Text="已有实验数据可初始化 GPR 模型（可选步骤）" FontSize="13" Foreground="{StaticResource WzTextSec}" Margin="0,0,0,22"/>

                            <Border BorderThickness="1.5" CornerRadius="12"
                                    Padding="36" HorizontalAlignment="Stretch"
                                    Cursor="Hand">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="BorderBrush" Value="{StaticResource WzBorderHover}"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="BorderBrush" Value="{StaticResource WzPrimary}"/>
                                                <Setter Property="Background" Value="#04000000"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel HorizontalAlignment="Center">
                                    <Border Width="36" Height="36" CornerRadius="9" Background="{StaticResource WzSurface}"
                                            HorizontalAlignment="Center" Margin="0,0,0,10">
                                        <TextBlock Text="📄" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="拖拽 Excel 文件到此处" FontSize="13" FontWeight="Medium" Foreground="{StaticResource WzTextSec}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="支持 .xlsx · 列名需匹配因子和响应名称" FontSize="11.5" Foreground="{StaticResource WzTextHint}" HorizontalAlignment="Center" Margin="0,3,0,10"/>
                                    <Button Content="浏览文件..." Style="{StaticResource WzBtnGhost}" HorizontalAlignment="Center" Command="{Binding BrowseImportCommand}"/>
                                </StackPanel>
                            </Border>

                            <TextBlock Text="{Binding ImportFilePath}" FontSize="12" Foreground="{StaticResource WzPrimary}" Margin="0,12,0,0"
                                       Visibility="{Binding ImportFilePath, Converter={StaticResource NullToVis}}"/>
                            <TextBlock Style="{StaticResource WzHint}" Margin="0,8,0,0"
                                       Text="{Binding StatusMessage}" Visibility="{Binding ImportFilePath, Converter={StaticResource NullToVis}}"/>
                        </StackPanel>

                        <!-- Step 6: 确认保存 -->
                        <StackPanel Visibility="{Binding IsStep6Visible, Converter={StaticResource BoolToVis}}">
                            <Border Background="{StaticResource WzPrimaryLight}" CornerRadius="6" Padding="10,3" HorizontalAlignment="Left" Margin="0,0,0,10">
                                <TextBlock Text="STEP 6" Style="{StaticResource WzStepBadge}"/>
                            </Border>
                            <TextBlock Text="确认并保存" FontSize="18" FontWeight="Medium" Foreground="{StaticResource WzText}" Margin="0,0,0,3"/>
                            <TextBlock Text="核对实验方案，确认后保存" FontSize="13" Foreground="{StaticResource WzTextSec}" Margin="0,0,0,22"/>

                            <TextBlock Text="批次名称" Style="{StaticResource WzLabel}"/>
                            <TextBox Text="{Binding BatchName}" Style="{StaticResource WzTextBox}" Tag="CCD_20250407_001" Margin="0,0,0,20"/>

                            <UniformGrid Columns="3" Margin="0,0,0,22">
                                <Border Style="{StaticResource WzStatCard}" Margin="0,0,5,0">
                                    <StackPanel>
                                        <TextBlock Text="因子" FontSize="11" Foreground="{StaticResource WzTextHint}" Margin="0,0,0,3"/>
                                        <TextBlock Text="{Binding Factors.Count}" FontSize="20" FontWeight="Medium" FontFamily="Consolas" Foreground="{StaticResource WzText}"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource WzStatCard}" Margin="3,0">
                                    <StackPanel>
                                        <TextBlock Text="实验组" FontSize="11" Foreground="{StaticResource WzTextHint}" Margin="0,0,0,3"/>
                                        <TextBlock Text="{Binding MatrixRunCount}" FontSize="20" FontWeight="Medium" FontFamily="Consolas" Foreground="{StaticResource WzText}"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource WzStatCard}" Margin="5,0,0,0">
                                    <StackPanel>
                                        <TextBlock Text="响应" FontSize="11" Foreground="{StaticResource WzTextHint}" Margin="0,0,0,3"/>
                                        <TextBlock Text="{Binding Responses.Count}" FontSize="20" FontWeight="Medium" FontFamily="Consolas" Foreground="{StaticResource WzText}"/>
                                    </StackPanel>
                                </Border>
                            </UniformGrid>

                            <StackPanel Margin="0,0,0,0">
                                <TextBlock FontSize="13" Foreground="{StaticResource WzTextSec}" LineHeight="28">
                                    <Run Foreground="{StaticResource WzTextHint}">设计方法   </Run><Run Text="{Binding SelectedMethod, Mode=OneWay}"/></TextBlock>
                                <TextBlock FontSize="13" Foreground="{StaticResource WzTextSec}" LineHeight="28">
                                    <Run Foreground="{StaticResource WzTextHint}">停止条件   </Run><Run Text="{Binding StopConditions.Count, StringFormat={}{0} 条, Mode=OneWay}"/></TextBlock>
                                <TextBlock FontSize="13" Foreground="{StaticResource WzTextSec}" LineHeight="28">
                                    <Run Foreground="{StaticResource WzTextHint}">历史数据   </Run><Run Text="{Binding ImportedDataCount, StringFormat={}{0} 条, Mode=OneWay}"/></TextBlock>
                            </StackPanel>

                            <!-- 设计质量评估 -->
                            <Border Background="{StaticResource WzSurface}" CornerRadius="8" Padding="16" Margin="0,16,0,0"
                                    Visibility="{Binding HasDesignQuality, Converter={StaticResource BoolToVis}}">
                                <StackPanel>
                                    <TextBlock Text="设计质量评估" FontSize="12" FontWeight="Medium" Foreground="{StaticResource WzTextMuted}" Margin="0,0,0,10"/>
                                    <UniformGrid Columns="4">
                                        <StackPanel Margin="0,0,12,0">
                                            <TextBlock Text="D-效率" FontSize="11" Foreground="{StaticResource WzTextHint}"/>
                                            <TextBlock Text="{Binding QualityDEffText}" FontSize="18" FontWeight="Medium" FontFamily="Consolas" Foreground="{StaticResource WzPrimary}"/>
                                        </StackPanel>
                                        <StackPanel Margin="0,0,12,0">
                                            <TextBlock Text="A-效率" FontSize="11" Foreground="{StaticResource WzTextHint}"/>
                                            <TextBlock Text="{Binding QualityAEffText}" FontSize="18" FontWeight="Medium" FontFamily="Consolas" Foreground="{StaticResource WzPrimary}"/>
                                        </StackPanel>
                                        <StackPanel Margin="0,0,12,0">
                                            <TextBlock Text="G-效率" FontSize="11" Foreground="{StaticResource WzTextHint}"/>
                                            <TextBlock Text="{Binding QualityGEffText}" FontSize="18" FontWeight="Medium" FontFamily="Consolas" Foreground="#8E44AD"/>
                                        </StackPanel>
                                        <StackPanel>
                                            <TextBlock Text="自由度" FontSize="11" Foreground="{StaticResource WzTextHint}"/>
                                            <TextBlock Text="{Binding QualityDofText}" FontSize="18" FontWeight="Medium" FontFamily="Consolas" Foreground="#E67E22"/>
                                        </StackPanel>
                                    </UniformGrid>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                    </Grid>
                </ScrollViewer>

                <!-- ═══ 底部导航栏 ═══ -->
                <Border Grid.Row="2" BorderBrush="{StaticResource WzDivider}" BorderThickness="0,0.5,0,0" Padding="30,13">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- 左侧进度 -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Margin="0,0,8,0">
                                <Border Width="18" Height="3" CornerRadius="1.5" Margin="0,0,2,0"
                                        Background="{Binding CurrentStep, Converter={StaticResource StepBrush}, ConverterParameter=1}"/>
                                <Border Width="18" Height="3" CornerRadius="1.5" Margin="0,0,2,0"
                                        Background="{Binding CurrentStep, Converter={StaticResource StepBrush}, ConverterParameter=2}"/>
                                <Border Width="18" Height="3" CornerRadius="1.5" Margin="0,0,2,0"
                                        Background="{Binding CurrentStep, Converter={StaticResource StepBrush}, ConverterParameter=3}"/>
                                <Border Width="18" Height="3" CornerRadius="1.5" Margin="0,0,2,0"
                                        Background="{Binding CurrentStep, Converter={StaticResource StepBrush}, ConverterParameter=4}"/>
                                <Border Width="18" Height="3" CornerRadius="1.5" Margin="0,0,2,0"
                                        Background="{Binding CurrentStep, Converter={StaticResource StepBrush}, ConverterParameter=5}"/>
                                <Border Width="18" Height="3" CornerRadius="1.5"
                                        Background="{Binding CurrentStep, Converter={StaticResource StepBrush}, ConverterParameter=6}"/>
                            </StackPanel>
                            <TextBlock FontSize="11" Foreground="{StaticResource WzTextHint}" VerticalAlignment="Center">
                                <Run Text="{Binding CurrentStep, Mode=OneWay}"/><Run Text=" / 6"/>
                            </TextBlock>
                            <!-- Loading -->
                            <StackPanel Orientation="Horizontal" Margin="16,0,0,0"
                                        Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
                                <Ellipse Width="14" Height="14" StrokeThickness="1.5" Stroke="{StaticResource WzPrimary}"
                                         StrokeDashArray="5 4" RenderTransformOrigin="0.5,0.5">
                                    <Ellipse.RenderTransform>
                                        <RotateTransform/>
                                    </Ellipse.RenderTransform>
                                    <Ellipse.Triggers>
                                        <EventTrigger RoutedEvent="Loaded">
                                            <BeginStoryboard>
                                                <Storyboard RepeatBehavior="Forever">
                                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                                     From="0" To="360" Duration="0:0:0.7"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </Ellipse.Triggers>
                                </Ellipse>
                                <TextBlock Text="{Binding StatusMessage}" FontSize="11" Foreground="{StaticResource WzTextMuted}"
                                           VerticalAlignment="Center" Margin="6,0,0,0"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- 右侧按钮 -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Content="← 上一步" Command="{Binding PreviousStepCommand}" Style="{StaticResource WzBtnGhost}" Margin="0,0,8,0"/>
                            <!-- Step1-5: 下一步 -->
                            <Button Content="下一步 →" Command="{Binding NextStepCommand}" Margin="0,0,8,0">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource WzBtnPrimary}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CurrentStep}" Value="6">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <!-- Step6: 保存并开始执行 -->
                            <Button Content="保存并开始执行" Command="{Binding SaveBatchCommand}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource WzBtnPrimary}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CurrentStep}" Value="6">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
