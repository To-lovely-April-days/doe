<UserControl x:Class="MaxChemical.Modules.DOE.Views.DOEExecutionDashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F2F4F7">
    <UserControl.Resources>
        <ResourceDictionary Source="DOEStyles.xaml"/>
    </UserControl.Resources>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="22">

                <!-- ═══ 顶部: 批次名 + 控制按钮 ═══ -->
                <Border Background="White" CornerRadius="10" BorderBrush="#ECEEF2" BorderThickness="1" Padding="18,14" Margin="0,0,0,14">
                    <Grid>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{Binding BatchName}" FontSize="15" FontWeight="SemiBold" Foreground="#1A1F36"/>
                            <TextBlock Text="{Binding BatchId}" FontSize="10" Foreground="#A0A4B0" FontFamily="Consolas" Margin="0,2,0,0"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <Button Style="{StaticResource DOEPrimaryBtn}" Padding="18,7" Margin="0,0,6,0"
                                Content="{Binding StartButtonText}"
                                Command="{Binding ContinueCommand}"/>
                            <Button Padding="14,7" Margin="0,0,6,0" Cursor="Hand"
                                Command="{Binding RetryFailedCommand}"
                                Visibility="{Binding HasFailedRuns, Converter={StaticResource BoolToVis}}">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd" CornerRadius="6" Padding="{TemplateBinding Padding}"
                                            Background="White" BorderBrush="#FF8C00" BorderThickness="1">
                                            <TextBlock Text="重试失败" FontSize="11" FontWeight="SemiBold" Foreground="#FF8C00"
                                                   HorizontalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#FFF5E6"/>
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter TargetName="Bd" Property="Opacity" Value="0.4"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <!-- 暂停按钮 -->
                            <Button Padding="14,7" Margin="0,0,6,0" Cursor="Hand"
                                Command="{Binding PauseCommand}">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd" CornerRadius="6" Padding="{TemplateBinding Padding}"
                                            Background="White" BorderBrush="#D0D0D0" BorderThickness="1">
                                            <TextBlock Text="暂停" FontSize="11" FontWeight="SemiBold" Foreground="#4A5066"
                                                   HorizontalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#F7F8FA"/>
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter TargetName="Bd" Property="Opacity" Value="0.4"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <!-- 恢复按钮 -->
                            <Button Padding="14,7" Margin="0,0,6,0" Cursor="Hand"
                                Command="{Binding ResumeCommand}">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd" CornerRadius="6" Padding="{TemplateBinding Padding}"
                                            Background="White" BorderBrush="#16C60C" BorderThickness="1">
                                            <TextBlock Text="恢复" FontSize="11" FontWeight="SemiBold" Foreground="#0D7A3E"
                                                   HorizontalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#E8F8EE"/>
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter TargetName="Bd" Property="Opacity" Value="0.4"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <Button Padding="14,7" Cursor="Hand"
                                Command="{Binding AbortCommand}">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd" CornerRadius="6" Padding="{TemplateBinding Padding}"
                                            Background="White" BorderBrush="#E8A0A0" BorderThickness="1">
                                            <TextBlock Text="终止" FontSize="11" FontWeight="SemiBold" Foreground="#C73845"
                                                   HorizontalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#FDE7E9"/>
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter TargetName="Bd" Property="Opacity" Value="0.4"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ═══ 4 指标卡片 ═══ -->
                <UniformGrid Columns="4" Margin="0,0,0,14">
                    <!-- 执行进度 -->
                    <Border Background="#FAFBFC" CornerRadius="8" Padding="16,14" Margin="0,0,6,0">
                        <StackPanel>
                            <TextBlock Text="执行进度" FontSize="11" Foreground="#8A8F9C" Margin="0,0,0,6"/>
                            <TextBlock FontSize="22" FontWeight="SemiBold" Foreground="#1A1F36" Margin="0,0,0,8">
                            <Run Text="{Binding CurrentRun, Mode=OneWay}"/>
                            <Run Text=" / " FontSize="14" Foreground="#A0A4B0"/>
                            <Run Text="{Binding TotalRuns, Mode=OneWay}" FontSize="14" Foreground="#A0A4B0"/>
                            </TextBlock>
                            <ProgressBar Height="4" Minimum="0" Maximum="100"
                                     Value="{Binding ProgressPercent, Mode=OneWay}"
                                     Background="#E8EAED" Foreground="#0078D4" BorderThickness="0"/>
                        </StackPanel>
                    </Border>

                    <!-- 当前最优 -->
                    <Border Background="#FAFBFC" CornerRadius="8" Padding="16,14" Margin="3,0">
                        <StackPanel>
                            <TextBlock Text="当前最优" FontSize="11" Foreground="#8A8F9C" Margin="0,0,0,6"/>
                            <TextBlock Text="{Binding BestRunText}" FontSize="22" FontWeight="SemiBold" Foreground="#1A1F36"/>
                            <TextBlock Text="{Binding BestValueText}" FontSize="11" Foreground="#A0A4B0" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- GPR 模型 -->
                    <Border Background="#FAFBFC" CornerRadius="8" Padding="16,14" Margin="3,0">
                        <StackPanel>
                            <TextBlock Text="GPR 模型" FontSize="11" Foreground="#8A8F9C" Margin="0,0,0,6"/>
                            <TextBlock Text="{Binding GPRStatusText}" FontSize="22" FontWeight="SemiBold" Foreground="#1A1F36"/>
                            <TextBlock Text="{Binding GPRDetailText}" FontSize="11" Foreground="#A0A4B0" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- 预计剩余 -->
                    <Border Background="#FAFBFC" CornerRadius="8" Padding="16,14" Margin="6,0,0,0">
                        <StackPanel>
                            <TextBlock Text="预计剩余" FontSize="11" Foreground="#8A8F9C" Margin="0,0,0,6"/>
                            <TextBlock Text="{Binding ETAText}" FontSize="22" FontWeight="SemiBold" Foreground="#1A1F36"/>
                            <TextBlock Text="{Binding ETADetailText}" FontSize="11" Foreground="#A0A4B0" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <!-- ═══ 实验矩阵表 ═══ -->
                <Border Background="White" CornerRadius="10" BorderBrush="#ECEEF2" BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- 表头 -->
                        <Border Background="#FAFBFC" Padding="18,10" BorderBrush="#E8EAED" BorderThickness="0,0,0,1"
                            CornerRadius="10,10,0,0">
                            <Grid>
                                <TextBlock Text="实验矩阵" FontSize="13" FontWeight="SemiBold" Foreground="#1A1F36"/>
                                <TextBlock HorizontalAlignment="Right" VerticalAlignment="Center"
                                       FontSize="11" Foreground="#A0A4B0">
                                <Run Text="{Binding MatrixTable.Rows.Count, Mode=OneWay}"/>
                                <Run Text=" 组实验"/>
                                </TextBlock>
                            </Grid>
                        </Border>

                        <!-- 动态 DataGrid（AutoGenerateColumns，列由 DataTable 决定） -->
                        <DataGrid Grid.Row="1"
                              ItemsSource="{Binding MatrixTable}"
                              AutoGenerateColumns="True"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="#F2F3F5"
                              BorderThickness="0"
                              Background="White"
                              RowBackground="White"
                              AlternatingRowBackground="White"
                              HeadersVisibility="Column"
                              SelectionMode="Single"
                              FontSize="12"
                              FontFamily="Segoe UI"
                              RowHeight="40"
                              ColumnHeaderHeight="38"
                              MaxHeight="520"
                              AutoGeneratingColumn="OnAutoGeneratingColumn">
                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="#FAFBFC"/>
                                    <Setter Property="Foreground" Value="#8A8F9C"/>
                                    <Setter Property="FontSize" Value="11"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Padding" Value="12,0"/>
                                    <Setter Property="BorderBrush" Value="#E8EAED"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Right"/>
                                </Style>
                            </DataGrid.ColumnHeaderStyle>
                            <DataGrid.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="Padding" Value="12,0"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="FontFamily" Value="Consolas"/>
                                    <Setter Property="Foreground" Value="#1A1F36"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="DataGridCell">
                                                <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}">
                                                    <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#EBF3FE"/>
                                            <Setter Property="Foreground" Value="#1A1F36"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.CellStyle>
                        </DataGrid>
                    </Grid>
                </Border>

                <!-- ═══ 底部状态条 ═══ -->
                <Border Background="White" CornerRadius="8" BorderBrush="#ECEEF2" BorderThickness="1"
                    Padding="14,8" Margin="0,10,0,0">
                    <TextBlock Text="{Binding StatusMessage}" FontSize="11" Foreground="#8A8F9C"/>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- ═══  暂停等待遮罩 ═══ -->
        <Border Background="#80FFFFFF" Visibility="{Binding IsPausing, Converter={StaticResource BoolToVis}}"
            VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
            <Border Background="White" CornerRadius="12" Padding="36,28"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                BorderBrush="#ECEEF2" BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect Color="#000" Direction="270" ShadowDepth="4" BlurRadius="20" Opacity="0.08"/>
                </Border.Effect>
                <StackPanel HorizontalAlignment="Center">
                    <!-- 旋转动画 -->
                    <Ellipse Width="36" Height="36" StrokeThickness="3" StrokeDashArray="8 6"
                         Stroke="{StaticResource PrimaryBrush}" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                         RenderTransformOrigin="0.5,0.5" HorizontalAlignment="Center" Margin="0,0,0,16">
                        <Ellipse.RenderTransform>
                            <RotateTransform x:Name="PauseSpinAngle"/>
                        </Ellipse.RenderTransform>
                        <Ellipse.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever">
                                        <DoubleAnimation Storyboard.TargetName="PauseSpinAngle"
                                                     Storyboard.TargetProperty="Angle"
                                                     From="0" To="360" Duration="0:0:1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Ellipse.Triggers>
                    </Ellipse>
                    <TextBlock Text="正在等待当前实验组完成..." FontSize="14" FontWeight="SemiBold" Foreground="#1A1F36"
                           HorizontalAlignment="Center" Margin="0,0,0,6"/>
                    <TextBlock Text="当前组执行完毕后将自动暂停" FontSize="11" Foreground="#8A8F9C"
                           HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Border>

    </Grid>
</UserControl>
