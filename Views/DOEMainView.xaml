<Window x:Class="MaxChemical.Modules.DOE.Views.DOEMainView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:MaxChemical.Modules.DOE.Views"
        Title="DOE" Width="1280" Height="860"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <ResourceDictionary Source="DOEStyles.xaml"/>
    </Window.Resources>

    <Grid>
        <!-- ═══ 主内容（大窗口模式） ═══ -->
        <Border x:Name="MainContent" Margin="10" CornerRadius="12" Background="White" BorderBrush="#D8DCE3" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect Color="#000" Direction="270" ShadowDepth="4" BlurRadius="16" Opacity="0.12"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="38"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- ═══ 标题栏 ═══ -->
                <Border Grid.Row="0" CornerRadius="12,12,0,0" MouseLeftButtonDown="TitleBar_MouseDown">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#003A96" Offset="0"/>
                            <GradientStop Color="#002D78" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Viewbox Width="16" Height="16" Margin="16,0,10,0">
                            <Canvas Width="16" Height="16">
                                <Rectangle Canvas.Left="1" Canvas.Top="1" Width="5.5" Height="5.5" RadiusX="1.2" RadiusY="1.2" Fill="White" Opacity="0.7"/>
                                <Rectangle Canvas.Left="9" Canvas.Top="1" Width="5.5" Height="5.5" RadiusX="1.2" RadiusY="1.2" Fill="White" Opacity="0.35"/>
                                <Rectangle Canvas.Left="1" Canvas.Top="9" Width="5.5" Height="5.5" RadiusX="1.2" RadiusY="1.2" Fill="White" Opacity="0.35"/>
                                <Rectangle Canvas.Left="9" Canvas.Top="9" Width="5.5" Height="5.5" RadiusX="1.2" RadiusY="1.2" Fill="White" Opacity="0.18"/>
                            </Canvas>
                        </Viewbox>

                        <TextBlock Grid.Column="1" Text="DOE 实验设计与优化" VerticalAlignment="Center"
                                   Foreground="#DDFFFFFF" FontSize="12" FontWeight="SemiBold"/>

                        <Button Grid.Column="2" Style="{StaticResource WinCloseBtn}" Click="CloseBtn_Click" Margin="0,0,8,0"/>
                    </Grid>
                </Border>

                <!-- ═══ Tab 栏 ═══ -->
                <Border Grid.Row="1" Background="White" BorderBrush="{StaticResource DividerBrush}" BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel x:Name="TabBar" Orientation="Horizontal" Margin="14,0,0,0">
                            <RadioButton Content="概览" Tag="0" IsChecked="True" GroupName="DOETabs"
                             Style="{StaticResource DOETabRadio}" Checked="TabRadio_Checked"/>
                            <RadioButton Content="执行" Tag="1" GroupName="DOETabs"
                             Style="{StaticResource DOETabRadio}" Checked="TabRadio_Checked"/>
                            <RadioButton Content="模型分析" Tag="2" GroupName="DOETabs"
                             Style="{StaticResource DOETabRadio}" Checked="TabRadio_Checked"/>
                            <RadioButton Content="历史" Tag="3" GroupName="DOETabs"
                             Style="{StaticResource DOETabRadio}" Checked="TabRadio_Checked"/>
                        </StackPanel>

                        <Button Grid.Column="1" Command="{Binding OpenDesignWizardCommand}" Margin="0,0,20,0"
                            Height="30" VerticalAlignment="Center" Cursor="Hand" BorderThickness="0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd" CornerRadius="6" Padding="10,3">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#0078D4" Offset="0"/>
                                                <GradientStop Color="#005FA3" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <StackPanel Orientation="Horizontal">
                                            <Viewbox Width="11" Height="11" Margin="0,0,5,0">
                                                <Canvas Width="16" Height="16">
                                                    <Ellipse Canvas.Left="0.5" Canvas.Top="0.5" Width="15" Height="15"
                                                             Stroke="White" StrokeThickness="1.3" Fill="Transparent"/>
                                                    <Line X1="8" Y1="4.5" X2="8" Y2="11.5" Stroke="White" StrokeThickness="1.3"
                                                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                                    <Line X1="4.5" Y1="8" X2="11.5" Y2="8" Stroke="White" StrokeThickness="1.3"
                                                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                                </Canvas>
                                            </Viewbox>
                                            <TextBlock Text="新建方案" Foreground="White" FontSize="10.5" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Opacity" Value="0.9"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="Bd" Property="Opacity" Value="0.8"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </Border>

                <!-- ═══ 内容区 ═══ -->
                <Grid Grid.Row="2" Background="{StaticResource PageBgBrush}">
                    <views:DOEOverviewView x:Name="OverviewView"
                        Visibility="{Binding DataContext.IsTab0, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVis}}"/>
                    <views:DOEExecutionDashboardView x:Name="ExecutionView"
                        Visibility="{Binding DataContext.IsTab1, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVis}}"/>
                    <views:DOEModelAnalysisView x:Name="ModelAnalysisView"
                        Visibility="{Binding DataContext.IsTab2, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVis}}"/>
                    <views:DOEHistoryView x:Name="HistoryView"
                        Visibility="{Binding DataContext.IsTab3, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVis}}"/>
                </Grid>

                <!-- ═══ Loading ═══ -->
                <Border x:Name="LoadingOverlay" Grid.RowSpan="3" Background="#DD000000" CornerRadius="12"
                        Visibility="Collapsed" Panel.ZIndex="100">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <Grid Width="52" Height="52" Margin="0,0,0,18">
                            <Ellipse Width="52" Height="52" Stroke="#333" StrokeThickness="3"/>
                            <Ellipse Width="52" Height="52" Style="{StaticResource DOESpinRing}" Stroke="#3B9EFF" RenderTransformOrigin="0.5,0.5">
                                <Ellipse.RenderTransform>
                                    <RotateTransform x:Name="LoadSpin" Angle="0"/>
                                </Ellipse.RenderTransform>
                                <Ellipse.Triggers>
                                    <EventTrigger RoutedEvent="Loaded">
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever">
                                                <DoubleAnimation Storyboard.TargetName="LoadSpin" Storyboard.TargetProperty="Angle" From="0" To="360" Duration="0:0:0.9"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Ellipse.Triggers>
                            </Ellipse>
                        </Grid>
                        <TextBlock Text="正在初始化 DOE 模块" FontSize="15" Foreground="White" HorizontalAlignment="Center" FontWeight="Medium" Margin="0,0,0,4"/>
                        <TextBlock Text="加载 Python 环境和分析引擎..." FontSize="11" Foreground="#6B8BBF" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ═══  迷你面板（执行时覆盖显示） ═══ -->
        <views:DOEMiniPanel x:Name="MiniPanel"
            Visibility="Collapsed"
            VerticalAlignment="Stretch" HorizontalAlignment="Stretch"/>
    </Grid>
</Window>
