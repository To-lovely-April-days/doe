<Window x:Class="MaxChemical.Modules.DOE.Views.DOEMainView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:MaxChemical.Modules.DOE.Views"
        Title="DOE" Width="1280" Height="860"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <ResourceDictionary Source="DOEStyles.xaml"/>
    </Window.Resources>

    <Grid>
        <!-- ═══ 主内容（大窗口模式） ═══ -->
        <Border x:Name="MainContent" Margin="10" CornerRadius="12" Background="White" BorderBrush="#D8DCE3" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect Color="#000" Direction="270" ShadowDepth="4" BlurRadius="16" Opacity="0.12"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="38"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- ═══ 标题栏 ═══ -->
                <Border Grid.Row="0" CornerRadius="12,12,0,0" MouseLeftButtonDown="TitleBar_MouseDown">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#003A96" Offset="0"/>
                            <GradientStop Color="#002D78" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Logo + 标题 -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="14,0,0,0">
                            <Viewbox Width="16" Height="16" Margin="0,0,10,0">
                                <Canvas Width="16" Height="16">
                                    <Rectangle Canvas.Left="1" Canvas.Top="1" Width="5.5" Height="5.5" 
                               RadiusX="1.2" RadiusY="1.2" Fill="White" Opacity="0.7"/>
                                    <Rectangle Canvas.Left="9" Canvas.Top="1" Width="5.5" Height="5.5" 
                               RadiusX="1.2" RadiusY="1.2" Fill="White" Opacity="0.35"/>
                                    <Rectangle Canvas.Left="1" Canvas.Top="9" Width="5.5" Height="5.5" 
                               RadiusX="1.2" RadiusY="1.2" Fill="White" Opacity="0.35"/>
                                    <Rectangle Canvas.Left="9" Canvas.Top="9" Width="5.5" Height="5.5" 
                               RadiusX="1.2" RadiusY="1.2" Fill="White" Opacity="0.18"/>
                                </Canvas>
                            </Viewbox>
                            <TextBlock Text="DOE 实验设计与优化" VerticalAlignment="Center"
                       Foreground="#DDFFFFFF" FontSize="12" FontWeight="SemiBold"/>
                        </StackPanel>

                        <!-- 关闭按钮 -->
                        <Button Grid.Column="2" Style="{StaticResource CloseButtonStyle}" 
                Click="CloseBtn_Click" VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- ═══ Tab 栏 ═══ -->
                <Border Grid.Row="1" Background="White" BorderBrush="{StaticResource DividerBrush}" BorderThickness="0,0,0,1">
                    <StackPanel x:Name="TabBar" Orientation="Horizontal" Margin="14,0,0,0">
                        <RadioButton Content="概览" Tag="0" IsChecked="True" GroupName="DOETabs"
                                     Style="{StaticResource DOETabRadio}" Checked="TabRadio_Checked"/>
                        <RadioButton Content="执行" Tag="1" GroupName="DOETabs"
                                     Style="{StaticResource DOETabRadio}" Checked="TabRadio_Checked"/>
                        <RadioButton Content="模型分析" Tag="2" GroupName="DOETabs"
                                     Style="{StaticResource DOETabRadio}" Checked="TabRadio_Checked"/>
                        <RadioButton Content="历史" Tag="3" GroupName="DOETabs"
                                     Style="{StaticResource DOETabRadio}" Checked="TabRadio_Checked"/>
                    </StackPanel>
                </Border>
                <!-- ═══ 内容区 ═══ -->
                <Grid Grid.Row="2" Background="{StaticResource PageBgBrush}">
                    <views:DOEOverviewView x:Name="OverviewView"
                        Visibility="{Binding DataContext.IsTab0, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVis}}"/>
                    <views:DOEExecutionDashboardView x:Name="ExecutionView"
                        Visibility="{Binding DataContext.IsTab1, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVis}}"/>
                    <views:DOEModelAnalysisView x:Name="ModelAnalysisView"
                        Visibility="{Binding DataContext.IsTab2, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVis}}"/>
                    <views:DOEHistoryView x:Name="HistoryView"
                        Visibility="{Binding DataContext.IsTab3, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVis}}"/>
                </Grid>

                <!-- ═══ Loading ═══ -->
                <Border x:Name="LoadingOverlay" Grid.Row="1" Grid.RowSpan="2" Background="White"
        Visibility="Collapsed" Panel.ZIndex="100">
                    <Grid>
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">

                            <!-- Logo + 产品名 -->
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,28">
                                <!-- Logo 方块 -->
                                <Border Width="40" Height="40" CornerRadius="9" Margin="0,0,12,0">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#0062B8" Offset="0"/>
                                            <GradientStop Color="#003A96" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Viewbox Width="22" Height="22">
                                        <Canvas Width="16" Height="16">
                                            <Rectangle Canvas.Left="1" Canvas.Top="1" Width="5.5" Height="5.5" 
                                       RadiusX="1.2" RadiusY="1.2" Fill="White" Opacity="0.9"/>
                                            <Rectangle Canvas.Left="9" Canvas.Top="1" Width="5.5" Height="5.5" 
                                       RadiusX="1.2" RadiusY="1.2" Fill="White" Opacity="0.5"/>
                                            <Rectangle Canvas.Left="1" Canvas.Top="9" Width="5.5" Height="5.5" 
                                       RadiusX="1.2" RadiusY="1.2" Fill="White" Opacity="0.5"/>
                                            <Rectangle Canvas.Left="9" Canvas.Top="9" Width="5.5" Height="5.5" 
                                       RadiusX="1.2" RadiusY="1.2" Fill="White" Opacity="0.3"/>
                                        </Canvas>
                                    </Viewbox>
                                </Border>
                                <!-- 产品名 -->
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="DOE 优化平台" FontSize="17" FontWeight="Medium" Foreground="#1A1F36"/>
                                    <TextBlock Text="MaxChemical" FontSize="11" Foreground="#A0A4B0" Margin="0,1,0,0"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- 进度条（带光扫动画） -->
                            <Grid Width="220" Height="3" Margin="0,0,0,16">
                                <!-- 轨道 -->
                                <Border Background="#ECEEF2" CornerRadius="1.5"/>
                                <!-- 进度 -->
                                <Border x:Name="LoadingProgressBar" Background="#0078D4" CornerRadius="1.5"
                        HorizontalAlignment="Left" Width="0">
                                    <!-- 光扫层 -->
                                    <Border CornerRadius="1.5" ClipToBounds="True">
                                        <Border x:Name="LoadingShine" Width="60" Height="3" 
                                HorizontalAlignment="Left" Margin="-60,0,0,0">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                                    <GradientStop Color="Transparent" Offset="0"/>
                                                    <GradientStop Color="#55FFFFFF" Offset="0.5"/>
                                                    <GradientStop Color="Transparent" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                            <Border.Triggers>
                                                <EventTrigger RoutedEvent="Loaded">
                                                    <BeginStoryboard>
                                                        <Storyboard RepeatBehavior="Forever">
                                                            <ThicknessAnimation Storyboard.TargetName="LoadingShine"
                                                Storyboard.TargetProperty="Margin"
                                                From="-60,0,0,0" To="280,0,0,0"
                                                Duration="0:0:1.5" />
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </EventTrigger>
                                            </Border.Triggers>
                                        </Border>
                                    </Border>
                                </Border>
                            </Grid>

                            <!-- 状态文字 -->
                            <TextBlock x:Name="LoadingStatusText" Text="正在加载分析引擎..."
                       FontSize="12.5" Foreground="#8A8F9C" HorizontalAlignment="Center"/>

                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- ═══  迷你面板（执行时覆盖显示） ═══ -->
        <views:DOEMiniPanel x:Name="MiniPanel"
            Visibility="Collapsed"
            VerticalAlignment="Stretch" HorizontalAlignment="Stretch"/>
    </Grid>
</Window>
