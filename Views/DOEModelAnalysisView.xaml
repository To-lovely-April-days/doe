<UserControl x:Class="MaxChemical.Modules.DOE.Views.DOEModelAnalysisView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:oxy="http://oxyplot.org/wpf"
             xmlns:converters="clr-namespace:MaxChemical.Modules.DOE.Converters"
           
             Background="#F2F4F7">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="DOEStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
            <converters:BoolToOlsBackgroundConverter x:Key="BoolToBackground"/>
            <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis"/>
            <converters:StringNotEmptyToVisibilityConverter x:Key="StringToVis"/>
            <converters:BindingProxy x:Key="VmProxy" Data="{Binding}"/>
            <!-- ★ JMP 折叠面板标题栏样式 -->
            <Style x:Key="JmpSectionToggle" TargetType="ToggleButton">
                <Setter Property="IsChecked" Value="True"/>
                <Setter Property="Background" Value="#F7F8FA"/>
                <Setter Property="Foreground" Value="#1A1F36"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="FontWeight" Value="Medium"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ToggleButton">
                            <Border x:Name="Bd" Background="{TemplateBinding Background}" Padding="8,6"
                                    BorderBrush="#E8EAED" BorderThickness="0,0,0,1">
                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#EFF0F3"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ═══ 0. 顶部 GPR / OLS 大 Tab ═══ -->
        <Border Grid.Row="0" Background="White" BorderBrush="#E8EAED" BorderThickness="0,0,0,1" Padding="18,10,18,0">
            <StackPanel Orientation="Horizontal">
                <Border Padding="16,8" CornerRadius="8,8,0,0" Cursor="Hand" Margin="0,0,2,0"
                        Background="{Binding GprTabBackground}" MouseLeftButtonDown="GprTab_Click">
                    <TextBlock Text="GPR 代理模型" FontSize="13" FontWeight="SemiBold" Foreground="{Binding GprTabForeground}"/>
                </Border>
                <Border Padding="16,8" CornerRadius="8,8,0,0" Cursor="Hand"
                        Background="{Binding OlsTabBackground}" MouseLeftButtonDown="OlsTab_Click">
                    <TextBlock Text="OLS 回归分析" FontSize="13" FontWeight="SemiBold" Foreground="{Binding OlsTabForeground}"/>
                </Border>
            </StackPanel>
        </Border>

        <!-- ═══ GPR Tab 内容 ═══ -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                      Visibility="{Binding IsGprTabSelected, Converter={StaticResource BoolToVis}}"  Style="{StaticResource ThinScrollViewerStyle}">
            <StackPanel Margin="18">

                <!-- 1. 模型选择 + 操作按钮 + 指标条 -->
                <Border Background="White" CornerRadius="10" BorderBrush="#ECEEF2" BorderThickness="1" Margin="0,0,0,12">
                    <StackPanel>
                        <Border Padding="10,10,10,8" BorderBrush="#E8EAED" BorderThickness="0,0,0,1">
                            <Grid>
                                <ItemsControl ItemsSource="{Binding Models}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,0,6,4" Padding="6,4,10,4" CornerRadius="6" Cursor="Hand" BorderThickness="1"
                                                    Background="{Binding TabBackground}" BorderBrush="{Binding TabBorderBrush}"
                                                    MouseLeftButtonDown="ModelTab_Click">
                                                <StackPanel Orientation="Horizontal">
                                                    <Ellipse Width="6" Height="6" Fill="{Binding StatusDotColor}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding ModelName}" FontSize="11" Foreground="{Binding TabForeground}" FontWeight="{Binding TabFontWeight}"/>
                                                    <TextBlock Text="{Binding ShortInfo}" FontSize="10" Foreground="#999" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                                    <Button Content="重新训练" Style="{StaticResource DOEPrimaryBtn}" Padding="10,4" Height="26" FontSize="10" Command="{Binding RetrainCommand}" Margin="0,0,4,0"/>
                                    <Button Padding="10,4" Height="26" FontSize="10" Cursor="Hand" Margin="0,0,4,0" Command="{Binding DownloadTemplateCommand}">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Bd" CornerRadius="6" Padding="{TemplateBinding Padding}" Background="White" BorderBrush="#D0D0D0" BorderThickness="1">
                                                    <TextBlock Text="下载模板" FontSize="10" FontWeight="SemiBold" Foreground="#4A5066" HorizontalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="#F7F8FA"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                    <Button Padding="10,4" Height="26" FontSize="10" Cursor="Hand" Margin="0,0,4,0" Command="{Binding ImportDataCommand}">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Bd" CornerRadius="6" Padding="{TemplateBinding Padding}" Background="White" BorderBrush="#0078D4" BorderThickness="1">
                                                    <TextBlock Text="导入数据" FontSize="10" FontWeight="SemiBold" Foreground="#0078D4" HorizontalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="#EBF3FE"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                    <Button Content="刷新" Style="{StaticResource DOEOutlineBtn}" Padding="10,4" Height="26" FontSize="10" Command="{Binding RefreshAllCommand}" Margin="0,0,4,0"/>
                                    <Button Content="删除" Style="{StaticResource DOEDangerBtn}" Padding="10,4" Height="26" FontSize="10" Command="{Binding DeleteModelCommand}"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <!-- 指标条 -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="180"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" HorizontalAlignment="Center" Margin="0,12,0,12">
                                <TextBlock Text="状态" FontSize="10" Foreground="#8A8F9C" HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding SelectedModel.StatusText}" FontSize="15" FontWeight="SemiBold" Foreground="{Binding SelectedModel.StatusColor}" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                <TextBlock FontSize="10" Foreground="#AAA" HorizontalAlignment="Center"><Run Text="{Binding SelectedModel.DataCountText, Mode=OneWay}"/><Run Text=" 组数据"/></TextBlock>
                            </StackPanel>
                            <Border Grid.Column="1" Width="1" Background="#ECEEF2" VerticalAlignment="Center" Height="36"/>
                            <StackPanel Grid.Column="2" HorizontalAlignment="Center" Margin="0,12,0,12">
                                <TextBlock Text="R²" FontSize="10" Foreground="#8A8F9C" HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding SelectedModel.RSquaredText}" FontSize="18" FontWeight="SemiBold" Foreground="#0078D4" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                            </StackPanel>
                            <Border Grid.Column="3" Width="1" Background="#ECEEF2" VerticalAlignment="Center" Height="36"/>
                            <StackPanel Grid.Column="4" HorizontalAlignment="Center" Margin="0,12,0,12">
                                <TextBlock Text="RMSE" FontSize="10" Foreground="#8A8F9C" HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding SelectedModel.RMSEText}" FontSize="18" FontWeight="SemiBold" Foreground="#1A1F36" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                            </StackPanel>
                            <Border Grid.Column="5" Width="1" Background="#ECEEF2" VerticalAlignment="Center" Height="36"/>
                            <StackPanel Grid.Column="6" HorizontalAlignment="Center" Margin="0,12,0,12">
                                <TextBlock Text="上次训练" FontSize="10" Foreground="#8A8F9C" HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding SelectedModel.LastTrainedText}" FontSize="12" FontWeight="SemiBold" Foreground="#1A1F36" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                <TextBlock Text="Const × RBF + White" FontSize="10" Foreground="#AAA" HorizontalAlignment="Center"/>
                            </StackPanel>
                            <Border Grid.Column="7" Width="1" Background="#ECEEF2" VerticalAlignment="Center" Height="36"/>
                            <StackPanel Grid.Column="8" HorizontalAlignment="Center" Margin="0,12,0,12">
                                <TextBlock Text="因子签名" FontSize="10" Foreground="#8A8F9C" HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding SelectedModel.FactorSignature}" FontSize="11" FontFamily="Consolas" Foreground="#0078D4" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 2. 训练数据集 -->
                <Border Background="White" CornerRadius="10" BorderBrush="#ECEEF2" BorderThickness="1" Margin="0,0,0,12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Border Background="#FAFBFC" Padding="14,8" BorderBrush="#E8EAED" BorderThickness="0,0,0,1" CornerRadius="10,10,0,0">
                            <Grid>
                                <TextBlock Text="训练数据集" FontSize="12" FontWeight="SemiBold" Foreground="#1A1F36"/>
                                <TextBlock HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="11" Foreground="#A0A4B0"><Run Text="共 "/><Run Text="{Binding TotalDataCount, Mode=OneWay}"/><Run Text=" 条数据"/></TextBlock>
                            </Grid>
                        </Border>
                        <DataGrid Grid.Row="1" ItemsSource="{Binding PagedTrainingData}" AutoGenerateColumns="True" CanUserAddRows="False" IsReadOnly="True" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F2F3F5" BorderThickness="0" Background="White" RowBackground="White" AlternatingRowBackground="#FAFBFC" HeadersVisibility="Column" SelectionMode="Single" FontSize="11" FontFamily="Segoe UI" RowHeight="34" ColumnHeaderHeight="32" AutoGeneratingColumn="TrainingData_AutoGeneratingColumn">
                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="#FAFBFC"/>
                                    <Setter Property="Foreground" Value="#8A8F9C"/>
                                    <Setter Property="FontSize" Value="10"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Padding" Value="10,0"/>
                                    <Setter Property="BorderBrush" Value="#E8EAED"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                </Style>
                            </DataGrid.ColumnHeaderStyle>
                            <DataGrid.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="Padding" Value="8,0"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Foreground" Value="#1A1F36"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="DataGridCell">
                                                <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}">
                                                    <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#EBF3FE"/>
                                            <Setter Property="Foreground" Value="#1A1F36"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.CellStyle>
                        </DataGrid>
                        <Border Grid.Row="2" Padding="14,8" BorderBrush="#E8EAED" BorderThickness="0,1,0,0">
                            <Grid>
                                <TextBlock VerticalAlignment="Center" FontSize="11" Foreground="#A0A4B0"><Run Text="第 "/><Run Text="{Binding CurrentPage, Mode=OneWay}"/><Run Text=" / "/><Run Text="{Binding TotalPages, Mode=OneWay}"/><Run Text=" 页，每页 10 条"/></TextBlock>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Content="◀" Command="{Binding PrevPageCommand}" Width="28" Height="28" FontSize="10" Cursor="Hand" Margin="0,0,4,0">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Bd" CornerRadius="6" Background="White" BorderBrush="#D8DCE3" BorderThickness="1">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="#F2F4F7"/>
                                                    </Trigger>
                                                    <Trigger Property="IsEnabled" Value="False">
                                                        <Setter TargetName="Bd" Property="Opacity" Value="0.35"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                    <Button Content="▶" Command="{Binding NextPageCommand}" Width="28" Height="28" FontSize="10" Cursor="Hand">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Bd" CornerRadius="6" Background="White" BorderBrush="#D8DCE3" BorderThickness="1">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="#F2F4F7"/>
                                                    </Trigger>
                                                    <Trigger Property="IsEnabled" Value="False">
                                                        <Setter TargetName="Bd" Property="Opacity" Value="0.35"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <!-- 3. 图表 2x2 -->
                <UniformGrid Columns="2" Margin="0,0,0,12">
                    <Border Background="White" CornerRadius="10" BorderBrush="#ECEEF2" BorderThickness="1" Margin="0,0,5,5">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="240"/>
                            </Grid.RowDefinitions>
                            <Border Background="#FAFBFC" Padding="14,8" BorderBrush="#E8EAED" BorderThickness="0,0,0,1" CornerRadius="10,10,0,0">
                                <TextBlock Text="模型演进 R² vs 数据量" FontSize="12" FontWeight="SemiBold" Foreground="#1A1F36"/>
                            </Border>
                            <oxy:PlotView Grid.Row="1" Model="{Binding EvolutionPlot}" Background="White" Margin="8"/>
                        </Grid>
                    </Border>
                    <Border Background="White" CornerRadius="10" BorderBrush="#ECEEF2" BorderThickness="1" Margin="5,0,0,5">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="240"/>
                            </Grid.RowDefinitions>
                            <Border Background="#FAFBFC" Padding="14,8" BorderBrush="#E8EAED" BorderThickness="0,0,0,1" CornerRadius="10,10,0,0">
                                <TextBlock Text="参数敏感性（GPR Lengthscale）" FontSize="12" FontWeight="SemiBold" Foreground="#1A1F36"/>
                            </Border>
                            <oxy:PlotView Grid.Row="1" Model="{Binding SensitivityPlot}" Background="White" Margin="8"/>
                        </Grid>
                    </Border>
                    <Border Background="White" CornerRadius="10" BorderBrush="#ECEEF2" BorderThickness="1" Margin="0,5,5,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="240"/>
                            </Grid.RowDefinitions>
                            <Border Background="#FAFBFC" Padding="14,8" BorderBrush="#E8EAED" BorderThickness="0,0,0,1" CornerRadius="10,10,0,0">
                                <TextBlock Text="实际值 vs GPR 预测值" FontSize="12" FontWeight="SemiBold" Foreground="#1A1F36"/>
                            </Border>
                            <oxy:PlotView Grid.Row="1" Model="{Binding ActualVsPredictedPlot}" Background="White" Margin="8"/>
                        </Grid>
                    </Border>
                    <Border Background="White" CornerRadius="10" BorderBrush="#ECEEF2" BorderThickness="1" Margin="5,5,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="240"/>
                            </Grid.RowDefinitions>
                            <Border Background="#FAFBFC" Padding="14,8" BorderBrush="#E8EAED" BorderThickness="0,0,0,1" CornerRadius="10,10,0,0">
                                <TextBlock Text="残差 vs GPR 拟合值" FontSize="12" FontWeight="SemiBold" Foreground="#1A1F36"/>
                            </Border>
                            <oxy:PlotView Grid.Row="1" Model="{Binding ResidualPlot}" Background="White" Margin="8"/>
                        </Grid>
                    </Border>
                </UniformGrid>

                <!-- 5. 响应曲面 -->
                <Border Background="White" CornerRadius="10" BorderBrush="#ECEEF2" BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="320"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Border Background="#FAFBFC" Padding="14,8" BorderBrush="#E8EAED" BorderThickness="0,0,0,1" CornerRadius="10,10,0,0">
                            <Grid>
                                <TextBlock Text="GPR 响应曲面" FontSize="12" FontWeight="SemiBold" Foreground="#1A1F36" VerticalAlignment="Center"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                    <ComboBox ItemsSource="{Binding FactorNames}" SelectedItem="{Binding SurfaceFactor1}" Width="110" FontSize="11" Padding="4,3" Margin="0,0,4,0" Style="{StaticResource FieldComboStyle}"/>
                                    <TextBlock Text="×" VerticalAlignment="Center" Foreground="#8A8F9C" FontSize="11" Margin="0,0,4,0"/>
                                    <ComboBox ItemsSource="{Binding FactorNames}" SelectedItem="{Binding SurfaceFactor2}" Width="110" FontSize="11" Padding="4,3" Margin="0,0,8,0" Style="{StaticResource FieldComboStyle}"/>
                                    <Button Content="生成" Style="{StaticResource DOEPrimaryBtn}" Padding="14,5" Command="{Binding GenerateSurfaceCommand}" Height="26"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <Grid Grid.Row="1">
                            <Image Source="{Binding SurfaceImage}" Stretch="Uniform" Margin="10">
                                <Image.Style>
                                    <Style TargetType="Image">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SurfaceImage}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Image.Style>
                            </Image>
                            <oxy:PlotView Model="{Binding SurfacePlot}" Background="White" Margin="8">
                                <oxy:PlotView.Style>
                                    <Style TargetType="oxy:PlotView">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SurfaceImage}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </oxy:PlotView.Style>
                            </oxy:PlotView>
                        </Grid>
                        <Border Grid.Row="2" Background="#FAFBFC" Padding="12,9" BorderBrush="#E8EAED" BorderThickness="0,1,0,0" CornerRadius="0,0,10,10" Visibility="{Binding HasOptimalResult, Converter={StaticResource BoolToVis}}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,16,0">
                                    <Ellipse Width="6" Height="6" Fill="#4CAF50" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="最优预测" FontSize="11" FontWeight="SemiBold" Foreground="#1A1F36" VerticalAlignment="Center"/>
                                </StackPanel>
                                <ItemsControl Grid.Column="1" ItemsSource="{Binding OptimalFactors}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,14,0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Key}" FontSize="11" Foreground="#8A8F9C" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding Value, StringFormat={}{0:F2}}" FontSize="12" FontWeight="SemiBold" FontFamily="Consolas" Foreground="#1A1F36" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <Border Grid.Column="2" Background="#E8F5E9" CornerRadius="6" Padding="12,4">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="响应 " FontSize="11" Foreground="#388E3C" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding OptimalResponseText}" FontSize="16" FontWeight="SemiBold" Foreground="#2E7D32" FontFamily="Consolas" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding OptimalConfidenceText}" FontSize="10" Foreground="#66BB6A" VerticalAlignment="Center" Margin="6,0,0,0"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- ═══ OLS Tab 内容 ═══ -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
              Visibility="{Binding IsOlsTabSelected, Converter={StaticResource BoolToVis}}"  Style="{StaticResource ThinScrollViewerStyle}">
            <StackPanel>

                <!-- ══ 顶部工具栏 ══ -->
                <Border Background="#F7F8FA" Padding="6,5" BorderBrush="#E8EAED" BorderThickness="0,0,0,1">
                    <DockPanel LastChildFill="True">
                        <!-- ★ 右侧按钮（DockPanel.Dock=Right 优先占位） -->
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0,8,0">
                            <Button Content="Import" FontSize="10" Padding="8,3" Margin="0,0,4,0"
                                    Style="{StaticResource DOEGhostBtn}" Command="{Binding OlsImportExcelCommand}"/>
                            <Button Content="Export" FontSize="10" Padding="8,3"
                                    Style="{StaticResource DOEGhostBtn}" Command="{Binding ExportReportCommand}"/>
                        </StackPanel>

                        <!-- 左侧内容（自动填充剩余空间） -->
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <!-- 批次选择 -->
                            <TextBlock Text="Batch:" FontSize="11" FontWeight="Medium" Foreground="#1A1F36"
                                       VerticalAlignment="Center" Margin="8,0,6,0"/>
                            <ItemsControl ItemsSource="{Binding OlsBatchItems}" MaxWidth="360">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,4,0" Padding="6,3" CornerRadius="3" Cursor="Hand" BorderThickness="1" Background="White">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="BorderBrush" Value="#D0D4DC"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                            <Setter Property="BorderBrush" Value="#0078D4"/>
                                                            <Setter Property="Background" Value="#EBF3FE"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Border.InputBindings>
                                                <MouseBinding MouseAction="LeftClick"
                                                    Command="{Binding DataContext.SelectOlsBatchCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}"/>
                                            </Border.InputBindings>
                                            <TextBlock FontSize="10">
                                                <Run Text="{Binding BatchName, Mode=OneWay}" FontWeight="Medium" Foreground="#1A1F36"/>
                                                <Run Text=" (" Foreground="#8A8F9C"/><Run Text="{Binding CompletedCount, Mode=OneWay}" Foreground="#8A8F9C"/><Run Text="obs)" Foreground="#8A8F9C"/>
                                            </TextBlock>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- 响应变量 -->
                            <TextBlock Text="Response:" FontSize="11" FontWeight="Medium" Foreground="#1A1F36"
                                       VerticalAlignment="Center" Margin="12,0,6,0"/>
                            <ComboBox ItemsSource="{Binding ResponseNames}" SelectedItem="{Binding SelectedResponseName}"
                                      FontSize="10" Padding="4,2" MinWidth="80" VerticalAlignment="Center"/>

                            <!-- 分隔符 -->
                            <Border Width="1" Height="16" Background="#D0D4DC" Margin="12,0"/>

                            <!-- 编码/未编码切换 -->
                            <Border Padding="6,3" CornerRadius="3" Cursor="Hand" Margin="0,0,3,0"
                                    MouseLeftButtonDown="ToggleEquationCoding_Click">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="White"/>
                                        <Setter Property="BorderBrush" Value="#D0D4DC"/>
                                        <Setter Property="BorderThickness" Value="1"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsCodedEquation}" Value="True">
                                                <Setter Property="Background" Value="#EBF3FE"/>
                                                <Setter Property="BorderBrush" Value="#0078D4"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="Coded" FontSize="10" Foreground="#1A1F36"/>
                            </Border>
                            <Border Padding="6,3" CornerRadius="3" Cursor="Hand"
                                    MouseLeftButtonDown="ToggleEquationCoding_Click">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="White"/>
                                        <Setter Property="BorderBrush" Value="#D0D4DC"/>
                                        <Setter Property="BorderThickness" Value="1"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsCodedEquation}" Value="False">
                                                <Setter Property="Background" Value="#EBF3FE"/>
                                                <Setter Property="BorderBrush" Value="#0078D4"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="Actual" FontSize="10" Foreground="#1A1F36"/>
                            </Border>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!-- 状态文本 -->
                <TextBlock Text="{Binding OlsStatusText}" FontSize="11" Foreground="#5A7CA8"
                           Margin="14,8,14,4" TextWrapping="Wrap"
                           Visibility="{Binding HasOlsResult, Converter={StaticResource InverseBoolToVis}}"/>

                <!-- 不可估计项警告条 -->
                <Border Background="#FFF8E1" Padding="10,6" BorderBrush="#FFD54F" BorderThickness="0,0,0,1"
                        Visibility="{Binding HasInestimableWarning, Converter={StaticResource BoolToVis}}">
                    <TextBlock FontSize="10" Foreground="#F57F17" TextWrapping="Wrap">
                        <Run Text="⚠ " FontWeight="Bold"/><Run Text="{Binding InestimableWarning, Mode=OneWay}"/>
                    </TextBlock>
                </Border>

                <!-- ═══ JMP 折叠面板树 ═══ -->
                <StackPanel Visibility="{Binding HasOlsResult, Converter={StaticResource BoolToVis}}">

                    <!-- ▼ Summary of fit -->
                    <Border BorderBrush="#E8EAED" BorderThickness="0,0,0,1">
                        <StackPanel>
                            <ToggleButton x:Name="tgl_Summary" Style="{StaticResource JmpSectionToggle}" IsChecked="True">
                                <TextBlock FontSize="12" FontWeight="Medium" Foreground="#1A1F36">
                                    <Run Text="▼ " FontSize="9" Foreground="#A0A4B0"/><Run Text="Summary of fit"/>
                                </TextBlock>
                            </ToggleButton>
                            <StackPanel Margin="14,8,14,12" Visibility="{Binding IsChecked, ElementName=tgl_Summary, Converter={StaticResource BoolToVis}}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition/>
                                        <RowDefinition/>
                                        <RowDefinition/>
                                        <RowDefinition/>
                                        <RowDefinition/>
                                        <RowDefinition/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="RSquare" FontSize="11" Foreground="#8A8F9C" Padding="0,3"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" FontSize="11" FontFamily="Consolas" FontWeight="Medium" Foreground="#1A1F36" Padding="0,3" Text="{Binding OlsResult.ModelSummary.RSquared, StringFormat={}{0:F6}}"/>
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="RSquare Adj" FontSize="11" Foreground="#8A8F9C" Padding="0,3"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" FontSize="11" FontFamily="Consolas" FontWeight="Medium" Foreground="#1A1F36" Padding="0,3" Text="{Binding OlsResult.ModelSummary.RSquaredAdj, StringFormat={}{0:F6}}"/>
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="RSquare Pred" FontSize="11" Foreground="#8A8F9C" Padding="0,3"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" FontSize="11" FontFamily="Consolas" FontWeight="Medium" Foreground="#1A1F36" Padding="0,3" Text="{Binding OlsResult.ModelSummary.RSquaredPred, StringFormat={}{0:F6}}"/>
                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Root Mean Square Error" FontSize="11" Foreground="#8A8F9C" Padding="0,3"/>
                                    <TextBlock Grid.Row="3" Grid.Column="1" FontSize="11" FontFamily="Consolas" FontWeight="Medium" Foreground="#1A1F36" Padding="0,3" Text="{Binding OlsResult.ModelSummary.RMSE, StringFormat={}{0:F6}}"/>
                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Adequate Precision" FontSize="11" Foreground="#8A8F9C" Padding="0,3"/>
                                    <TextBlock Grid.Row="4" Grid.Column="1" FontSize="11" FontFamily="Consolas" FontWeight="Medium" Foreground="#1A1F36" Padding="0,3" Text="{Binding OlsResult.ModelSummary.AdequatePrecision, StringFormat={}{0:F4}}"/>
                                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Lack of Fit p-value" FontSize="11" Foreground="#8A8F9C" Padding="0,3"/>
                                    <TextBlock Grid.Row="5" Grid.Column="1" FontSize="11" FontFamily="Consolas" FontWeight="Medium" Foreground="#1A1F36" Padding="0,3" Text="{Binding OlsResult.ModelSummary.LackOfFitP, StringFormat={}{0:F6}}"/>
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- ▼ Regression equation -->
                    <Border BorderBrush="#E8EAED" BorderThickness="0,0,0,1">
                        <StackPanel>
                            <ToggleButton x:Name="tgl_Equation" Style="{StaticResource JmpSectionToggle}" IsChecked="True">
                                <TextBlock FontSize="12" FontWeight="Medium" Foreground="#1A1F36">
                                    <Run Text="▼ " FontSize="9" Foreground="#A0A4B0"/><Run Text="Regression equation"/>
                                </TextBlock>
                            </ToggleButton>
                            <StackPanel Margin="14,8,14,12" Visibility="{Binding IsChecked, ElementName=tgl_Equation, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="{Binding EquationModeText, StringFormat='Final equation in terms of {0}:'}" FontSize="10" Foreground="#A0A4B0" Margin="0,0,0,6"/>
                                <Border Background="#F7F8FA" CornerRadius="3" Padding="10,8" Visibility="{Binding HasCategoricalEquations, Converter={StaticResource InverseBoolToVis}}">
                                    <TextBlock Text="{Binding CurrentEquationText}" FontSize="11" FontFamily="Consolas" Foreground="#1A1F36" TextWrapping="Wrap" LineHeight="20"/>
                                </Border>
                                <ItemsControl ItemsSource="{Binding CategoryEquations}" Visibility="{Binding HasCategoricalEquations, Converter={StaticResource BoolToVis}}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="0,0,0,6">
                                                <TextBlock FontSize="10" FontWeight="Medium" Foreground="#0078D4" Margin="0,0,0,2"><Run Text="{Binding LevelName, Mode=OneWay}"/></TextBlock>
                                                <Border Background="#F7F8FA" CornerRadius="3" Padding="10,6">
                                                    <TextBlock Text="{Binding Equation}" FontSize="11" FontFamily="Consolas" Foreground="#1A1F36" TextWrapping="Wrap" LineHeight="20"/>
                                                </Border>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- ▼ Analysis of variance -->
                    <Border BorderBrush="#E8EAED" BorderThickness="0,0,0,1">
                        <StackPanel>
                            <ToggleButton x:Name="tgl_Anova" Style="{StaticResource JmpSectionToggle}" IsChecked="True">
                                <TextBlock FontSize="12" FontWeight="Medium" Foreground="#1A1F36">
                                    <Run Text="▼ " FontSize="9" Foreground="#A0A4B0"/><Run Text="Analysis of variance"/>
                                </TextBlock>
                            </ToggleButton>
                            <Border Margin="14,8,14,12" Visibility="{Binding IsChecked, ElementName=tgl_Anova, Converter={StaticResource BoolToVis}}">
                                <DataGrid ItemsSource="{Binding OlsResult.AnovaTable}" AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#E8EAED" BorderThickness="0" CanUserAddRows="False" Background="White" FontFamily="Consolas" FontSize="10" RowHeight="24" MaxHeight="350">
                                    <DataGrid.ColumnHeaderStyle>
                                        <Style TargetType="DataGridColumnHeader">
                                            <Setter Property="Background" Value="White"/>
                                            <Setter Property="Foreground" Value="#8A8F9C"/>
                                            <Setter Property="FontSize" Value="10"/>
                                            <Setter Property="FontFamily" Value="Segoe UI"/>
                                            <Setter Property="FontWeight" Value="Medium"/>
                                            <Setter Property="Padding" Value="6,4"/>
                                            <Setter Property="BorderBrush" Value="#1A1F36"/>
                                            <Setter Property="BorderThickness" Value="0,0,0,1.5"/>
                                        </Style>
                                    </DataGrid.ColumnHeaderStyle>
                                    <DataGrid.CellStyle>
                                        <Style TargetType="DataGridCell">
                                            <Setter Property="BorderThickness" Value="0"/>
                                            <Setter Property="Padding" Value="6,0"/>
                                            <Setter Property="Foreground" Value="#1A1F36"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="DataGridCell">
                                                        <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}">
                                                            <ContentPresenter VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </DataGrid.CellStyle>
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Source" Binding="{Binding Source}" Width="100">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="FontFamily" Value="Segoe UI"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="DF" Binding="{Binding DF}" Width="45">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="TextAlignment" Value="Right"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="Sum of squares" Binding="{Binding SS, StringFormat={}{0:F4}}" Width="110">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="TextAlignment" Value="Right"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="Mean square" Binding="{Binding MS, StringFormat={}{0:F4}}" Width="100">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="TextAlignment" Value="Right"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="F ratio" Binding="{Binding FValue, StringFormat={}{0:F2}}" Width="80">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="TextAlignment" Value="Right"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="Prob > F" Binding="{Binding PValue, StringFormat={}{0:F4}}" Width="90">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="TextAlignment" Value="Right"/>
                                                    <Setter Property="Foreground" Value="#1A1F36"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSignificant}" Value="True">
                                                            <Setter Property="Foreground" Value="#C62828"/>
                                                            <Setter Property="FontWeight" Value="Medium"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ▼ Parameter estimates -->
                    <Border BorderBrush="#E8EAED" BorderThickness="0,0,0,1">
                        <StackPanel>
                            <ToggleButton x:Name="tgl_Params" Style="{StaticResource JmpSectionToggle}" IsChecked="True">
                                <TextBlock FontSize="12" FontWeight="Medium" Foreground="#1A1F36">
                                    <Run Text="▼ " FontSize="9" Foreground="#A0A4B0"/><Run Text="Parameter estimates"/>
                                </TextBlock>
                            </ToggleButton>
                            <Border Margin="14,8,14,12" Visibility="{Binding IsChecked, ElementName=tgl_Params, Converter={StaticResource BoolToVis}}">
                                <DataGrid ItemsSource="{Binding DisplayCoefficients}" AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#E8EAED" BorderThickness="0" CanUserAddRows="False" Background="White" FontFamily="Consolas" FontSize="10" RowHeight="24" MaxHeight="350">
                                    <DataGrid.ColumnHeaderStyle>
                                        <Style TargetType="DataGridColumnHeader">
                                            <Setter Property="Background" Value="White"/>
                                            <Setter Property="Foreground" Value="#8A8F9C"/>
                                            <Setter Property="FontSize" Value="10"/>
                                            <Setter Property="FontFamily" Value="Segoe UI"/>
                                            <Setter Property="FontWeight" Value="Medium"/>
                                            <Setter Property="Padding" Value="6,4"/>
                                            <Setter Property="BorderBrush" Value="#1A1F36"/>
                                            <Setter Property="BorderThickness" Value="0,0,0,1.5"/>
                                        </Style>
                                    </DataGrid.ColumnHeaderStyle>
                                    <DataGrid.CellStyle>
                                        <Style TargetType="DataGridCell">
                                            <Setter Property="BorderThickness" Value="0"/>
                                            <Setter Property="Padding" Value="6,0"/>
                                            <Setter Property="Foreground" Value="#1A1F36"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="DataGridCell">
                                                        <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}">
                                                            <ContentPresenter VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </DataGrid.CellStyle>
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Term" Binding="{Binding Term}" Width="110">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="FontFamily" Value="Segoe UI"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="Effect" Binding="{Binding Effect, StringFormat={}{0:F3}}" Width="80"
   Visibility="{Binding Data.HasCurvatureTest, Source={StaticResource VmProxy}, Converter={StaticResource BoolToVis}}">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="TextAlignment" Value="Right"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="Estimate" Binding="{Binding Coefficient, StringFormat={}{0:F6}}" Width="100">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="TextAlignment" Value="Right"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="Std error" Binding="{Binding StdError, StringFormat={}{0:F6}}" Width="100">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="TextAlignment" Value="Right"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="t ratio" Binding="{Binding TValue, StringFormat={}{0:F4}}" Width="80">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="TextAlignment" Value="Right"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="Prob>|t|" Binding="{Binding PValue, StringFormat={}{0:F4}}" Width="90">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="TextAlignment" Value="Right"/>
                                                    <Setter Property="Foreground" Value="#1A1F36"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSignificant}" Value="True">
                                                            <Setter Property="Foreground" Value="#C62828"/>
                                                            <Setter Property="FontWeight" Value="Medium"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="VIF" Binding="{Binding VIF, StringFormat={}{0:F2}}" Width="65">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="TextAlignment" Value="Right"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ▼ Effect tests — Pareto -->
                    <Border BorderBrush="#E8EAED" BorderThickness="0,0,0,1">
                        <StackPanel>
                            <ToggleButton x:Name="tgl_Pareto" Style="{StaticResource JmpSectionToggle}" IsChecked="True">
                                <Grid>
                                    <TextBlock FontSize="12" FontWeight="Medium" Foreground="#1A1F36" VerticalAlignment="Center">
                                        <Run Text="▼ " FontSize="9" Foreground="#A0A4B0"/><Run Text="Effect tests — Pareto"/>
                                    </TextBlock>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                        <Button Content="Refit reduced" FontSize="9" Padding="6,2" Style="{StaticResource DOEGhostBtn}" Foreground="#0078D4" Command="{Binding RefitReducedModelCommand}" Margin="0,0,4,0"/>
                                        <Button Content="Restore full" FontSize="9" Padding="6,2" Style="{StaticResource DOEGhostBtn}" Foreground="#8A8F9C" Command="{Binding RestoreFullModelCommand}"/>
                                    </StackPanel>
                                </Grid>
                            </ToggleButton>
                            <StackPanel Margin="14,8,14,12" Visibility="{Binding IsChecked, ElementName=tgl_Pareto, Converter={StaticResource BoolToVis}}">
                                <TextBlock FontSize="10" Foreground="#A0A4B0" Margin="0,0,0,6" Text="{Binding ParetoSubtitle}"/>
                                <Border BorderBrush="#E8EAED" BorderThickness="1" CornerRadius="3">
                                    <oxy:PlotView Model="{Binding OlsParetoPlot}" Height="240" Background="White" x:Name="OlsParetoPlotView" PreviewMouseDown="OlsPareto_MouseDown"/>
                                </Border>
                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                    <TextBlock FontSize="10" Foreground="#8A8F9C"><Run Text="Included: "/><Run Text="{Binding IncludedTermsText, Mode=OneWay}" Foreground="#1A1F36"/></TextBlock>
                                </StackPanel>
                                <TextBlock FontSize="10" Foreground="#8A8F9C" Margin="0,2,0,0" Visibility="{Binding ExcludedTermsText, Converter={StaticResource StringToVis}}">
                                    <Run Text="Excluded: "/><Run Text="{Binding ExcludedTermsText, Mode=OneWay}" Foreground="#C62828"/>
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- ▼ Residual diagnostics -->
                    <Border BorderBrush="#E8EAED" BorderThickness="0,0,0,1">
                        <StackPanel>
                            <ToggleButton x:Name="tgl_Residual" Style="{StaticResource JmpSectionToggle}" IsChecked="True">
                                <TextBlock FontSize="12" FontWeight="Medium" Foreground="#1A1F36">
                                    <Run Text="▼ " FontSize="9" Foreground="#A0A4B0"/><Run Text="Residual diagnostics"/>
                                </TextBlock>
                            </ToggleButton>
                            <StackPanel Margin="14,8,14,12" Visibility="{Binding IsChecked, ElementName=tgl_Residual, Converter={StaticResource BoolToVis}}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="8"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Border Grid.Row="0" Grid.Column="0" BorderBrush="#E8EAED" BorderThickness="1" CornerRadius="3">
                                        <StackPanel>
                                            <TextBlock Text="Normal quantile plot" FontSize="9" Foreground="#A0A4B0" Margin="6,4,0,0"/>
                                            <oxy:PlotView Model="{Binding NormalProbPlot}" Height="200" Background="White"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Row="0" Grid.Column="2" BorderBrush="#E8EAED" BorderThickness="1" CornerRadius="3">
                                        <StackPanel>
                                            <TextBlock Text="Residual vs predicted" FontSize="9" Foreground="#A0A4B0" Margin="6,4,0,0"/>
                                            <oxy:PlotView Model="{Binding ResidVsFittedPlot}" Height="200" Background="White"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Row="2" Grid.Column="0" BorderBrush="#E8EAED" BorderThickness="1" CornerRadius="3">
                                        <StackPanel>
                                            <TextBlock Text="Residual histogram" FontSize="9" Foreground="#A0A4B0" Margin="6,4,0,0"/>
                                            <oxy:PlotView Model="{Binding ResidHistogramPlot}" Height="200" Background="White"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Row="2" Grid.Column="2" BorderBrush="#E8EAED" BorderThickness="1" CornerRadius="3">
                                        <StackPanel>
                                            <TextBlock Text="Residual by row number" FontSize="9" Foreground="#A0A4B0" Margin="6,4,0,0"/>
                                            <oxy:PlotView Model="{Binding ResidVsOrderPlot}" Height="200" Background="White"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- ▼ Response surface -->
                    <Border BorderBrush="#E8EAED" BorderThickness="0,0,0,1">
                        <StackPanel>
                            <ToggleButton x:Name="tgl_Surface" Style="{StaticResource JmpSectionToggle}" IsChecked="True">
                                <Grid>
                                    <TextBlock FontSize="12" FontWeight="Medium" Foreground="#1A1F36" VerticalAlignment="Center">
                                        <Run Text="▼ " FontSize="9" Foreground="#A0A4B0"/><Run Text="Response surface"/>
                                    </TextBlock>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                        <TextBlock Text="Factor 1:" FontSize="10" Foreground="#8A8F9C" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                        <ComboBox ItemsSource="{Binding OlsContinuousFactors}" SelectedItem="{Binding OlsSurfaceFactor1}" FontSize="10" Padding="3,1" MinWidth="70" VerticalAlignment="Center"/>
                                        <TextBlock Text=" × " FontSize="10" Foreground="#8A8F9C" VerticalAlignment="Center" Margin="4,0"/>
                                        <TextBlock Text="Factor 2:" FontSize="10" Foreground="#8A8F9C" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                        <ComboBox ItemsSource="{Binding OlsContinuousFactors}" SelectedItem="{Binding OlsSurfaceFactor2}" FontSize="10" Padding="3,1" MinWidth="70" VerticalAlignment="Center"/>
                                        <Button Content="Generate" FontSize="9" Padding="6,2" Margin="6,0,0,0" Style="{StaticResource DOEGhostBtn}" Foreground="#0078D4" Command="{Binding GenerateOlsSurfaceCommand}"/>
                                    </StackPanel>
                                </Grid>
                            </ToggleButton>
                            <StackPanel Margin="14,8,14,12" Visibility="{Binding IsChecked, ElementName=tgl_Surface, Converter={StaticResource BoolToVis}}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" BorderBrush="#E8EAED" BorderThickness="1" CornerRadius="3">
                                        <Grid>
                                            <Image Source="{Binding OlsSurfaceImage}" Stretch="Uniform" MaxHeight="300">
                                                <Image.Style>
                                                    <Style TargetType="Image">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding OlsSurfaceImage}" Value="{x:Null}">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Image.Style>
                                            </Image>
                                            <TextBlock Text="Select two factors and click Generate" FontSize="10" Foreground="#A0A4B0" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding OlsSurfaceImage}" Value="{x:Null}">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style></TextBlock>
                                        </Grid>
                                    </Border>
                                    <Border Grid.Column="2" BorderBrush="#E8EAED" BorderThickness="1" CornerRadius="3">
                                        <oxy:PlotView Model="{Binding OlsContourPlot}" Height="300" Background="White"/>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- ▼ Effect summary -->
                    <Border BorderBrush="#E8EAED" BorderThickness="0,0,0,1">
                        <StackPanel>
                            <ToggleButton x:Name="tgl_Effects" Style="{StaticResource JmpSectionToggle}" IsChecked="True">
                                <TextBlock FontSize="12" FontWeight="Medium" Foreground="#1A1F36">
                                    <Run Text="▼ " FontSize="9" Foreground="#A0A4B0"/><Run Text="Effect summary"/>
                                </TextBlock>
                            </ToggleButton>
                            <StackPanel Margin="14,8,14,12" Visibility="{Binding IsChecked, ElementName=tgl_Effects, Converter={StaticResource BoolToVis}}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" BorderBrush="#E8EAED" BorderThickness="1" CornerRadius="3">
                                        <StackPanel>
                                            <TextBlock Text="Main effects plot" FontSize="9" Foreground="#A0A4B0" Margin="6,4,0,0"/>
                                            <oxy:PlotView Model="{Binding OlsMainEffectsPlot}" Height="220" Background="White"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="2" BorderBrush="#E8EAED" BorderThickness="1" CornerRadius="3">
                                        <StackPanel>
                                            <TextBlock Text="Interaction plot" FontSize="9" Foreground="#A0A4B0" Margin="6,4,0,0"/>
                                            <oxy:PlotView Model="{Binding OlsInteractionPlot}" Height="220" Background="White"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- ▼ Prediction profiler -->
                    <Border BorderBrush="#E8EAED" BorderThickness="0,0,0,1">
                        <StackPanel>
                            <ToggleButton x:Name="tgl_Profiler" Style="{StaticResource JmpSectionToggle}" IsChecked="True">
                                <Grid>
                                    <TextBlock FontSize="12" FontWeight="Medium" Foreground="#1A1F36" VerticalAlignment="Center">
                                        <Run Text="▼ " FontSize="9" Foreground="#A0A4B0"/><Run Text="Prediction profiler"/>
                                    </TextBlock>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                        <Button Content="Load profiler" FontSize="9" Padding="6,2" Margin="0,0,4,0" Style="{StaticResource DOEGhostBtn}" Foreground="#0078D4" Command="{Binding LoadProfilerCommand}"/>
                                        <Button Content="Maximize ↑" FontSize="9" Padding="6,2" Margin="0,0,4,0" Style="{StaticResource DOEGhostBtn}" Foreground="#0078D4" Command="{Binding FindOptimalMaxCommand}"/>
                                        <Button Content="Minimize ↓" FontSize="9" Padding="6,2" Margin="0,0,4,0" Style="{StaticResource DOEGhostBtn}" Foreground="#8A8F9C" Command="{Binding FindOptimalMinCommand}"/>
                                        <Button Content="Desirability" FontSize="9" Padding="6,2" Style="{StaticResource DOEGhostBtn}" Foreground="#8A8F9C" Command="{Binding ToggleDesirabilityCommand}"/>
                                    </StackPanel>
                                </Grid>
                            </ToggleButton>
                            <StackPanel Visibility="{Binding IsChecked, ElementName=tgl_Profiler, Converter={StaticResource BoolToVis}}">
                                <StackPanel Margin="14,8,14,12" Visibility="{Binding IsProfilerLoaded, Converter={StaticResource BoolToVis}}">
                                    <Border Background="#F7F8FA" CornerRadius="3" Padding="10,6" Margin="0,0,0,8" BorderBrush="#E8EAED" BorderThickness="1">
                                        <TextBlock FontSize="11" FontFamily="Consolas" Foreground="#1A1F36" Text="{Binding ProfilerCurrentPredicted}"/>
                                    </Border>
                                    <ItemsControl ItemsSource="{Binding ProfilerPlots}" x:Name="ProfilerItemsControl">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <UniformGrid Rows="1"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border BorderBrush="#E8EAED" BorderThickness="0,0,1,0" Margin="0">
                                                    <oxy:PlotView Model="{Binding}" Height="200" Background="White"
                                                                   PreviewMouseDown="Profiler_MouseDown" PreviewMouseMove="Profiler_MouseMove" PreviewMouseUp="Profiler_MouseUp"/>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <ItemsControl ItemsSource="{Binding DesirabilityPlots}" x:Name="DesirabilityItemsControl"
                                                  Visibility="{Binding IsDesirabilityVisible, Converter={StaticResource BoolToVis}}" Margin="0,4,0,0">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <UniformGrid Rows="1"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border BorderBrush="#E8EAED" BorderThickness="0,0,1,0">
                                                    <oxy:PlotView Model="{Binding}" Height="160" Background="White"
                                                                   PreviewMouseDown="DesirabilityProfiler_MouseDown" PreviewMouseMove="DesirabilityProfiler_MouseMove" PreviewMouseUp="DesirabilityProfiler_MouseUp"/>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <Border Background="#F7F8FA" CornerRadius="3" Padding="10,6" Margin="0,8,0,0" BorderBrush="#E8EAED" BorderThickness="1"
                                            Visibility="{Binding OptimalResultText, Converter={StaticResource StringToVis}}">
                                        <TextBlock Text="{Binding OptimalResultText}" FontSize="10" FontFamily="Consolas" Foreground="#1A1F36" TextWrapping="Wrap" LineHeight="18"/>
                                    </Border>
                                </StackPanel>
                                <TextBlock Text="Click 'Load profiler' to generate interactive prediction profiler."
                                           FontSize="10" Foreground="#A0A4B0" Margin="14,8,14,12"
                                           Visibility="{Binding IsProfilerLoaded, Converter={StaticResource InverseBoolToVis}}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- ▼ Box-Cox transformation -->
                    <Border BorderBrush="#E8EAED" BorderThickness="0,0,0,1" Visibility="{Binding HasBoxCoxResult, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <ToggleButton x:Name="tgl_BoxCox" Style="{StaticResource JmpSectionToggle}" IsChecked="True">
                                <Grid>
                                    <TextBlock FontSize="12" FontWeight="Medium" Foreground="#1A1F36" VerticalAlignment="Center">
                                        <Run Text="▼ " FontSize="9" Foreground="#A0A4B0"/><Run Text="Box-Cox transformation"/>
                                    </TextBlock>
                                    <Button Content="Apply transform" FontSize="9" Padding="6,2" HorizontalAlignment="Right" VerticalAlignment="Center" Style="{StaticResource DOEGhostBtn}" Foreground="#0078D4" Command="{Binding ApplyBoxCoxCommand}"/>
                                </Grid>
                            </ToggleButton>
                            <StackPanel Margin="14,8,14,12" Visibility="{Binding IsChecked, ElementName=tgl_BoxCox, Converter={StaticResource BoolToVis}}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" BorderBrush="#E8EAED" BorderThickness="1" CornerRadius="3">
                                        <oxy:PlotView Model="{Binding BoxCoxProfilePlot}" Height="200" Background="White"/>
                                    </Border>
                                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="140"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition/>
                                                <RowDefinition/>
                                                <RowDefinition/>
                                                <RowDefinition/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Optimal λ" FontSize="11" Foreground="#8A8F9C" Padding="0,3"/>
                                            <TextBlock Grid.Row="0" Grid.Column="1" FontSize="11" FontFamily="Consolas" FontWeight="Medium" Text="{Binding BoxCoxLambda, StringFormat={}{0:F2}}" Padding="0,3"/>
                                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Transform" FontSize="11" Foreground="#8A8F9C" Padding="0,3"/>
                                            <TextBlock Grid.Row="1" Grid.Column="1" FontSize="11" FontWeight="Medium" Text="{Binding BoxCoxTransformName}" Padding="0,3"/>
                                            <TextBlock Grid.Row="2" Grid.Column="0" Text="R² (original)" FontSize="11" Foreground="#8A8F9C" Padding="0,3"/>
                                            <TextBlock Grid.Row="2" Grid.Column="1" FontSize="11" FontFamily="Consolas" Text="{Binding BoxCoxOrigR2, StringFormat={}{0:F4}}" Padding="0,3"/>
                                            <TextBlock Grid.Row="3" Grid.Column="0" Text="R² (transformed)" FontSize="11" Foreground="#8A8F9C" Padding="0,3"/>
                                            <TextBlock Grid.Row="3" Grid.Column="1" FontSize="11" FontFamily="Consolas" Text="{Binding BoxCoxTransR2, StringFormat={}{0:F4}}" Padding="0,3"/>
                                        </Grid>
                                        <TextBlock Text="{Binding BoxCoxRecommendation}" FontSize="10" Foreground="#5A9C76" TextWrapping="Wrap" LineHeight="18"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- ▼ Outlier diagnostics -->
                    <Border BorderBrush="#E8EAED" BorderThickness="0,0,0,1" Visibility="{Binding HasOutliers, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <ToggleButton x:Name="tgl_Outlier" Style="{StaticResource JmpSectionToggle}" IsChecked="True">
                                <Grid>
                                    <TextBlock FontSize="12" FontWeight="Medium" Foreground="#1A1F36" VerticalAlignment="Center">
                                        <Run Text="▼ " FontSize="9" Foreground="#A0A4B0"/><Run Text="Outlier diagnostics"/>
                                    </TextBlock>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                        <Button Content="Exclude selected" FontSize="9" Padding="6,2" Margin="0,0,4,0" Style="{StaticResource DOEGhostBtn}" Foreground="#C62828" Command="{Binding ExcludeOutliersCommand}"/>
                                        <Button Content="Restore all" FontSize="9" Padding="6,2" Style="{StaticResource DOEGhostBtn}" Foreground="#8A8F9C" Command="{Binding RestoreAllDataCommand}"/>
                                    </StackPanel>
                                </Grid>
                            </ToggleButton>
                            <StackPanel Margin="14,8,14,12" Visibility="{Binding IsChecked, ElementName=tgl_Outlier, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="{Binding OutlierSummaryText}" FontSize="10" Foreground="#8A8F9C" Margin="0,0,0,6"/>
                                <DataGrid ItemsSource="{Binding OutlierItems}" AutoGenerateColumns="False" IsReadOnly="False" HeadersVisibility="Column" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#E8EAED" BorderThickness="0" CanUserAddRows="False" Background="White" FontFamily="Consolas" FontSize="10" RowHeight="24" MaxHeight="200">
                                    <DataGrid.ColumnHeaderStyle>
                                        <Style TargetType="DataGridColumnHeader">
                                            <Setter Property="Background" Value="White"/>
                                            <Setter Property="Foreground" Value="#8A8F9C"/>
                                            <Setter Property="FontSize" Value="10"/>
                                            <Setter Property="FontFamily" Value="Segoe UI"/>
                                            <Setter Property="FontWeight" Value="Medium"/>
                                            <Setter Property="Padding" Value="6,4"/>
                                            <Setter Property="BorderBrush" Value="#1A1F36"/>
                                            <Setter Property="BorderThickness" Value="0,0,0,1.5"/>
                                        </Style>
                                    </DataGrid.ColumnHeaderStyle>
                                    <DataGrid.Columns>
                                        <DataGridCheckBoxColumn Header="Exclude" Binding="{Binding IsExcluded, UpdateSourceTrigger=PropertyChanged}" Width="55"/>
                                        <DataGridTextColumn Header="Obs" Binding="{Binding Index}" Width="40"/>
                                        <DataGridTextColumn Header="Actual" Binding="{Binding Actual, StringFormat={}{0:F4}}" Width="80"/>
                                        <DataGridTextColumn Header="Predicted" Binding="{Binding Predicted, StringFormat={}{0:F4}}" Width="80"/>
                                        <DataGridTextColumn Header="Std resid" Binding="{Binding StdResidual, StringFormat={}{0:F3}}" Width="70"/>
                                        <DataGridTextColumn Header="Cook's D" Binding="{Binding CooksD, StringFormat={}{0:F4}}" Width="70"/>
                                        <DataGridTextColumn Header="Leverage" Binding="{Binding Leverage, StringFormat={}{0:F4}}" Width="70"/>
                                        <DataGridTextColumn Header="Reasons" Binding="{Binding Reasons}" Width="*">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="FontFamily" Value="Segoe UI"/>
                                                    <Setter Property="Foreground" Value="#C62828"/>
                                                    <Setter Property="FontSize" Value="9"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- ▼ Tukey HSD -->
                    <Border BorderBrush="#E8EAED" BorderThickness="0,0,0,1" Visibility="{Binding HasTukeyResult, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <ToggleButton x:Name="tgl_Tukey" Style="{StaticResource JmpSectionToggle}" IsChecked="True">
                                <TextBlock FontSize="12" FontWeight="Medium" Foreground="#1A1F36">
                                    <Run Text="▼ " FontSize="9" Foreground="#A0A4B0"/><Run Text="Tukey HSD — "/><Run Text="{Binding TukeyFactorName, Mode=OneWay}"/>
                                </TextBlock>
                            </ToggleButton>
                            <StackPanel Margin="14,8,14,12" Visibility="{Binding IsChecked, ElementName=tgl_Tukey, Converter={StaticResource BoolToVis}}">
                                <DataGrid ItemsSource="{Binding TukeyComparisons}" AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#E8EAED" BorderThickness="0" CanUserAddRows="False" Background="White" FontFamily="Consolas" FontSize="10" RowHeight="24" MaxHeight="200">
                                    <DataGrid.ColumnHeaderStyle>
                                        <Style TargetType="DataGridColumnHeader">
                                            <Setter Property="Background" Value="White"/>
                                            <Setter Property="Foreground" Value="#8A8F9C"/>
                                            <Setter Property="FontSize" Value="10"/>
                                            <Setter Property="FontFamily" Value="Segoe UI"/>
                                            <Setter Property="FontWeight" Value="Medium"/>
                                            <Setter Property="Padding" Value="6,4"/>
                                            <Setter Property="BorderBrush" Value="#1A1F36"/>
                                            <Setter Property="BorderThickness" Value="0,0,0,1.5"/>
                                        </Style>
                                    </DataGrid.ColumnHeaderStyle>
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Comparison" Binding="{Binding ComparisonText}" Width="120">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="FontFamily" Value="Segoe UI"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="Mean diff" Binding="{Binding DiffText}" Width="90">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="TextAlignment" Value="Right"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="p-value" Binding="{Binding PValueText}" Width="80">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="TextAlignment" Value="Right"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Significant}" Value="True">
                                                            <Setter Property="Foreground" Value="#C62828"/>
                                                            <Setter Property="FontWeight" Value="Medium"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="95% CI" Binding="{Binding CIText}" Width="120">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="TextAlignment" Value="Right"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="" Binding="{Binding SignificanceMarker}" Width="30">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#C62828"/>
                                                    <Setter Property="FontWeight" Value="Bold"/>
                                                    <Setter Property="TextAlignment" Value="Center"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <!-- ★ Loading 遮罩 — StatusMessage 改为 OlsStatusText 同步 -->
        <Border Grid.RowSpan="2" Background="#F0FFFFFF"
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}" Panel.ZIndex="50">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="320">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,16">
                    <Grid Width="28" Height="28" Margin="0,0,10,0">
                        <Ellipse Width="28" Height="28" Stroke="#E8EAED" StrokeThickness="2.5"/>
                        <Ellipse Width="28" Height="28" Stroke="#0078D4" StrokeThickness="2.5"
                                 StrokeDashArray="6 5" StrokeStartLineCap="Round" StrokeEndLineCap="Round" RenderTransformOrigin="0.5,0.5">
                            <Ellipse.RenderTransform>
                                <RotateTransform Angle="0"/>
                            </Ellipse.RenderTransform>
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                            <DataTrigger.EnterActions>
                                                <BeginStoryboard x:Name="SpinStory">
                                                    <Storyboard RepeatBehavior="Forever">
                                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)" From="0" To="360" Duration="0:0:0.8"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.EnterActions>
                                            <DataTrigger.ExitActions>
                                                <StopStoryboard BeginStoryboardName="SpinStory"/>
                                            </DataTrigger.ExitActions>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                    </Grid>
                    <TextBlock Text="{Binding StatusMessage}" FontSize="13" FontWeight="Medium" Foreground="#1A1F36" VerticalAlignment="Center"/>
                </StackPanel>
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{Binding LoadingStepText}" FontSize="10" Foreground="#8A8F9C" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" FontSize="10" Foreground="#A0A4B0" VerticalAlignment="Center" Text="{Binding LoadingProgressPercent, StringFormat={}{0}%}"/>
                </Grid>
                <Border Height="3" Background="#E8EAED" CornerRadius="1.5" Margin="0,0,0,14">
                    <Border Height="3" CornerRadius="1.5" Background="#0078D4" HorizontalAlignment="Left" Width="{Binding LoadingProgressWidth}"/>
                </Border>
                <ItemsControl ItemsSource="{Binding LoadingSteps}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="0,2,0,2">
                                <Grid Width="16" Height="16" Margin="0,0,8,0" VerticalAlignment="Center">
                                    <Border Width="16" Height="16" CornerRadius="8" Background="#E8F5E9" Visibility="{Binding IsCompleted, Converter={StaticResource BoolToVis}}">
                                        <TextBlock Text="✓" FontSize="9" Foreground="#2E7D32" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <Border Width="16" Height="16" CornerRadius="8" BorderBrush="#0078D4" BorderThickness="1.5" Visibility="{Binding IsActive, Converter={StaticResource BoolToVis}}">
                                        <Border Width="6" Height="6" CornerRadius="3" Background="#0078D4" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <Border Width="16" Height="16" CornerRadius="8" BorderBrush="#D0D4DC" BorderThickness="1.5" Visibility="{Binding IsPending, Converter={StaticResource BoolToVis}}"/>
                                </Grid>
                                <TextBlock Text="{Binding StepName}" FontSize="11" VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#A0A4B0"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                    <Setter Property="Foreground" Value="#1A1F36"/>
                                                    <Setter Property="FontWeight" Value="Medium"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                    <Setter Property="Foreground" Value="#8A8F9C"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
