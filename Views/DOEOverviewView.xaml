<UserControl x:Class="MaxChemical.Modules.DOE.Views.DOEOverviewView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F4F7F9">
    <UserControl.Resources>
        <ResourceDictionary Source="DOEStyles.xaml"/>
    </UserControl.Resources>

    <DockPanel Margin="28,24,28,24">

        <!-- ═══ 可恢复批次提示条 ═══ -->
        <Border DockPanel.Dock="Top" CornerRadius="10" Padding="16,12" Margin="0,0,0,20"
                Visibility="{Binding HasResumableBatch, Converter={StaticResource BoolToVis}}"
                BorderThickness="0.5" BorderBrush="#C8DEE8">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#F8FCFE" Offset="0"/>
                    <GradientStop Color="#EFF7FB" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="7" Height="7" Fill="#3A98B9" VerticalAlignment="Center" Margin="0,0,12,0">
                        <Ellipse.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever">
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                            From="1" To="0.25" Duration="0:0:0.8" AutoReverse="True"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Ellipse.Triggers>
                    </Ellipse>
                    <TextBlock Text="{Binding ResumableBatchSummary}" FontSize="13"
                               Foreground="#2A6080" VerticalAlignment="Center"/>
                </StackPanel>
                <Button Grid.Column="1" Content="继续执行" Padding="16,7" Cursor="Hand"
                        FontSize="12" FontWeight="SemiBold" Foreground="White"
                        Command="{Binding ResumeLastBatchCommand}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="#3A98B9" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#2D7E9E"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>

        <!-- ═══ 项目列表主体 ═══ -->
        <Border Background="White" CornerRadius="16" BorderBrush="#E0E8ED" BorderThickness="0.5">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- ── 标题栏 ── -->
                <Border Grid.Row="0" Padding="28,20,28,18">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="优化项目" FontSize="20" FontWeight="Medium"
                                   Foreground="#1A2B3C" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" VerticalAlignment="Center" Margin="12,0,0,0"
                                   FontSize="13" Foreground="#9EACB6">
                            <Run Text="共 "/><Run Text="{Binding TotalProjectCount, Mode=OneWay}"/><Run Text=" 个"/>
                        </TextBlock>

                        <Button Grid.Column="3" Margin="0,0,12,0" VerticalAlignment="Center" Cursor="Hand"
                                Command="{Binding GoToHistoryCommand}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <TextBlock x:Name="Tx" Text="查看历史 →" FontSize="13" Foreground="#9EACB6"/>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Tx" Property="Foreground" Value="#5A7080"/>
                                            <Setter TargetName="Tx" Property="TextDecorations" Value="Underline"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Button Grid.Column="4" Padding="20,9" Cursor="Hand" VerticalAlignment="Center"
                                Command="{Binding DataContext.CreateProjectCommand, RelativeSource={RelativeSource AncestorType=Window}}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd" Background="#3A98B9" CornerRadius="10" Padding="{TemplateBinding Padding}">
                                        <TextBlock Text="＋ 新建项目" FontSize="13" FontWeight="SemiBold" Foreground="White"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#2D7E9E"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#256B86"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </Border>

                <!-- ── 项目列表 ── -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                              Visibility="{Binding HasProjects, Converter={StaticResource BoolToVis}}">
                    <ItemsControl ItemsSource="{Binding ProjectCards}" Margin="0,0,0,8">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border x:Name="RowBorder" Background="Transparent" Padding="28,22"
                                        BorderBrush="#EFF3F5" BorderThickness="0,1,0,0" Cursor="Hand"
                                        Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=ItemsControl}}">
                                    <Border.InputBindings>
                                        <MouseBinding MouseAction="LeftDoubleClick"
                                            Command="{Binding DataContext.ContinueProjectCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding ProjectId}"/>
                                    </Border.InputBindings>
                                    <Border.ContextMenu>
                                        <ContextMenu Style="{StaticResource DOEContextMenu}">
                                            <MenuItem Header="查看详情" Style="{StaticResource DOEMenuItem}"
                                                      Command="{Binding PlacementTarget.Tag.ViewProjectDetailCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding ProjectId}"/>
                                            <MenuItem Header="查看分析" Style="{StaticResource DOEMenuItem}"
                                                      Command="{Binding PlacementTarget.Tag.ViewProjectAnalysisCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding ProjectId}"/>
                                            <MenuItem Header="查看历史" Style="{StaticResource DOEMenuItem}"
                                                      Command="{Binding PlacementTarget.Tag.ViewProjectCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding ProjectId}"/>
                                            <Separator/>
                                            <MenuItem Header="归档项目" Style="{StaticResource DOEMenuItem}"
                                                      Command="{Binding PlacementTarget.Tag.ArchiveProjectCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding ProjectId}"/>
                                            <MenuItem Header="删除项目" Style="{StaticResource DOEMenuItem}" Foreground="#D32F2F"
                                                      Command="{Binding PlacementTarget.Tag.DeleteProjectCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding ProjectId}"/>
                                        </ContextMenu>
                                    </Border.ContextMenu>

                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#F8FAFB"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- 左侧：编号色块 -->
                                        <Border Grid.Column="0" Width="40" Height="40" CornerRadius="10"
                                                VerticalAlignment="Top" Margin="0,2,18,0"
                                                HorizontalAlignment="Center">
                                            <Border.Background>
                                                <SolidColorBrush Color="{Binding PhaseColor}" Opacity="0.12"/>
                                            </Border.Background>
                                            <TextBlock Text="{Binding PhaseText}" FontSize="13"
                                                       FontWeight="Medium" HorizontalAlignment="Center"
                                                       VerticalAlignment="Center">
                                                <TextBlock.Foreground>
                                                    <SolidColorBrush Color="{Binding PhaseColor}"/>
                                                </TextBlock.Foreground>
                                            </TextBlock>
                                        </Border>

                                        <!-- 中间：项目信息 -->
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding ProjectName}" FontSize="15" FontWeight="Medium">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="#1A2B3C"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding CanContinue}" Value="False">
                                                                <Setter Property="Foreground" Value="#9EACB6"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>

                                            <TextBlock FontSize="12.5" Foreground="#8A9BAA" Margin="0,3,0,0">
                                                <Run Text="{Binding DetailSummaryText, Mode=OneWay}"/>
                                            </TextBlock>

                                            <ItemsControl ItemsSource="{Binding TagItems}" Margin="0,10,0,0">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel Orientation="Horizontal"/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Padding="9,4" Margin="0,0,5,5" CornerRadius="6"
                                                                Background="{Binding Background}">
                                                            <TextBlock Text="{Binding Text}" FontSize="10.5"
                                                                       FontWeight="Medium" Foreground="{Binding Foreground}"/>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <StackPanel Orientation="Horizontal" Margin="0,12,0,0"
                                                        Visibility="{Binding CanContinue, Converter={StaticResource BoolToVis}}">
                                                <ItemsControl ItemsSource="{Binding PhaseSegments}" VerticalAlignment="Center">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <StackPanel Orientation="Horizontal"/>
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Width="28" Height="4" CornerRadius="2" Margin="0,0,3,0"
                                                                    Background="{Binding Color}"/>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                                <TextBlock Text="{Binding PhaseProgressText}" FontSize="11"
                                                           Foreground="#A5B5C0" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- 右侧：最优值 + 按钮 -->
                                        <StackPanel Grid.Column="2" VerticalAlignment="Top" Margin="24,0,0,0"
                                                    HorizontalAlignment="Right" MinWidth="100">
                                            <TextBlock FontSize="10" Foreground="#B0BFC8" FontWeight="Medium"
                                                       HorizontalAlignment="Right" Margin="0,0,0,2">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="当前最优"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding CanContinue}" Value="False">
                                                                <Setter Property="Text" Value="最终结果"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <TextBlock Text="{Binding BestValueText}" FontSize="24" FontWeight="Medium"
                                                       FontFamily="Consolas" HorizontalAlignment="Right">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground">
                                                            <Setter.Value>
                                                                <SolidColorBrush Color="{Binding PhaseColor}"/>
                                                            </Setter.Value>
                                                        </Setter>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding CanContinue}" Value="False">
                                                                <Setter Property="Foreground" Value="#B0BFC8"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>

                                            <Button Padding="16,7" Margin="0,12,0,0" Cursor="Hand"
                                                    Visibility="{Binding CanContinue, Converter={StaticResource BoolToVis}}"
                                                    Command="{Binding DataContext.ContinueProjectCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding ProjectId}">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="Bd" CornerRadius="8" Padding="{TemplateBinding Padding}"
                                                                Background="Transparent" BorderBrush="#C8D8E0" BorderThickness="0.5">
                                                            <TextBlock x:Name="Tx" Text="继续优化 →" FontSize="12"
                                                                       FontWeight="Medium" Foreground="#3A7CA5"
                                                                       HorizontalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="Bd" Property="Background" Value="#EDF4F8"/>
                                                            </Trigger>
                                                            <Trigger Property="IsPressed" Value="True">
                                                                <Setter TargetName="Bd" Property="Background" Value="#D8EAF0"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- ── 空状态 ── -->
                <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,48,0,48">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasProjects}" Value="False">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <Border Width="64" Height="64" CornerRadius="32" Margin="0,0,0,18"
                            HorizontalAlignment="Center">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#EDF4F8" Offset="0"/>
                                <GradientStop Color="#D8EAF0" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock Text="＋" FontSize="24" Foreground="#3A98B9"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <TextBlock Text="开始第一个优化项目" FontSize="16" FontWeight="Medium"
                               Foreground="#1A2B3C" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                    <TextBlock HorizontalAlignment="Center" FontSize="13" Foreground="#8A9BAA"
                               TextAlignment="Center" Margin="0,0,0,24" LineHeight="22">
                        <Run Text="创建项目后，系统自动引导完成"/><LineBreak/>
                        <Run Text="筛选 → 路径探索 → 响应面优化 → 验证 全流程"/>
                    </TextBlock>
                    <Button Padding="24,11" Cursor="Hand" HorizontalAlignment="Center"
                            Command="{Binding DataContext.CreateProjectCommand, RelativeSource={RelativeSource AncestorType=Window}}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="#3A98B9" CornerRadius="10" Padding="{TemplateBinding Padding}">
                                    <TextBlock Text="＋ 新建项目" FontSize="14" FontWeight="SemiBold" Foreground="White"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#2D7E9E"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </DockPanel>
</UserControl>
