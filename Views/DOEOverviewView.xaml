<UserControl x:Class="MaxChemical.Modules.DOE.Views.DOEOverviewView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F2F4F7">
    <UserControl.Resources>
        <ResourceDictionary Source="DOEStyles.xaml"/>
    </UserControl.Resources>

    <DockPanel Margin="22">

        <!-- ═══ 快捷操作（顶部） ═══ -->
        <Grid DockPanel.Dock="Top" Margin="0,0,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- 新建项目卡 -->
            <Border Grid.Column="0" CornerRadius="12" BorderThickness="1" BorderBrush="#C2D9F5" Padding="26,24">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#EBF3FE" Offset="0"/>
                        <GradientStop Color="#D6E8FC" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <Ellipse Width="140" Height="140" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-30,-30,0"
                             Fill="#0A0078D4" IsHitTestVisible="False"/>
                    <Ellipse Width="100" Height="100" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,40,-40"
                             Fill="#060078D4" IsHitTestVisible="False"/>
                    <StackPanel>
                        <Border Background="#140078D4" CornerRadius="4" Padding="8,3" HorizontalAlignment="Left" Margin="0,0,0,10">
                            <TextBlock Text="QUICK START" FontSize="9" FontWeight="Bold" Foreground="#0062B8"/>
                        </Border>
                        <TextBlock Text="创建新优化项目" FontSize="15" FontWeight="Bold" Foreground="#0C1D3A" Margin="0,0,0,3"/>
                        <TextBlock Text="筛选 → 爬坡 → RSM → 验证，全流程自动引导" FontSize="11" Foreground="#5A7CA8" Margin="0,0,0,16"/>
                        <Button Content="新建项目" Style="{StaticResource DOEPrimaryBtn}" Padding="22,8"
                                HorizontalAlignment="Left"
                                Command="{Binding DataContext.CreateProjectCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 继续执行卡（有正在执行的批次时显示）-->
            <Border Grid.Column="1" CornerRadius="12" BorderThickness="1" BorderBrush="#B5E3C6" Padding="26,24"
                    Width="350" Margin="14,0,0,0"
                    Visibility="{Binding HasResumableBatch, Converter={StaticResource BoolToVis}}">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#E8F8EE" Offset="0"/>
                        <GradientStop Color="#D0F0DC" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <Ellipse Width="140" Height="140" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-30,-30,0"
                             Fill="#0A16C60C" IsHitTestVisible="False"/>
                    <StackPanel>
                        <Border Background="#140D7A3E" CornerRadius="4" Padding="8,3" HorizontalAlignment="Left" Margin="0,0,0,10">
                            <TextBlock Text="RESUME" FontSize="9" FontWeight="Bold" Foreground="#0D7A3E"/>
                        </Border>
                        <TextBlock Text="继续执行实验" FontSize="15" FontWeight="Bold" Foreground="#0A2618" Margin="0,0,0,3"/>
                        <TextBlock Text="{Binding ResumableBatchSummary}" FontSize="11" Foreground="#5A9C76" Margin="0,0,0,16"/>
                        <Button Content="继续执行 →" Style="{StaticResource DOEOutlineBtn}" Foreground="#0D7A3E" Padding="22,8"
                                HorizontalAlignment="Left" Command="{Binding ResumeLastBatchCommand}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- ═══ 指标卡 ═══ -->
        <UniformGrid DockPanel.Dock="Top" Columns="3" Margin="0,0,0,18">
            <!-- 总项目数 -->
            <Border Background="White" CornerRadius="14" BorderBrush="#ECEEF2" BorderThickness="1" Padding="20" Margin="0,0,6,0">
                <StackPanel>
                    <TextBlock Text="优化项目" FontSize="10" Foreground="#8A8F9C" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <TextBlock Text="{Binding TotalProjectCount}" FontSize="28" FontWeight="Bold" Foreground="#1A1F36"/>
                    <TextBlock Text="{Binding ActiveProjectCount, StringFormat='{}活跃 {0} 个'}" FontSize="10" Foreground="#A0A4B0" Margin="0,6,0,0"/>
                </StackPanel>
            </Border>

            <!-- 总实验数 -->
            <Border Background="White" CornerRadius="14" BorderBrush="#ECEEF2" BorderThickness="1" Padding="20" Margin="3,0,3,0">
                <StackPanel>
                    <TextBlock Text="总实验次数" FontSize="10" Foreground="#8A8F9C" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <TextBlock Text="{Binding TotalExperiments}" FontSize="28" FontWeight="Bold" Foreground="#0078D4"/>
                    <TextBlock Text="跨所有项目累计" FontSize="10" Foreground="#A0A4B0" Margin="0,6,0,0"/>
                </StackPanel>
            </Border>

            <!-- GPR 模型 -->
            <Border Background="White" CornerRadius="14" BorderBrush="#ECEEF2" BorderThickness="1" Padding="20" Margin="6,0,0,0">
                <StackPanel>
                    <TextBlock Text="GPR 模型" FontSize="10" Foreground="#8A8F9C" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <TextBlock Text="{Binding GPRStatusSummary}" FontSize="19" FontWeight="Bold" Foreground="#0D7A3E"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- ═══ 项目列表（占满剩余空间） ═══ -->
        <Border Background="White" CornerRadius="10" BorderBrush="#E8EAED" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Padding="20,13" BorderBrush="#E8EAED" BorderThickness="0,0,0,1">
                    <Grid>
                        <TextBlock Text="我的优化项目" FontSize="13" FontWeight="SemiBold" Foreground="#1A1F36"/>
                        <Button Content="查看全部历史 →" Style="{StaticResource DOELinkBtn}" HorizontalAlignment="Right"
                                FontSize="11" Command="{Binding GoToHistoryCommand}"/>
                    </Grid>
                </Border>

                <!-- 有项目时显示列表 -->
                <ItemsControl Grid.Row="1" ItemsSource="{Binding ProjectCards}"
                              Visibility="{Binding HasProjects, Converter={StaticResource BoolToVis}}"
                              Margin="12,8,12,12">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#FAFBFC" CornerRadius="8" BorderBrush="#E8EAED" BorderThickness="1"
                                    Padding="16,12" Margin="0,0,0,8" Cursor="Hand">
                                <Border.InputBindings>
                                    <MouseBinding MouseAction="LeftDoubleClick"
                                                  Command="{Binding DataContext.ContinueProjectCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                  CommandParameter="{Binding ProjectId}"/>
                                </Border.InputBindings>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- 阶段标签 -->
                                    <Border Grid.Column="0" CornerRadius="4" Padding="8,3" VerticalAlignment="Center" Margin="0,0,12,0">
                                        <Border.Background>
                                            <SolidColorBrush Color="{Binding PhaseColor}" Opacity="0.15"/>
                                        </Border.Background>
                                        <TextBlock Text="{Binding PhaseText}" FontSize="10" FontWeight="SemiBold">
                                            <TextBlock.Foreground>
                                                <SolidColorBrush Color="{Binding PhaseColor}"/>
                                            </TextBlock.Foreground>
                                        </TextBlock>
                                    </Border>

                                    <!-- 项目信息 -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding ProjectName}" FontSize="13" FontWeight="SemiBold" Foreground="#1A1F36"/>
                                        <TextBlock FontSize="11" Foreground="#8A8F9C" Margin="0,2,0,0">
                                            <Run Text="{Binding SummaryText, Mode=OneWay}"/>
                                            <Run Text=" · "/>
                                            <Run Text="{Binding UpdatedTime, StringFormat='{}{0:MM-dd HH:mm}', Mode=OneWay}"/>
                                        </TextBlock>
                                    </StackPanel>

                                    <!-- 最优值 -->
                                    <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="12,0">
                                        <TextBlock Text="最优" FontSize="9" Foreground="#A0A4B0" HorizontalAlignment="Center"/>
                                        <TextBlock Text="{Binding BestValueText}" FontSize="16" FontWeight="Bold" Foreground="#0078D4" HorizontalAlignment="Center"/>
                                    </StackPanel>

                                    <!-- 继续按钮 -->
                                    <Button Grid.Column="3" Content="继续优化 →" Padding="14,6"
                                            Visibility="{Binding CanContinue, Converter={StaticResource BoolToVis}}"
                                            Style="{StaticResource DOEOutlineBtn}" Foreground="#0078D4" FontSize="11"
                                            Command="{Binding DataContext.ContinueProjectCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding ProjectId}"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- 无项目时显示引导 -->
                <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                            Margin="0,40,0,40">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasProjects}" Value="False">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="📊" FontSize="40" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                    <TextBlock Text="还没有优化项目" FontSize="15" FontWeight="SemiBold" Foreground="#4A5066" HorizontalAlignment="Center"/>
                    <TextBlock Text="点击上方「新建项目」开始您的第一个 DOE 优化" FontSize="12" Foreground="#8A8F9C" HorizontalAlignment="Center" Margin="0,4,0,16"/>
                    <Button Content="新建项目" Style="{StaticResource DOEPrimaryBtn}" Padding="28,10"
                            HorizontalAlignment="Center"
                            Command="{Binding DataContext.CreateProjectCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
                </StackPanel>
            </Grid>
        </Border>
    </DockPanel>
</UserControl>
