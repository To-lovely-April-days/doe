<UserControl x:Class="MaxChemical.Modules.DOE.Views.DOEOverviewView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F2F4F7">
    <UserControl.Resources>
        <ResourceDictionary Source="DOEStyles.xaml"/>
    </UserControl.Resources>

    <DockPanel Margin="22">

        <!-- ═══ 可恢复批次提示条 ═══ -->
        <Border DockPanel.Dock="Top" CornerRadius="8" Padding="12,10" Margin="0,0,0,14"
                Visibility="{Binding HasResumableBatch, Converter={StaticResource BoolToVis}}"
                BorderThickness="1" BorderBrush="#FFE082" Background="#FFFBF0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="6" Height="6" Fill="#FF8F00" VerticalAlignment="Center" Margin="0,0,8,0">
                        <Ellipse.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever">
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                            From="1" To="0.3" Duration="0:0:0.8" AutoReverse="True"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Ellipse.Triggers>
                    </Ellipse>
                    <TextBlock Text="{Binding ResumableBatchSummary}" FontSize="12"
                               Foreground="#1A1F36" VerticalAlignment="Center"/>
                </StackPanel>
                <Button Grid.Column="1" Content="继续执行" Padding="14,5" Cursor="Hand"
                        FontSize="11" FontWeight="SemiBold" Foreground="White"
                        Command="{Binding ResumeLastBatchCommand}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="#FF8F00" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.9"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>

        <!-- ═══ 项目列表主体 ═══ -->
        <Border Background="White" CornerRadius="10" BorderBrush="#E8EAED" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- ── 列表头 ── -->
                <Border Grid.Row="0" Padding="18,12" BorderBrush="#E8EAED" BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="优化项目" FontSize="14" FontWeight="Bold"
                                   Foreground="#1A1F36" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0"
                                   FontSize="12" Foreground="#A0A4B0">
                            <Run Text="共 "/><Run Text="{Binding TotalProjectCount, Mode=OneWay}"/><Run Text=" 个"/>
                        </TextBlock>

                        <Button Grid.Column="3" Content="查看历史 →" Style="{StaticResource DOELinkBtn}"
                                FontSize="12" Margin="0,0,14,0" VerticalAlignment="Center"
                                Command="{Binding GoToHistoryCommand}"/>

                        <Button Grid.Column="4" Padding="18,7" Cursor="Hand" VerticalAlignment="Center"
                                Command="{Binding DataContext.CreateProjectCommand, RelativeSource={RelativeSource AncestorType=Window}}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd" Background="#0078D4" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                        <TextBlock Text="＋ 新建项目" FontSize="12" FontWeight="SemiBold" Foreground="White"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Opacity" Value="0.9"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="Bd" Property="Opacity" Value="0.8"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </Border>

                <!-- ── 项目列表 ── -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                              Visibility="{Binding HasProjects, Converter={StaticResource BoolToVis}}">
                    <ItemsControl ItemsSource="{Binding ProjectCards}" Margin="0,2,0,2">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border x:Name="RowBorder" Background="Transparent" Padding="18,16"
        BorderBrush="#F2F3F5" BorderThickness="0,0,0,1" Cursor="Hand"
        Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=ItemsControl}}">
                                    <Border.InputBindings>
                                        <MouseBinding MouseAction="LeftDoubleClick"
                                            Command="{Binding DataContext.ContinueProjectCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding ProjectId}"/>
                                    </Border.InputBindings>
                                    <Border.ContextMenu>
                                        <ContextMenu Style="{StaticResource DOEContextMenu}">
                                            <MenuItem Header="查看详情" Style="{StaticResource DOEMenuItem}"
                                                      Command="{Binding PlacementTarget.Tag.ViewProjectDetailCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding ProjectId}"/>
                                            <MenuItem Header="查看分析" Style="{StaticResource DOEMenuItem}"
                                                      Command="{Binding PlacementTarget.Tag.ViewProjectAnalysisCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding ProjectId}"/>
                                            <MenuItem Header="查看历史" Style="{StaticResource DOEMenuItem}"
                                                      Command="{Binding PlacementTarget.Tag.ViewProjectCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding ProjectId}"/>
                                            <Separator/>
                                            <MenuItem Header="归档项目" Style="{StaticResource DOEMenuItem}"
                                                      Command="{Binding PlacementTarget.Tag.ArchiveProjectCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding ProjectId}"/>
                                            <MenuItem Header="删除项目" Style="{StaticResource DOEMenuItem}" Foreground="#D32F2F"
                                                      Command="{Binding PlacementTarget.Tag.DeleteProjectCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding ProjectId}"/>
                                        </ContextMenu>
                                    </Border.ContextMenu>

                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#F7F8FA"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- 左侧：阶段标签 -->
                                        <Border Grid.Column="0" CornerRadius="4" Padding="10,4"
                                                VerticalAlignment="Top" Margin="0,2,16,0"
                                                MinWidth="42" HorizontalAlignment="Center">
                                            <Border.Background>
                                                <SolidColorBrush Color="{Binding PhaseColor}" Opacity="0.12"/>
                                            </Border.Background>
                                            <TextBlock Text="{Binding PhaseText}" FontSize="11"
                                                       FontWeight="SemiBold" HorizontalAlignment="Center">
                                                <TextBlock.Foreground>
                                                    <SolidColorBrush Color="{Binding PhaseColor}"/>
                                                </TextBlock.Foreground>
                                            </TextBlock>
                                        </Border>

                                        <!-- 中间：项目信息 + 标签 + 进度条 -->
                                        <StackPanel Grid.Column="1">
                                            <!-- 项目名 -->
                                            <TextBlock Text="{Binding ProjectName}" FontSize="14" FontWeight="Bold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="#1A1F36"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding CanContinue}" Value="False">
                                                                <Setter Property="Foreground" Value="#8A8F9C"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>

                                            <!-- 摘要行 -->
                                            <TextBlock FontSize="12" Foreground="#8A8F9C" Margin="0,3,0,0">
                                                <Run Text="{Binding DetailSummaryText, Mode=OneWay}"/>
                                            </TextBlock>

                                            <!-- 因子 + 响应标签 -->
                                            <ItemsControl ItemsSource="{Binding TagItems}" Margin="0,8,0,0">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel Orientation="Horizontal"/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Padding="8,3" Margin="0,0,5,4" CornerRadius="3"
                                                                Background="{Binding Background}">
                                                            <TextBlock Text="{Binding Text}" FontSize="11"
                                                                       Foreground="{Binding Foreground}"/>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <!-- 进度条（仅活跃项目） -->
                                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0"
                                                        Visibility="{Binding CanContinue, Converter={StaticResource BoolToVis}}">
                                                <TextBlock Text="进度" FontSize="11" Foreground="#A0A4B0"
                                                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                <ItemsControl ItemsSource="{Binding PhaseSegments}" VerticalAlignment="Center">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <StackPanel Orientation="Horizontal"/>
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Width="32" Height="4" CornerRadius="2" Margin="1,0"
                                                                    Background="{Binding Color}"/>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                                <TextBlock Text="{Binding PhaseProgressText}" FontSize="11"
                                                           Foreground="#A0A4B0" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- 右侧：最优值 + 继续按钮 -->
                                        <StackPanel Grid.Column="2" VerticalAlignment="Top" Margin="20,0,0,0"
                                                    HorizontalAlignment="Right">
                                            <TextBlock Text="当前最优" FontSize="10" Foreground="#A0A4B0"
                                                       HorizontalAlignment="Right" Margin="0,0,0,2"/>
                                            <TextBlock Text="{Binding BestValueText}" FontSize="20" FontWeight="Medium"
                                                       HorizontalAlignment="Right">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="#0078D4"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding CanContinue}" Value="False">
                                                                <Setter Property="Foreground" Value="#A0A4B0"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <Button Content="继续优化 →" Padding="16,6" Margin="0,10,0,0"
                                                    Visibility="{Binding CanContinue, Converter={StaticResource BoolToVis}}"
                                                    Style="{StaticResource DOEOutlineBtn}" Foreground="#0078D4" FontSize="12"
                                                    Command="{Binding DataContext.ContinueProjectCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding ProjectId}"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- ── 空状态 ── -->
                <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,40,0,40">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasProjects}" Value="False">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="开始第一个优化项目" FontSize="15" FontWeight="SemiBold"
                               Foreground="#1A1F36" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                    <TextBlock HorizontalAlignment="Center" FontSize="12" Foreground="#8A8F9C"
                               TextAlignment="Center" Margin="0,0,0,20">
                        <Run Text="创建项目后，系统自动引导完成"/><LineBreak/>
                        <Run Text="筛选 → 路径探索 → 响应面优化 → 验证 全流程"/>
                    </TextBlock>
                    <Button Padding="24,10" Cursor="Hand" HorizontalAlignment="Center"
                            Command="{Binding DataContext.CreateProjectCommand, RelativeSource={RelativeSource AncestorType=Window}}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="#0078D4" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                    <TextBlock Text="＋ 新建项目" FontSize="13" FontWeight="SemiBold" Foreground="White"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Opacity" Value="0.9"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </DockPanel>
</UserControl>
