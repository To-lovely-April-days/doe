<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ══════════════════════════════════════════════════
         DOE 设计向导 — 冰蓝极简控件库
         配合 DOEDesignWizardView.xaml 使用
         ══════════════════════════════════════════════════ -->

    <!-- ═══ 色彩令牌 ═══ -->
    <Color x:Key="IcePrimary">#3A98B9</Color>
    <Color x:Key="IcePrimaryDark">#2E7E9C</Color>
    <Color x:Key="IcePrimaryLight">#EDF4F8</Color>
    <Color x:Key="IcePrimaryRing">#193A98B9</Color>

    <Color x:Key="IceText">#1A2B3C</Color>
    <Color x:Key="IceTextSec">#5A7080</Color>
    <Color x:Key="IceTextMuted">#8A9BAA</Color>
    <Color x:Key="IceTextHint">#A5B5C0</Color>

    <Color x:Key="IceBorder">#D8E2E8</Color>
    <Color x:Key="IceBorderHover">#B0C4CE</Color>
    <Color x:Key="IceBorderFocus">#3A98B9</Color>

    <Color x:Key="IceSurface">#F4F7F9</Color>
    <Color x:Key="IceSurfaceHover">#EDF1F4</Color>
    <Color x:Key="IceCard">#FFFFFF</Color>
    <Color x:Key="IceDivider">#E8EEF2</Color>

    <Color x:Key="IceDanger">#E24B4A</Color>
    <Color x:Key="IceDangerLight">#FCEBEB</Color>
    <Color x:Key="IceSuccess">#5DCAA5</Color>
    <Color x:Key="IceSuccessLight">#E6F5EE</Color>

    <SolidColorBrush x:Key="WzPrimary" Color="{StaticResource IcePrimary}"/>
    <SolidColorBrush x:Key="WzPrimaryDark" Color="{StaticResource IcePrimaryDark}"/>
    <SolidColorBrush x:Key="WzPrimaryLight" Color="{StaticResource IcePrimaryLight}"/>
    <SolidColorBrush x:Key="WzText" Color="{StaticResource IceText}"/>
    <SolidColorBrush x:Key="WzTextSec" Color="{StaticResource IceTextSec}"/>
    <SolidColorBrush x:Key="WzTextMuted" Color="{StaticResource IceTextMuted}"/>
    <SolidColorBrush x:Key="WzTextHint" Color="{StaticResource IceTextHint}"/>
    <SolidColorBrush x:Key="WzBorder" Color="{StaticResource IceBorder}"/>
    <SolidColorBrush x:Key="WzBorderHover" Color="{StaticResource IceBorderHover}"/>
    <SolidColorBrush x:Key="WzSurface" Color="{StaticResource IceSurface}"/>
    <SolidColorBrush x:Key="WzDivider" Color="{StaticResource IceDivider}"/>
    <SolidColorBrush x:Key="WzDanger" Color="{StaticResource IceDanger}"/>
    <SolidColorBrush x:Key="WzSuccess" Color="{StaticResource IceSuccess}"/>

    <!-- ═══ 文本输入框 ═══ -->
    <Style x:Key="WzTextBox" TargetType="TextBox">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="Foreground" Value="{StaticResource WzText}"/>
        <Setter Property="Background" Value="White"/>
        <Setter Property="CaretBrush" Value="{StaticResource WzPrimary}"/>
        <Setter Property="SelectionBrush" Value="{StaticResource WzPrimary}"/>
        <Setter Property="Padding" Value="11,9"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                            BorderBrush="{StaticResource WzBorder}" BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8" SnapsToDevicePixels="True">
                        <Grid>
                            <!-- Placeholder -->
                            <TextBlock x:Name="Placeholder" Text="{TemplateBinding Tag}"
                                       Foreground="{StaticResource WzTextHint}" FontSize="{TemplateBinding FontSize}"
                                       Margin="{TemplateBinding Padding}" VerticalAlignment="Center"
                                       Visibility="Collapsed" IsHitTestVisible="False"/>
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0"
                                          VerticalAlignment="Center" Focusable="False"
                                          HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"/>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <!-- Placeholder 显示 -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="Text" Value=""/>
                                <Condition Property="IsFocused" Value="False"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Placeholder" Property="Visibility" Value="Visible"/>
                        </MultiTrigger>
                        <!-- Hover -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource WzBorderHover}"/>
                        </Trigger>
                        <!-- Focus -->
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush">
                                <Setter.Value>
                                    <SolidColorBrush Color="{StaticResource IceBorderFocus}"/>
                                </Setter.Value>
                            </Setter>
                            <Setter TargetName="Bd" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect Color="{StaticResource IcePrimary}" BlurRadius="8" ShadowDepth="0" Opacity="0.12"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <!-- Disabled -->
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource WzSurface}"/>
                            <Setter Property="Foreground" Value="{StaticResource WzTextHint}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- 数值输入（等宽右对齐） -->
    <Style x:Key="WzNumBox" TargetType="TextBox" BasedOn="{StaticResource WzTextBox}">
        <Setter Property="FontFamily" Value="Consolas"/>
        <Setter Property="TextAlignment" Value="Right"/>
        <Setter Property="Padding" Value="11,9"/>
    </Style>

    <!-- ═══ 多行文本框 ═══ -->
    <Style x:Key="WzTextArea" TargetType="TextBox" BasedOn="{StaticResource WzTextBox}">
        <Setter Property="AcceptsReturn" Value="True"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
        <Setter Property="MinHeight" Value="72"/>
        <Setter Property="VerticalContentAlignment" Value="Top"/>
        <Setter Property="Padding" Value="11,9"/>
    </Style>

    <!-- ═══ 下拉框 ═══ -->
    <Style x:Key="WzComboBox" TargetType="ComboBox">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="Foreground" Value="{StaticResource WzText}"/>
        <Setter Property="Background" Value="White"/>
        <Setter Property="Padding" Value="11,8,28,8"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{StaticResource WzBorder}" BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8" SnapsToDevicePixels="True"/>
                        <ToggleButton x:Name="ToggleBtn" Focusable="False" ClickMode="Press"
                                      IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border Background="Transparent">
                                        <!-- 自定义箭头 -->
                                        <Path x:Name="Arrow" HorizontalAlignment="Right" VerticalAlignment="Center"
                                              Margin="0,0,12,0" Width="8" Height="5"
                                              Data="M0,0 L4,5 L8,0" Stroke="{StaticResource WzTextMuted}"
                                              StrokeThickness="1.5" StrokeLineJoin="Round" Fill="Transparent"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter TargetName="Arrow" Property="RenderTransform">
                                                <Setter.Value>
                                                    <RotateTransform Angle="180" CenterX="4" CenterY="2.5"/>
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </ToggleButton.Template>
                        </ToggleButton>
                        <ContentPresenter x:Name="ContentSite" IsHitTestVisible="False"
                                          Content="{TemplateBinding SelectionBoxItem}"
                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                          Margin="{TemplateBinding Padding}" VerticalAlignment="Center"/>
                        <!-- 下拉面板 -->
                        <Popup x:Name="PART_Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}"
                               AllowsTransparency="True" PopupAnimation="Slide">
                            <Border x:Name="DropBorder" Background="White" CornerRadius="8"
                                    BorderBrush="{StaticResource WzBorder}" BorderThickness="1"
                                    Margin="0,4,0,0" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="240"
                                    Effect="{x:Null}">
                                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="4">
                                    <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource WzBorderHover}"/>
                        </Trigger>
                        <Trigger Property="IsDropDownOpen" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource WzPrimary}"/>
                            <Setter TargetName="Bd" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect Color="{StaticResource IcePrimary}" BlurRadius="8" ShadowDepth="0" Opacity="0.12"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- 下拉选项 -->
    <Style x:Key="WzComboItem" TargetType="ComboBoxItem">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Foreground" Value="{StaticResource WzText}"/>
        <Setter Property="Padding" Value="10,7"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBoxItem">
                    <Border x:Name="Bd" Padding="{TemplateBinding Padding}" Background="Transparent" CornerRadius="5">
                        <ContentPresenter/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource WzSurface}"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource WzPrimaryLight}"/>
                            <Setter Property="Foreground" Value="{StaticResource WzPrimary}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- 行内紧凑下拉（因子表格用） -->
    <Style x:Key="WzComboCompact" TargetType="ComboBox" BasedOn="{StaticResource WzComboBox}">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Padding" Value="8,6,24,6"/>
    </Style>

    <!-- ═══ 复选框 ═══ -->
    <Style x:Key="WzCheckBox" TargetType="CheckBox">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Foreground" Value="{StaticResource WzText}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Padding" Value="8,0,0,0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border x:Name="Box" Width="18" Height="18" CornerRadius="5"
                                Background="White" BorderBrush="{StaticResource WzBorderHover}" BorderThickness="1"
                                VerticalAlignment="Center">
                            <Path x:Name="Check" Data="M3,8 L7,12 L13,4" Stroke="White" StrokeThickness="2"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                                  Width="16" Height="16" Stretch="None" Visibility="Collapsed"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ContentPresenter Margin="{TemplateBinding Padding}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Box" Property="BorderBrush" Value="{StaticResource WzPrimary}"/>
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Box" Property="Background" Value="{StaticResource WzPrimary}"/>
                            <Setter TargetName="Box" Property="BorderBrush" Value="{StaticResource WzPrimary}"/>
                            <Setter TargetName="Check" Property="Visibility" Value="Visible"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══ 单选按钮 ═══ -->
    <Style x:Key="WzRadio" TargetType="RadioButton">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Foreground" Value="{StaticResource WzText}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Padding" Value="8,0,0,0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border x:Name="Ring" Width="18" Height="18" CornerRadius="9"
                                Background="White" BorderBrush="{StaticResource WzBorderHover}" BorderThickness="1.5"
                                VerticalAlignment="Center">
                            <Ellipse x:Name="Dot" Width="8" Height="8" Fill="{StaticResource WzPrimary}"
                                     Visibility="Collapsed" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ContentPresenter Margin="{TemplateBinding Padding}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Ring" Property="BorderBrush" Value="{StaticResource WzPrimary}"/>
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Ring" Property="BorderBrush" Value="{StaticResource WzPrimary}"/>
                            <Setter TargetName="Dot" Property="Visibility" Value="Visible"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══ 主按钮（冰蓝填充） ═══ -->
    <Style x:Key="WzBtnPrimary" TargetType="Button">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Padding" Value="22,9"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="{StaticResource WzPrimary}" CornerRadius="9"
                            Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource WzPrimaryDark}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="RenderTransform">
                                <Setter.Value>
                                    <ScaleTransform ScaleX="0.98" ScaleY="0.98"/>
                                </Setter.Value>
                            </Setter>
                            <Setter TargetName="Bd" Property="RenderTransformOrigin" Value="0.5,0.5"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bd" Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══ 次要按钮（描边） ═══ -->
    <Style x:Key="WzBtnGhost" TargetType="Button">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Foreground" Value="{StaticResource WzTextSec}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Padding" Value="18,8"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="Transparent" CornerRadius="9"
                            Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True"
                            BorderBrush="{StaticResource WzBorderHover}" BorderThickness="1">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource WzSurface}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bd" Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══ 成功按钮（绿色） ═══ -->
    <Style x:Key="WzBtnSuccess" TargetType="Button">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Padding" Value="22,9"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="#1D8A5F" CornerRadius="9"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#167A52"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══ 虚线添加按钮 ═══ -->
    <Style x:Key="WzBtnAdd" TargetType="Button">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Foreground" Value="{StaticResource WzTextSec}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Padding" Value="0,9"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="Transparent" CornerRadius="8"
                            Padding="{TemplateBinding Padding}" BorderThickness="1">
                        <Border.BorderBrush>
                            <VisualBrush TileMode="None">
                                <VisualBrush.Visual>
                                    <Rectangle Width="100" Height="100" StrokeDashArray="6 4"
                                               Stroke="{StaticResource WzBorderHover}" StrokeThickness="1"
                                               RadiusX="8" RadiusY="8"/>
                                </VisualBrush.Visual>
                            </VisualBrush>
                        </Border.BorderBrush>
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource WzSurface}"/>
                            <Setter Property="Foreground" Value="{StaticResource WzText}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══ 删除按钮（行内小方块） ═══ -->
    <Style x:Key="WzBtnDel" TargetType="Button">
        <Setter Property="Width" Value="26"/>
        <Setter Property="Height" Value="26"/>
        <Setter Property="Foreground" Value="{StaticResource WzTextHint}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="Transparent" CornerRadius="7"
                            Width="{TemplateBinding Width}" Height="{TemplateBinding Height}">
                        <TextBlock Text="×" FontSize="{TemplateBinding FontSize}"
                                   Foreground="{TemplateBinding Foreground}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background">
                                <Setter.Value>
                                    <SolidColorBrush Color="{StaticResource IceDangerLight}"/>
                                </Setter.Value>
                            </Setter>
                            <Setter Property="Foreground">
                                <Setter.Value>
                                    <SolidColorBrush Color="{StaticResource IceDanger}"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══ 步骤徽章 ═══ -->
    <Style x:Key="WzStepBadge" TargetType="TextBlock">
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource WzPrimary}"/>
        <Setter Property="Padding" Value="10,3"/>
    </Style>

    <!-- ═══ 字段标签 ═══ -->
    <Style x:Key="WzLabel" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12.5"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Foreground" Value="{StaticResource WzTextSec}"/>
        <Setter Property="Margin" Value="0,0,0,6"/>
    </Style>

    <!-- ═══ 字段提示 ═══ -->
    <Style x:Key="WzHint" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="Foreground" Value="{StaticResource WzTextHint}"/>
        <Setter Property="Margin" Value="0,5,0,0"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <!-- ═══ 侧栏导航项 ═══ -->
    <Style x:Key="WzNavItem" TargetType="Border">
        <Setter Property="Padding" Value="22,9"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="BorderThickness" Value="2.5,0,0,0"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="Background" Value="Transparent"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#08000000"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ═══ 阶段选择卡片 ═══ -->
    <Style x:Key="WzPhaseChip" TargetType="Border">
        <Setter Property="Padding" Value="14"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="{StaticResource WzBorder}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="BorderBrush" Value="{StaticResource WzBorderHover}"/>
                <Setter Property="Background" Value="{StaticResource WzSurface}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ═══ 设计方法选择卡片 ═══ -->
    <Style x:Key="WzMethodCard" TargetType="Border">
        <Setter Property="Padding" Value="13,14"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="{StaticResource WzBorder}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="BorderBrush" Value="{StaticResource WzBorderHover}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ═══ 统计卡片（确认页） ═══ -->
    <Style x:Key="WzStatCard" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource WzSurface}"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Padding" Value="16,14"/>
    </Style>

    <!-- ═══ DataGrid 行样式（因子/响应表格） ═══ -->
    <Style x:Key="WzGridRow" TargetType="DataGridRow">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="{StaticResource WzDivider}"/>
        <Setter Property="BorderThickness" Value="0,0,0,0.5"/>
        <Setter Property="MinHeight" Value="38"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource WzSurface}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ═══ 行内紧凑输入框（表格单元格用） ═══ -->
    <Style x:Key="WzCellInput" TargetType="TextBox">
        <Setter Property="FontSize" Value="12.5"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="Foreground" Value="{StaticResource WzText}"/>
        <Setter Property="Background" Value="White"/>
        <Setter Property="CaretBrush" Value="{StaticResource WzPrimary}"/>
        <Setter Property="Padding" Value="8,6"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                            BorderBrush="{StaticResource WzBorder}" BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="7">
                        <ScrollViewer x:Name="PART_ContentHost" Margin="0" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource WzBorderHover}"/>
                        </Trigger>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource WzPrimary}"/>
                            <Setter TargetName="Bd" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect Color="{StaticResource IcePrimary}" BlurRadius="6" ShadowDepth="0" Opacity="0.1"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- 行内数值输入（等宽右对齐） -->
    <Style x:Key="WzCellNum" TargetType="TextBox" BasedOn="{StaticResource WzCellInput}">
        <Setter Property="FontFamily" Value="Consolas"/>
        <Setter Property="TextAlignment" Value="Right"/>
    </Style>

    <!-- ═══ 进度条段 ═══ -->
    <Style x:Key="WzProgressSeg" TargetType="Border">
        <Setter Property="Width" Value="18"/>
        <Setter Property="Height" Value="3"/>
        <Setter Property="CornerRadius" Value="1.5"/>
        <Setter Property="Background" Value="{StaticResource WzDivider}"/>
        <Setter Property="Margin" Value="0,0,2,0"/>
    </Style>

    <Style x:Key="WzProgressSegDone" TargetType="Border" BasedOn="{StaticResource WzProgressSeg}">
        <Setter Property="Background" Value="{StaticResource WzPrimary}"/>
    </Style>

</ResourceDictionary>
