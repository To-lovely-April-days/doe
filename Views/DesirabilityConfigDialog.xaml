<Window x:Class="MaxChemical.Modules.DOE.Views.DesirabilityConfigDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:oxy="http://oxyplot.org/wpf"
        Title="设置意愿 — Desirability 配置" Width="820" Height="580"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="配置每个响应变量的 Desirability 目标" 
                   FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12"/>

        <ScrollViewer Grid.Row="1">
            <ItemsControl ItemsSource="{Binding Configs}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,0,12" Padding="14" Background="#FAFBFC"
                                CornerRadius="8" BorderBrush="#E8EAED" BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="260"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <!-- 响应名称 + 目标选择 + 数据范围 -->
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                        <TextBlock Text="{Binding ResponseName}" FontSize="15" 
                                                   FontWeight="SemiBold" Foreground="#1A1F36" VerticalAlignment="Center"/>
                                        <ComboBox SelectedItem="{Binding Goal, UpdateSourceTrigger=PropertyChanged}" 
                                                  ItemsSource="{Binding GoalOptions}" Margin="16,0,0,0"
                                                  Width="100" VerticalAlignment="Center" FontSize="12"/>
                                        <TextBlock Text="{Binding DataRangeText}" FontSize="10" Foreground="#999" 
                                                   VerticalAlignment="Center" Margin="12,0,0,0"/>
                                    </StackPanel>

                                    <!-- ═══ 最大化: 目标值 + 最低可接受值 ═══ -->
                                    <StackPanel Visibility="{Binding IsMaximize, Converter={StaticResource BoolToVis}}">
                                        <Grid Margin="0,4,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="110"/>
                                                <ColumnDefinition Width="120"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="34"/>
                                                <RowDefinition Height="34"/>
                                            </Grid.RowDefinitions>

                                            <TextBlock Text="目标值（越大越好）:" FontSize="11" VerticalAlignment="Center" Foreground="#333"/>
                                            <TextBox Grid.Column="1" 
                                                     Text="{Binding TargetValue, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:F4}}"
                                                     VerticalAlignment="Center" FontSize="12" Padding="6,4" Margin="4,0"/>
                                            <TextBlock Grid.Column="2" Text="d = 1" FontSize="10" Foreground="#2E7D32" 
                                                       VerticalAlignment="Center" Margin="8,0,0,0"/>

                                            <TextBlock Grid.Row="1" Text="最低可接受值:" FontSize="11" VerticalAlignment="Center" Foreground="#333"/>
                                            <TextBox Grid.Row="1" Grid.Column="1"
                                                     Text="{Binding LowerBound, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:F4}}"
                                                     VerticalAlignment="Center" FontSize="12" Padding="6,4" Margin="4,0"/>
                                            <TextBlock Grid.Row="1" Grid.Column="2" Text="d = 0" FontSize="10" Foreground="#C62828" 
                                                       VerticalAlignment="Center" Margin="8,0,0,0"/>
                                        </Grid>
                                    </StackPanel>

                                    <!-- ═══ 最小化: 目标值 + 最高可接受值 ═══ -->
                                    <StackPanel Visibility="{Binding IsMinimize, Converter={StaticResource BoolToVis}}">
                                        <Grid Margin="0,4,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="110"/>
                                                <ColumnDefinition Width="120"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="34"/>
                                                <RowDefinition Height="34"/>
                                            </Grid.RowDefinitions>

                                            <TextBlock Text="目标值（越小越好）:" FontSize="11" VerticalAlignment="Center" Foreground="#333"/>
                                            <TextBox Grid.Column="1"
                                                     Text="{Binding TargetValue, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:F4}}"
                                                     VerticalAlignment="Center" FontSize="12" Padding="6,4" Margin="4,0"/>
                                            <TextBlock Grid.Column="2" Text="d = 1" FontSize="10" Foreground="#2E7D32" 
                                                       VerticalAlignment="Center" Margin="8,0,0,0"/>

                                            <TextBlock Grid.Row="1" Text="最高可接受值:" FontSize="11" VerticalAlignment="Center" Foreground="#333"/>
                                            <TextBox Grid.Row="1" Grid.Column="1"
                                                     Text="{Binding UpperBound, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:F4}}"
                                                     VerticalAlignment="Center" FontSize="12" Padding="6,4" Margin="4,0"/>
                                            <TextBlock Grid.Row="1" Grid.Column="2" Text="d = 0" FontSize="10" Foreground="#C62828" 
                                                       VerticalAlignment="Center" Margin="8,0,0,0"/>
                                        </Grid>
                                    </StackPanel>

                                    <!-- ═══ 望目: 下限 + 目标值 + 上限 ═══ -->
                                    <StackPanel Visibility="{Binding IsTarget, Converter={StaticResource BoolToVis}}">
                                        <Grid Margin="0,4,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="110"/>
                                                <ColumnDefinition Width="120"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="34"/>
                                                <RowDefinition Height="34"/>
                                                <RowDefinition Height="34"/>
                                            </Grid.RowDefinitions>

                                            <TextBlock Text="下限:" FontSize="11" VerticalAlignment="Center" Foreground="#333"/>
                                            <TextBox Grid.Column="1"
                                                     Text="{Binding LowerBound, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:F4}}"
                                                     VerticalAlignment="Center" FontSize="12" Padding="6,4" Margin="4,0"/>
                                            <TextBlock Grid.Column="2" Text="d = 0" FontSize="10" Foreground="#C62828" 
                                                       VerticalAlignment="Center" Margin="8,0,0,0"/>

                                            <TextBlock Grid.Row="1" Text="目标值:" FontSize="11" VerticalAlignment="Center" 
                                                       Foreground="#333" FontWeight="SemiBold"/>
                                            <TextBox Grid.Row="1" Grid.Column="1"
                                                     Text="{Binding TargetValue, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:F4}}"
                                                     VerticalAlignment="Center" FontSize="12" Padding="6,4" Margin="4,0" FontWeight="SemiBold"/>
                                            <TextBlock Grid.Row="1" Grid.Column="2" Text="d = 1" FontSize="10" Foreground="#2E7D32" 
                                                       VerticalAlignment="Center" Margin="8,0,0,0" FontWeight="SemiBold"/>

                                            <TextBlock Grid.Row="2" Text="上限:" FontSize="11" VerticalAlignment="Center" Foreground="#333"/>
                                            <TextBox Grid.Row="2" Grid.Column="1"
                                                     Text="{Binding UpperBound, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:F4}}"
                                                     VerticalAlignment="Center" FontSize="12" Padding="6,4" Margin="4,0"/>
                                            <TextBlock Grid.Row="2" Grid.Column="2" Text="d = 0" FontSize="10" Foreground="#C62828" 
                                                       VerticalAlignment="Center" Margin="8,0,0,0"/>
                                        </Grid>
                                    </StackPanel>

                                    <!-- 重要度 -->
                                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                        <TextBlock Text="重要度:" FontSize="11" VerticalAlignment="Center" Foreground="#555"/>
                                        <Slider Minimum="1" Maximum="5" Value="{Binding Importance}" 
                                                IsSnapToTickEnabled="True" TickFrequency="1" 
                                                Width="120" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Importance}" FontSize="11" VerticalAlignment="Center" 
                                                   Margin="6,0,0,0" FontWeight="SemiBold" Foreground="#0078D4"/>
                                    </StackPanel>

                                    <!-- 高级选项 -->
                                    <Expander Header="高级选项" FontSize="10" Foreground="#999" Margin="0,6,0,0" IsExpanded="False">
                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                            <TextBlock Text="形状 s:" FontSize="11" VerticalAlignment="Center" Foreground="#555"/>
                                            <TextBox Text="{Binding Shape, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:F2}}"
                                                     Width="70" Margin="8,0,0,0" FontSize="11" Padding="4,3"/>
                                            <TextBlock Text="{Binding ShapeHint}" FontSize="10" Foreground="#999" 
                                                       VerticalAlignment="Center" Margin="8,0,0,0"/>
                                        </StackPanel>
                                    </Expander>
                                </StackPanel>

                                <!-- 右: d(y) 预览曲线 -->
                                <Border Grid.Column="1" Margin="14,0,0,0" BorderBrush="#E8EAED" BorderThickness="1" CornerRadius="6">
                                    <oxy:PlotView Model="{Binding PreviewPlot}" Height="220" Background="White" Margin="2"/>
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="恢复默认" Padding="16,6" Margin="0,0,12,0" Click="ResetDefaults_Click"
                    Background="#FFF3E0" BorderBrush="#FFB74D" Cursor="Hand" FontSize="12"/>
            <Button Content="取消" Padding="20,6" Margin="0,0,8,0" Click="Cancel_Click" FontSize="12"/>
            <Button Content="确定" Padding="20,6" Background="#0078D4" Foreground="White" Click="OK_Click" 
                    FontSize="12" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>
