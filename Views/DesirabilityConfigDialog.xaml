<Window x:Class="MaxChemical.Modules.DOE.Views.DesirabilityConfigDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MaxChemical.Modules.DOE.Views"
        xmlns:oxy="http://oxyplot.org/wpf"
        mc:Ignorable="d"
       Title="设置意愿 — Desirability 配置" Width="800" Height="600"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <TextBlock Text="配置每个响应变量的 Desirability 目标" 
                   FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12"/>

        <!-- 响应配置列表 -->
        <ScrollViewer Grid.Row="1">
            <ItemsControl ItemsSource="{Binding Configs}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,0,12" Padding="12" Background="#FAFBFC"
                                CornerRadius="8" BorderBrush="#E8EAED" BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="250"/>
                                </Grid.ColumnDefinitions>

                                <!-- 左: 参数设置 -->
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding ResponseName}" FontSize="14" 
                                               FontWeight="SemiBold" Foreground="#1A1F36" Margin="0,0,0,8"/>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="30"/>
                                            <RowDefinition Height="30"/>
                                            <RowDefinition Height="30"/>
                                            <RowDefinition Height="30"/>
                                            <RowDefinition Height="30"/>
                                            <RowDefinition Height="30"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock Text="目标:" VerticalAlignment="Center"/>
                                        <ComboBox SelectedItem="{Binding Goal, UpdateSourceTrigger=PropertyChanged}" 
          Width="120" HorizontalAlignment="Left"
          ItemsSource="{Binding GoalOptions}"/>

                                        <TextBlock Grid.Row="1" Text="下限 L:" VerticalAlignment="Center"/>
                                        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Lower, UpdateSourceTrigger=PropertyChanged}" Width="100" HorizontalAlignment="Left"/>

                                        <TextBlock Grid.Row="2" Text="目标 T:" VerticalAlignment="Center"/>
                                        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Target, UpdateSourceTrigger=PropertyChanged}" Width="100" HorizontalAlignment="Left"/>

                                        <TextBlock Grid.Row="3" Text="上限 U:" VerticalAlignment="Center"/>
                                        <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding Upper, UpdateSourceTrigger=PropertyChanged}" Width="100" HorizontalAlignment="Left"/>

                                        <TextBlock Grid.Row="4" Text="重要度:" VerticalAlignment="Center"/>
                                        <Slider Grid.Row="4" Grid.Column="1" Minimum="1" Maximum="5" 
                                                Value="{Binding Importance}" IsSnapToTickEnabled="True" TickFrequency="1" Width="150" HorizontalAlignment="Left"/>

                                        <TextBlock Grid.Row="5" Text="形状 s:" VerticalAlignment="Center"/>
                                        <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding Shape, UpdateSourceTrigger=PropertyChanged}" Width="100" HorizontalAlignment="Left"/>
                                    </Grid>
                                </StackPanel>

                                <!-- 右: d(y) 预览曲线 -->
                                <Border Grid.Column="1" Margin="12,0,0,0" BorderBrush="#E8EAED" BorderThickness="1" CornerRadius="4">
                                    <oxy:PlotView Model="{Binding PreviewPlot}" Height="200" Background="White" Margin="2"/>
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- 底部按钮 -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="取消" Padding="20,6" Margin="0,0,8,0" Click="Cancel_Click"/>
            <Button Content="确定" Padding="20,6" Background="#0078D4" Foreground="White" Click="OK_Click"/>
        </StackPanel>
    </Grid>
</Window>
