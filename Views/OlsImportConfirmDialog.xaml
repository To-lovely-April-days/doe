<Window x:Class="MaxChemical.Modules.DOE.Views.OlsImportConfirmDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="导入数据确认" Width="780" Height="520"
        WindowStartupLocation="CenterOwner"
        Background="#F5F5F5" ResizeMode="CanResizeWithGrip">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="配置列角色和类型" FontSize="16" FontWeight="SemiBold" Foreground="#1B4F72"/>
            <TextBlock Text="{Binding FilePath}" FontSize="11" Foreground="#888" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- 说明 -->
        <Border Grid.Row="1" Background="#EBF5FB" Padding="12,8" CornerRadius="6" Margin="0,0,0,12">
            <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#2C3E50">
                请为每一列指定角色：「因子」= 实验输入参数，「响应」= 实验结果（至少1个），「忽略」= 不参与分析。
                因子需要进一步选择类型：「连续」= 数值型，「类别」= 分类型（如催化剂A/B/C）。
                系统已根据数据自动预填，请核实后确认。
            </TextBlock>
        </Border>

        <!-- 列配置表 -->
        <DataGrid Grid.Row="2" ItemsSource="{Binding Columns}" AutoGenerateColumns="False"
                  CanUserAddRows="False" CanUserDeleteRows="False"
                  GridLinesVisibility="Horizontal" AlternatingRowBackground="#FAFAFA"
                  BorderBrush="#DDD" BorderThickness="1"
                  RowHeight="32" HeadersVisibility="Column">
            <DataGrid.Columns>
                <DataGridTextColumn Header="列名" Binding="{Binding ColumnName}" Width="120" IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="Margin" Value="6,0"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTemplateColumn Header="角色" Width="110">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <ComboBox ItemsSource="{Binding RoleOptions}" SelectedItem="{Binding Role, UpdateSourceTrigger=PropertyChanged}"
                                      Margin="4,2" FontSize="11"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="因子类型" Width="110">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <ComboBox ItemsSource="{Binding FactorTypeOptions}" SelectedItem="{Binding FactorType, UpdateSourceTrigger=PropertyChanged}"
                                      IsEnabled="{Binding IsFactorTypeEnabled}" Margin="4,2" FontSize="11"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="数值列" Binding="{Binding IsAllNumeric}" Width="55" IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                            <Setter Property="Foreground" Value="#888"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="唯一值" Binding="{Binding UniqueCount}" Width="55" IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                            <Setter Property="Foreground" Value="#888"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="数据预览（前5行）" Binding="{Binding PreviewText}" Width="*" IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#666"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="Margin" Value="6,0"/>
                            <Setter Property="FontSize" Value="10.5"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- 统计摘要 -->
        <Border Grid.Row="3" Margin="0,10,0,0" Padding="10,6" Background="White" CornerRadius="4" BorderBrush="#DDD" BorderThickness="1">
            <TextBlock x:Name="SummaryText" FontSize="11" Foreground="#555"/>
        </Border>

        <!-- 底部按钮 -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="取消" Width="80" Padding="0,6" Margin="0,0,10,0" Click="Cancel_Click"/>
            <Button Content="确认导入" Width="100" Padding="0,6"
                    Background="#2E75B6" Foreground="White" FontWeight="SemiBold"
                    Click="Confirm_Click"/>
        </StackPanel>
    </Grid>
</Window>